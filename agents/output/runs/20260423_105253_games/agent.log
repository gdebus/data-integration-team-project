        if "eval_id" in fused_df.columns:
            eval_id = str(row_dict.get("eval_id", "")).strip()
            if eval_id and eval_id in gold_ids:
                candidate_ids.append(eval_id)

        source_ids = _parse_source_ids(row_dict.get("_fusion_sources"))
        source_hits = [sid for sid in source_ids if sid in gold_ids]
        candidate_ids.extend(source_hits)

        if not candidate_ids and cluster_id:
            candidate_ids.append(cluster_id)

        seen = set()
        for cid in candidate_ids:
            if cid in seen:
                continue
            seen.add(cid)
            out = dict(row_dict)
            out["eval_id"] = cid
            out["_eval_cluster_id"] = cluster_id
            expanded_rows.append(out)

    if not expanded_rows:
        fallback = fused_df.copy()
        fallback["eval_id"] = fallback["_id"].astype(str) if "_id" in fallback.columns else fallback["id"].astype(str)
        fallback["_eval_cluster_id"] = fallback["eval_id"]
        return fallback

    fused_eval = pd.DataFrame(expanded_rows)

    if "_fusion_confidence" in fused_eval.columns:
        fused_eval["_fusion_confidence"] = pd.to_numeric(fused_eval["_fusion_confidence"], errors="coerce").fillna(0.0)
        fused_eval = fused_eval.sort_values("_fusion_confidence", ascending=False)

    fused_eval = fused_eval.drop_duplicates(subset=["eval_id"], keep="first")
    return fused_eval


# ================================
# 2. LOAD DATA
# ================================
fused = pd.read_csv(FUSION_PATH)
fusion_test_set = load_xml(GOLD_PATH, name="fusion_test_set", nested_handling="aggregate")

fused_eval = build_eval_view(fused, fusion_test_set)


# ================================
# 3. NORMALIZE TO SAME REPRESENTATION
# Use validation/test-set representation as target.
# Keep releaseYear as string for year_only_match.
# ================================
for df in [fused_eval, fusion_test_set]:
    for col in df.columns:
        if col in {"id", "_id", "eval_id", "_eval_cluster_id", "_fusion_sources", "_fusion_source_datasets", "_fusion_metadata"}:
            continue
        if col == "releaseYear":
            df[col] = df[col].apply(lambda x: str(x).strip() if not _safe_is_missing(x) else x)
        elif df[col].dtype == object:
            df[col] = df[col].apply(_strip_text)

# Normalize list-like columns consistently
list_eval_columns = detect_list_like_columns(
    [fused_eval, fusion_test_set],
    exclude_columns={"id", "_id", "eval_id", "_eval_cluster_id", "_fusion_confidence"},
)
list_eval_columns = [c for c in list_eval_columns if not str(c).startswith("_")]

if list_eval_columns:
    fused_eval, fusion_test_set = normalize_list_like_columns([fused_eval, fusion_test_set], list_eval_columns)
    for col in list_eval_columns:
        if col in fused_eval.columns:
            fused_eval[col] = fused_eval[col].apply(_normalize_list_text_case)
        if col in fusion_test_set.columns:
            fusion_test_set[col] = fusion_test_set[col].apply(_normalize_list_text_case)

# Coerce numeric-like columns consistently in BOTH fused and gold
numeric_eval_columns = [c for c in ["criticScore", "userScore", "globalSales"] if c in fused_eval.columns or c in fusion_test_set.columns]
fused_eval = _coerce_numeric_like(fused_eval, numeric_eval_columns)
fusion_test_set = _coerce_numeric_like(fusion_test_set, numeric_eval_columns)


# ================================
# 4. ID ALIGNMENT DIAGNOSTICS
# ================================
gold_ids = set(fusion_test_set["id"].dropna().astype(str).tolist()) if "id" in fusion_test_set.columns else set()
direct_cov = len(set(fused["_id"].astype(str).tolist()) & gold_ids) if "_id" in fused.columns else 0
eval_cov = len(set(fused["eval_id"].astype(str).tolist()) & gold_ids) if "eval_id" in fused.columns else 0
mapped_cov = len(set(fused_eval["eval_id"].astype(str).tolist()) & gold_ids) if "eval_id" in fused_eval.columns else 0

print(json.dumps({
    "stage": "sealed_test",
    "id_alignment": {
        "gold_records": len(gold_ids),
        "direct__id_coverage": direct_cov,
        "provided_eval_id_coverage": eval_cov,
        "mapped_eval_id_coverage": mapped_cov,
    }
}, indent=2))


# ================================
# 5. REGISTER EVALUATION FUNCTIONS
# Only for meaningful columns in BOTH datasets.
# Do not overuse exact matching.
# ================================
strategy = DataFusionStrategy("evaluation_strategy")
eval_funcs_summary = {}
skipped_columns = {}

shared_columns = sorted((set(fused_eval.columns) & set(fusion_test_set.columns)) - {"id", "_id", "eval_id", "_eval_cluster_id"})
meaningful_columns = []

for col in shared_columns:
    if str(col).startswith("_"):
        skipped_columns[col] = "internal_column"
        continue
    if _is_nested_subfield(col):
        skipped_columns[col] = "nested_subfield_skipped"
        continue
    if not _has_meaningful_values(fused_eval, col):
        skipped_columns[col] = "no_meaningful_values_in_fused"
        continue
    if not _has_meaningful_values(fusion_test_set, col):
        skipped_columns[col] = "no_meaningful_values_in_gold"
        continue
    meaningful_columns.append(col)

def register_eval(column, fn, fn_name, **kwargs):
    strategy.add_evaluation_function(column, fn, **kwargs)
    args = ",".join(f"{k}={v}" for k, v in kwargs.items()) if kwargs else ""
    eval_funcs_summary[column] = f"{column}:{fn_name}" + (f"({args})" if args else "")

for col in meaningful_columns:
    col_l = str(col).lower()

    if col in list_eval_columns:
        register_eval(col, set_equality_match, "set_equality_match")
    elif col in {"releaseYear"} or "year" in col_l or "date" in col_l:
        register_eval(col, year_only_match, "year_only_match")
    elif col in {"criticScore"}:
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=5.0)
    elif col in {"userScore"}:
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
    elif any(tok in col_l for tok in ["score", "rating", "sales", "count", "duration", "price", "revenue", "latitude", "longitude"]):
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=0.01)
    elif any(tok in col_l for tok in ["id", "code"]) or col in {"ESRB"}:
        register_eval(col, exact_match, "exact_match")
    elif any(tok in col_l for tok in ["is_", "has_", "flag", "bool", "boolean"]):
        register_eval(col, boolean_match, "boolean_match")
    else:
        register_eval(col, tokenized_match, "tokenized_match", threshold=0.85)

print("EVAL_FUNCTIONS:", " | ".join(eval_funcs_summary[c] for c in sorted(eval_funcs_summary)))
print(json.dumps({"skipped_columns": skipped_columns}, indent=2))


# ================================
# 6. RUN EVALUATION
# Prefer mapped eval_id view.
# ================================
evaluator = DataFusionEvaluator(
    strategy,
    debug=True,
    debug_format="json",
    debug_file=DEBUG_OUTPUT_PATH,
)

evaluation_results = evaluator.evaluate(
    fused_df=fused_eval,
    fused_id_column="eval_id",
    gold_df=fusion_test_set,
    gold_id_column="id",
)


# ================================
# 7. PRINT STRUCTURED METRICS
# ================================
print(json.dumps({
    "stage": "sealed_test",
    "evaluation_functions": eval_funcs_summary,
    "results": evaluation_results,
}, indent=2, default=str))


# ================================
# 8. SAVE OUTPUT
# ================================
with open(EVAL_OUTPUT_PATH, "w") as f:
    json.dump(evaluation_results, f, indent=4, default=str)
