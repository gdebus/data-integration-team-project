    from list_normalization import detect_list_like_columns, normalize_list_like_columns


# ================================
# 0. PATHS
# ================================
OUTPUT_DIR = "output/runs/20260423_105253_games"
FUSION_PATH = os.path.join(OUTPUT_DIR, "data_fusion", "fusion_data.csv")
EVAL_DIR = os.path.join(OUTPUT_DIR, "pipeline_evaluation")
EVAL_OUTPUT_PATH = os.path.join(EVAL_DIR, "pipeline_evaluation.json")
DEBUG_PATH = os.path.join(EVAL_DIR, "debug_fusion_eval.jsonl")
EVAL_SET_PATH = "input/datasets/games/testsets/validation_set_fusion.xml"

os.makedirs(EVAL_DIR, exist_ok=True)


# ================================
# 1. HELPERS
# ================================
def _safe_is_missing(value):
    if value is None:
        return True
    try:
        result = pd.isna(value)
        if hasattr(result, "__len__") and not isinstance(result, str):
            return False
        return bool(result)
    except Exception:
        return False


def _is_meaningful_series(series):
    if series is None or len(series) == 0:
        return False

    def _is_meaningful(v):
        if _safe_is_missing(v):
            return False
        if isinstance(v, (list, tuple, set)):
            return any(str(x).strip() for x in v if not _safe_is_missing(x))
        text = str(v).strip()
        return text != ""

    return series.apply(_is_meaningful).any()


def _parse_source_ids(value):
    if value is None:
        return []
    if isinstance(value, (list, tuple, set)):
        return [str(v) for v in value if str(v).strip()]
    text = str(value).strip()
    if not text:
        return []
    for parser in (json.loads, ast.literal_eval):
        try:
            parsed = parser(text)
            if isinstance(parsed, (list, tuple, set)):
                return [str(v) for v in parsed if str(v).strip()]
        except Exception:
            pass
    return []


def build_eval_view(fused_df, gold_df):
    """
    Build an evaluation-aligned view by mapping every gold ID to the fused row
    whose _fusion_sources contains that gold ID. This is more robust than relying
    on a precomputed eval_id when clusters contain multiple source records.
    """
    gold_ids = gold_df["id"].dropna().astype(str).tolist() if "id" in gold_df.columns else []
    gold_id_set = set(gold_ids)

    expanded_rows = []
    matched_gold_ids = set()

    if "_fusion_sources" in fused_df.columns:
        for _, row in fused_df.iterrows():
            row_dict = row.to_dict()
            cluster_id = str(row_dict.get("_id", ""))
            source_ids = _parse_source_ids(row_dict.get("_fusion_sources"))
            overlap = [sid for sid in source_ids if sid in gold_id_set]

            if overlap:
                for gid in overlap:
                    enriched = dict(row_dict)
                    enriched["eval_id"] = gid
                    enriched["_eval_cluster_id"] = cluster_id
                    expanded_rows.append(enriched)
                    matched_gold_ids.add(gid)

    # If some gold IDs were not found in _fusion_sources, fall back to existing eval_id if present
    if "eval_id" in fused_df.columns:
        fallback_rows = fused_df.copy()
        fallback_rows["eval_id"] = fallback_rows["eval_id"].astype(str)
        for _, row in fallback_rows.iterrows():
            gid = str(row["eval_id"])
            if gid in gold_id_set and gid not in matched_gold_ids:
                row_dict = row.to_dict()
                row_dict["_eval_cluster_id"] = str(row_dict.get("_id", gid))
                expanded_rows.append(row_dict)
                matched_gold_ids.add(gid)

    if not expanded_rows:
        fallback = fused_df.copy()
        if "eval_id" in fallback.columns:
            fallback["eval_id"] = fallback["eval_id"].astype(str)
        else:
            fallback["eval_id"] = fallback["_id"].astype(str) if "_id" in fallback.columns else fallback.index.astype(str)
        fallback["_eval_cluster_id"] = fallback["_id"].astype(str) if "_id" in fallback.columns else fallback["eval_id"]
        return fallback

    fused_eval = pd.DataFrame(expanded_rows)

    if "_fusion_confidence" in fused_eval.columns:
        fused_eval["_fusion_confidence"] = pd.to_numeric(fused_eval["_fusion_confidence"], errors="coerce").fillna(0.0)
        fused_eval = fused_eval.sort_values("_fusion_confidence", ascending=False)

    fused_eval = fused_eval.drop_duplicates(subset=["eval_id"], keep="first")
    return fused_eval


def _normalize_list_text_case(value):
    if _safe_is_missing(value):
        return value
    if isinstance(value, (list, tuple, set)):
        vals = [str(v).strip().lower() for v in value if not _safe_is_missing(v) and str(v).strip()]
        return vals
    text = str(value).strip()
    return text.lower() if text else text


def _normalize_text(value):
    if _safe_is_missing(value):
        return value
    if isinstance(value, (list, tuple, set)):
        return [str(v).strip() for v in value if not _safe_is_missing(v) and str(v).strip()]
    text = str(value).strip()
    return text if text else pd.NA


def _coerce_numeric_like(df, cols):
    for col in cols:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce")
            non_null = df[col].dropna()
            if len(non_null) > 0:
                try:
                    if non_null.apply(lambda x: float(x).is_integer()).all():
                        df[col] = df[col].astype("Int64")
                except Exception:
                    pass
    return df


def _has_nested_pattern(column_name):
    text = str(column_name)
    return text.count("_") >= 2


# ================================
# 2. LOAD DATA
# ================================
fused = pd.read_csv(FUSION_PATH)
fusion_eval_set = load_xml(EVAL_SET_PATH, name="fusion_validation_set", nested_handling="aggregate")
fused_eval = build_eval_view(fused, fusion_eval_set)

print(json.dumps({
    "stage": "validation",
    "fused_path": FUSION_PATH,
    "gold_path": EVAL_SET_PATH,
    "fused_rows": int(len(fused)),
    "gold_rows": int(len(fusion_eval_set)),
    "fused_eval_rows": int(len(fused_eval)),
}, indent=2))


# ================================
# 3. NORMALIZE TO VALIDATION REPRESENTATION
#    - Do NOT country-normalize here.
#    - Keep dates as strings for year_only_match.
# ================================
for df in [fused_eval, fusion_eval_set]:
    for col in df.columns:
        if col in {"id", "_id", "eval_id", "_eval_cluster_id", "_fusion_sources"} or col.startswith("_"):
            continue
        if col == "releaseYear":
            df[col] = df[col].apply(lambda x: str(x).strip() if not _safe_is_missing(x) and str(x).strip() else pd.NA)
        else:
            df[col] = df[col].apply(_normalize_text)

# Normalize list-like columns consistently on both sides
list_eval_columns = detect_list_like_columns(
    [fused_eval, fusion_eval_set],
    exclude_columns={"id", "_id", "eval_id", "_eval_cluster_id", "_fusion_confidence"},
)
list_eval_columns = [c for c in list_eval_columns if not c.startswith("_")]

if list_eval_columns:
    fused_eval, fusion_eval_set = normalize_list_like_columns([fused_eval, fusion_eval_set], list_eval_columns)
    for col in list_eval_columns:
        if col in fused_eval.columns:
            fused_eval[col] = fused_eval[col].apply(_normalize_list_text_case)
        if col in fusion_eval_set.columns:
            fusion_eval_set[col] = fusion_eval_set[col].apply(_normalize_list_text_case)

# Coerce numeric-like columns consistently in both frames
numeric_cols = [
    col for col in ["criticScore", "userScore", "globalSales"]
    if col in fused_eval.columns and col in fusion_eval_set.columns
]
fused_eval = _coerce_numeric_like(fused_eval, numeric_cols)
fusion_eval_set = _coerce_numeric_like(fusion_eval_set, numeric_cols)


# ================================
# 4. ID ALIGNMENT DIAGNOSTICS
# ================================
gold_ids = set(fusion_eval_set["id"].dropna().astype(str).tolist()) if "id" in fusion_eval_set.columns else set()
direct_cov = len(set(fused["eval_id"].astype(str).tolist()) & gold_ids) if "eval_id" in fused.columns else 0
mapped_cov = len(set(fused_eval["eval_id"].astype(str).tolist()) & gold_ids) if "eval_id" in fused_eval.columns else 0

print(json.dumps({
    "id_alignment": {
        "gold_ids": len(gold_ids),
        "direct_eval_id_coverage": direct_cov,
        "mapped_eval_id_coverage": mapped_cov,
    }
}, indent=2))


# ================================
# 5. REGISTER EVALUATION FUNCTIONS
# ================================
strategy = DataFusionStrategy("games_validation_evaluation")
eval_funcs_summary = {}

def register_eval(column, fn, fn_name, **kwargs):
    strategy.add_evaluation_function(column, fn, **kwargs)
    args = ",".join(f"{k}={v}" for k, v in kwargs.items()) if kwargs else ""
    eval_funcs_summary[column] = f"{fn_name}({args})" if args else fn_name


shared_columns = sorted(
    c for c in (set(fused_eval.columns) & set(fusion_eval_set.columns))
    if c not in {"id", "_id", "eval_id", "_eval_cluster_id", "_fusion_sources", "_fusion_confidence"}
    and not c.startswith("_")
)

registered_columns = []
skipped_columns = {}

for col in shared_columns:
    if _has_nested_pattern(col):
        skipped_columns[col] = "nested_structural_column"
        continue

    if not _is_meaningful_series(fusion_eval_set[col]):
        skipped_columns[col] = "gold_empty_or_non_meaningful"
        continue

    if not _is_meaningful_series(fused_eval[col]):
        skipped_columns[col] = "fused_empty_or_non_meaningful"
        continue

    if col in list_eval_columns:
        register_eval(col, set_equality_match, "set_equality_match")
        registered_columns.append(col)
        continue

    lc = col.lower()

    if col == "releaseYear" or "date" in lc or lc.endswith("year"):
        register_eval(col, year_only_match, "year_only_match")
    elif lc in {"criticscore", "critic_score"}:
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=5.0)
    elif lc in {"userscore", "user_score"}:
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
    elif lc in {"globalsales", "global_sales", "sales"}:
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=0.01)
    elif lc in {"esrb"}:
        register_eval(col, exact_match, "exact_match")
    elif lc.startswith("is_") or lc.startswith("has_") or lc in {"active", "enabled", "available"}:
        register_eval(col, boolean_match, "boolean_match")
    else:
        register_eval(col, tokenized_match, "tokenized_match", threshold=0.85)

    registered_columns.append(col)

print("[EVALUATION_FUNCTIONS] " + " | ".join(f"{k}:{v}" for k, v in sorted(eval_funcs_summary.items())))
print(json.dumps({
    "registered_columns": registered_columns,
    "skipped_columns": skipped_columns,
    "list_eval_columns": list_eval_columns,
}, indent=2))


# ================================
# 6. RUN EVALUATION
# ================================
evaluator = DataFusionEvaluator(
    strategy,
    debug=True,
    debug_format="json",
    debug_file=DEBUG_PATH,
)

evaluation_results = evaluator.evaluate(
    fused_df=fused_eval,
    fused_id_column="eval_id",
    gold_df=fusion_eval_set,
    gold_id_column="id",
)


# ================================
# 7. PRINT STRUCTURED METRICS
# ================================
print(json.dumps({
    "stage": "validation",
    "evaluation_metrics": evaluation_results
}, indent=2, default=str))


# ================================
# 8. WRITE RESULTS
# ================================
with open(EVAL_OUTPUT_PATH, "w", encoding="utf-8") as f:
    json.dump(evaluation_results, f, indent=4, ensure_ascii=False)
