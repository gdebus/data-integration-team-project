            parsed = parser(text)
            if isinstance(parsed, (list, tuple, set)):
                return [str(v) for v in parsed if not _safe_is_missing(v)]
        except Exception:
            pass
    return []


def _normalize_scalar_text(value):
    if _safe_is_missing(value):
        return value
    return str(value).strip()


def _normalize_list_text_case(value):
    if _safe_is_missing(value):
        return value
    if isinstance(value, (list, tuple, set)):
        cleaned = [str(v).strip().lower() for v in value if not _safe_is_missing(v) and str(v).strip()]
        return cleaned
    text = str(value).strip()
    return text.lower() if text else text


def _meaningful_nonempty_series(df, col):
    if col not in df.columns:
        return pd.Series(dtype="object")
    s = df[col]
    s = s.dropna()
    if s.empty:
        return s.astype("object")
    s = s.astype(str).str.strip().replace("", pd.NA).dropna()
    return s


def _looks_nested_subfield(col):
    parts = str(col).split("_")
    return len(parts) >= 3 and parts[0] == parts[1] or len(parts) >= 3


def _build_eval_view_by_gold_lookup(fused_df, gold_df):
    gold_ids = gold_df["id"].dropna().astype(str).tolist() if "id" in gold_df.columns else []
    gold_id_set = set(gold_ids)
    rows = []

    if "_fusion_sources" not in fused_df.columns:
        fallback = fused_df.copy()
        fallback["eval_id"] = fallback["_id"].astype(str) if "_id" in fallback.columns else fallback.index.astype(str)
        fallback["_eval_cluster_id"] = fallback["eval_id"]
        return fallback

    source_map = {}
    for idx, row in fused_df.iterrows():
        srcs = _parse_source_ids(row.get("_fusion_sources"))
        for sid in srcs:
            source_map.setdefault(str(sid), []).append(idx)

    seen_gold = set()
    for gid in gold_ids:
        matched_rows = source_map.get(gid, [])
        if not matched_rows:
            continue
        for ridx in matched_rows:
            row = fused_df.loc[ridx].to_dict()
            row["eval_id"] = gid
            row["_eval_cluster_id"] = str(row.get("_id", gid))
            rows.append(row)
            seen_gold.add(gid)

    if not rows:
        fallback = fused_df.copy()
        fallback["eval_id"] = fallback["_id"].astype(str) if "_id" in fallback.columns else fallback.index.astype(str)
        fallback["_eval_cluster_id"] = fallback["eval_id"]
        return fallback

    eval_df = pd.DataFrame(rows)
    if "_fusion_confidence" in eval_df.columns:
        eval_df["_fusion_confidence"] = pd.to_numeric(eval_df["_fusion_confidence"], errors="coerce").fillna(0.0)
        eval_df = eval_df.sort_values("_fusion_confidence", ascending=False)
    eval_df = eval_df.drop_duplicates(subset=["eval_id"], keep="first")

    missing_gold = gold_id_set - set(eval_df["eval_id"].astype(str).tolist())
    if missing_gold:
        if "_id" in fused_df.columns:
            direct = fused_df[fused_df["_id"].astype(str).isin(missing_gold)].copy()
            if not direct.empty:
                direct["eval_id"] = direct["_id"].astype(str)
                direct["_eval_cluster_id"] = direct["_id"].astype(str)
                eval_df = pd.concat([eval_df, direct], ignore_index=True)
                if "_fusion_confidence" in eval_df.columns:
                    eval_df["_fusion_confidence"] = pd.to_numeric(eval_df["_fusion_confidence"], errors="coerce").fillna(0.0)
                    eval_df = eval_df.sort_values("_fusion_confidence", ascending=False)
                eval_df = eval_df.drop_duplicates(subset=["eval_id"], keep="first")

    return eval_df


def _coerce_numeric_like(df, columns):
    for col in columns:
        if col not in df.columns:
            continue
        df[col] = pd.to_numeric(df[col], errors="coerce")
        non_null = df[col].dropna()
        if not non_null.empty:
            try:
                if non_null.apply(lambda x: float(x).is_integer()).all():
                    df[col] = df[col].astype("Int64")
            except Exception:
                pass
    return df


def _compact_eval_fn_summary(mapping):
    return " | ".join(f"{k}:{v}" for k, v in mapping.items())


# ================================
# 2. LOAD DATA
# ================================
fused = pd.read_csv(FUSION_PATH)
gold = load_xml(GOLD_PATH, name="fusion_validation_set", nested_handling="aggregate")

# Use validation-set representation as target; do NOT country-normalize.
fused_eval = _build_eval_view_by_gold_lookup(fused, gold)

# Prefer eval_id if coverage is good; otherwise rebuild was already done above.
gold_ids = set(gold["id"].dropna().astype(str).tolist()) if "id" in gold.columns else set()
direct_cov = len(set(fused["_id"].astype(str).tolist()) & gold_ids) if "_id" in fused.columns else 0
eval_cov = len(set(fused_eval["eval_id"].astype(str).tolist()) & gold_ids) if "eval_id" in fused_eval.columns else 0

print(json.dumps({
    "stage": "validation",
    "id_alignment": {
        "gold_records": len(gold_ids),
        "direct_id_coverage": direct_cov,
        "eval_id_coverage": eval_cov,
        "fused_rows": int(len(fused)),
        "fused_eval_rows": int(len(fused_eval)),
    }
}, indent=2))


# ================================
# 3. NORMALIZE SHARED REPRESENTATION
# ================================
shared_cols = sorted((set(fused_eval.columns) & set(gold.columns)) - {"id", "_id", "eval_id", "_eval_cluster_id"})
list_eval_columns = detect_list_like_columns(
    [fused_eval, gold],
    exclude_columns={"id", "_id", "eval_id", "_eval_cluster_id", "_fusion_confidence"},
)
list_eval_columns = [c for c in list_eval_columns if c in shared_cols]

if list_eval_columns:
    fused_eval, gold = normalize_list_like_columns([fused_eval, gold], list_eval_columns)
    for col in list_eval_columns:
        if col in fused_eval.columns:
            fused_eval[col] = fused_eval[col].apply(_normalize_list_text_case)
        if col in gold.columns:
            gold[col] = gold[col].apply(_normalize_list_text_case)

# Keep date/year fields as strings for year_only_match.
date_like_cols = [c for c in shared_cols if "year" in c.lower() or "date" in c.lower() or c.lower() in {"releaseyear", "founded"}]
for col in date_like_cols:
    if col in fused_eval.columns:
        fused_eval[col] = fused_eval[col].apply(lambda x: _normalize_scalar_text(x) if not _safe_is_missing(x) else x)
    if col in gold.columns:
        gold[col] = gold[col].apply(lambda x: _normalize_scalar_text(x) if not _safe_is_missing(x) else x)

numeric_cols = []
for col in shared_cols:
    lc = col.lower()
    if any(tok in lc for tok in ["score", "rating", "count", "price", "duration", "revenue", "sales"]):
        if col not in list_eval_columns and col not in date_like_cols:
            numeric_cols.append(col)

fused_eval = _coerce_numeric_like(fused_eval, numeric_cols)
gold = _coerce_numeric_like(gold, numeric_cols)


# ================================
# 4. REGISTER EVALUATION FUNCTIONS
# ================================
strategy = DataFusionStrategy("evaluation_strategy")
eval_funcs_summary = {}

def register_eval(column, fn, fn_name, **kwargs):
    strategy.add_evaluation_function(column, fn, **kwargs)
    args = ",".join(f"{k}={v}" for k, v in kwargs.items()) if kwargs else ""
    eval_funcs_summary[column] = f"{fn_name}({args})" if args else fn_name

candidate_columns = []
for col in shared_cols:
    gold_nonempty = _meaningful_nonempty_series(gold, col)
    fused_nonempty = _meaningful_nonempty_series(fused_eval, col)
    if gold_nonempty.empty or fused_nonempty.empty:
        continue
    candidate_columns.append(col)

for col in candidate_columns:
    lc = col.lower()

    # Skip technical fields and structurally noisy nested XML-derived subfields except known useful list field.
    if col.startswith("_"):
        continue
    if _looks_nested_subfield(col) and col not in {"genres_genre"}:
        continue

    if col in list_eval_columns:
        register_eval(col, set_equality_match, "set_equality_match")
    elif "year" in lc or "date" in lc or col in {"releaseYear", "founded"}:
        register_eval(col, year_only_match, "year_only_match")
    elif lc in {"id", "_id", "eval_id"} or lc.endswith("code"):
        register_eval(col, exact_match, "exact_match")
    elif any(tok in lc for tok in ["criticscore"]):
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=5.0)
    elif any(tok in lc for tok in ["userscore", "rating"]):
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
    elif any(tok in lc for tok in ["sales", "count", "revenue", "price", "duration", "latitude", "longitude"]):
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=0.01)
    elif lc.startswith("is_") or lc.startswith("has_") or lc in {"active", "available", "published"}:
        register_eval(col, boolean_match, "boolean_match")
    else:
        threshold = 0.85
        if lc in {"platform", "publisher", "developer"}:
            threshold = 0.80
        elif lc in {"name", "title"}:
            threshold = 0.85
        register_eval(col, tokenized_match, "tokenized_match", threshold=threshold)

print(f"[EVAL_FUNCS] {_compact_eval_fn_summary(eval_funcs_summary)}")


# ================================
# 5. RUN EVALUATION
# ================================
evaluator = DataFusionEvaluator(
    strategy,
    debug=True,
    debug_format="json",
    debug_file=EVAL_DEBUG,
)

evaluation_results = evaluator.evaluate(
    fused_df=fused_eval,
    fused_id_column="eval_id",
    gold_df=gold,
    gold_id_column="id",
)

print(json.dumps({
    "stage": "validation",
    "evaluation_functions": eval_funcs_summary,
    "metrics": evaluation_results,
}, indent=2, default=str))


# ================================
# 6. WRITE RESULTS
# ================================
with open(EVAL_OUTPUT, "w", encoding="utf-8") as f:
    json.dump(evaluation_results, f, indent=4, ensure_ascii=False)
