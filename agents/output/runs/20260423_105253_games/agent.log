    from list_normalization import detect_list_like_columns, normalize_list_like_columns
except ModuleNotFoundError:
    _candidates = [
        Path.cwd(),
        Path.cwd() / "agents",
        Path(__file__).resolve().parent if "__file__" in globals() else Path.cwd(),
        (Path(__file__).resolve().parent.parent if "__file__" in globals() else Path.cwd()),
        (Path(__file__).resolve().parent.parent.parent if "__file__" in globals() else Path.cwd()),
    ]
    for _path in _candidates:
        if (_path / "list_normalization.py").is_file():
            if str(_path.resolve()) not in sys.path:
                sys.path.append(str(_path.resolve()))
    from list_normalization import detect_list_like_columns, normalize_list_like_columns


# ================================
# 0. PATHS
# ================================
OUTPUT_DIR = "output/runs/20260423_105253_games"
FUSION_DIR = os.path.join(OUTPUT_DIR, "data_fusion")
EVAL_DIR = os.path.join(OUTPUT_DIR, "pipeline_evaluation")
os.makedirs(EVAL_DIR, exist_ok=True)

FUSED_PATH = os.path.join(FUSION_DIR, "fusion_data.csv")
GOLD_PATH = "input/datasets/games/testsets/validation_set_fusion.xml"
EVAL_OUTPUT_PATH = os.path.join(EVAL_DIR, "pipeline_evaluation.json")
DEBUG_OUTPUT_PATH = os.path.join(EVAL_DIR, "debug_fusion_eval.jsonl")


# ================================
# 1. HELPERS
# ================================
def _safe_is_missing(value):
    if value is None:
        return True
    try:
        is_na = pd.isna(value)
        if hasattr(is_na, "__len__") and not isinstance(is_na, str):
            return False
        return bool(is_na)
    except Exception:
        return False


def _parse_source_ids(value):
    if value is None:
        return []
    if isinstance(value, (list, tuple, set)):
        return [str(v) for v in value if str(v).strip()]
    text = str(value).strip()
    if not text:
        return []
    for parser in (json.loads, ast.literal_eval):
        try:
            parsed = parser(text)
            if isinstance(parsed, (list, tuple, set)):
                return [str(v) for v in parsed if str(v).strip()]
        except Exception:
            pass
    return []


def _normalize_scalar_text(value):
    if _safe_is_missing(value):
        return value
    text = str(value).strip()
    return text if text else pd.NA


def _normalize_list_text_case(value):
    if _safe_is_missing(value):
        return value
    if isinstance(value, (list, tuple, set)):
        return [str(v).strip().lower() for v in value if str(v).strip()]
    text = str(value).strip()
    return text.lower() if text else pd.NA


def _meaningful_series(series):
    if series is None:
        return pd.Series(dtype="object")
    s = series.dropna()
    if s.empty:
        return s
    s = s.astype(str).str.strip().replace("", pd.NA).dropna()
    return s


def _is_meaningful_column(df, col):
    if col not in df.columns:
        return False
    return not _meaningful_series(df[col]).empty


def _looks_boolean_column(series):
    vals = set(_meaningful_series(series).str.lower().unique().tolist())
    if not vals:
        return False
    allowed = {"true", "false", "yes", "no", "0", "1"}
    return vals.issubset(allowed)


def _looks_nested_structural(col):
    parts = str(col).split("_")
    return len(parts) >= 3


def _choose_text_threshold(col):
    c = str(col).lower()
    if "name" in c:
        return 0.85
    if "platform" in c or "developer" in c or "publisher" in c:
        return 0.80
    if "genre" in c or "series" in c:
        return 0.75
    if "esrb" in c:
        return 0.90
    return 0.80


def _coerce_numeric_like_columns(df, numeric_cols):
    for col in numeric_cols:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce")
            non_null = df[col].dropna()
            if not non_null.empty:
                try:
                    if non_null.apply(lambda x: float(x).is_integer()).all():
                        df[col] = df[col].astype("Int64")
                except Exception:
                    pass
    return df


def build_eval_view_from_sources(fused_df, gold_df):
    gold_ids = set(gold_df["id"].dropna().astype(str).tolist()) if "id" in gold_df.columns else set()
    expanded_rows = []

    for _, row in fused_df.iterrows():
        row_dict = row.to_dict()
        cluster_id = str(row_dict.get("_id", row_dict.get("id", "")))
        source_ids = _parse_source_ids(row_dict.get("_fusion_sources"))

        matched_gold_ids = [sid for sid in source_ids if sid in gold_ids]

        if matched_gold_ids:
            for gid in matched_gold_ids:
                enriched = dict(row_dict)
                enriched["eval_id"] = gid
                enriched["_eval_cluster_id"] = cluster_id
                expanded_rows.append(enriched)
        else:
            enriched = dict(row_dict)
            enriched["eval_id"] = cluster_id
            enriched["_eval_cluster_id"] = cluster_id
            expanded_rows.append(enriched)

    fused_eval = pd.DataFrame(expanded_rows) if expanded_rows else fused_df.copy()

    if "_fusion_confidence" in fused_eval.columns:
        fused_eval["_fusion_confidence"] = pd.to_numeric(fused_eval["_fusion_confidence"], errors="coerce").fillna(0.0)
        fused_eval = fused_eval.sort_values("_fusion_confidence", ascending=False)

    if "eval_id" not in fused_eval.columns:
        fused_eval["eval_id"] = fused_eval["_id"].astype(str)

    fused_eval = fused_eval.drop_duplicates(subset=["eval_id"], keep="first")
    return fused_eval


# ================================
# 2. LOAD DATA
# ================================
fused = pd.read_csv(FUSED_PATH)
gold = load_xml(GOLD_PATH, name="validation_fusion_set", nested_handling="aggregate")

fused_eval = build_eval_view_from_sources(fused, gold)

# Fallback: if provided eval_id coverage is poor, rebuild from _fusion_sources only
gold_ids = set(gold["id"].dropna().astype(str).tolist()) if "id" in gold.columns else set()
mapped_cov = len(set(fused_eval["eval_id"].astype(str).tolist()) & gold_ids) if "eval_id" in fused_eval.columns else 0
if gold_ids and mapped_cov / max(len(gold_ids), 1) < 0.5:
    fused_eval = build_eval_view_from_sources(fused.drop(columns=["eval_id"], errors="ignore"), gold)

direct_cov = len(set(fused["_id"].astype(str).tolist()) & gold_ids) if "_id" in fused.columns else 0
mapped_cov = len(set(fused_eval["eval_id"].astype(str).tolist()) & gold_ids) if "eval_id" in fused_eval.columns else 0

print(json.dumps({
    "stage": "validation",
    "fused_rows": int(len(fused)),
    "gold_rows": int(len(gold)),
    "id_alignment": {
        "direct__id_coverage": direct_cov,
        "mapped_eval_id_coverage": mapped_cov,
        "gold_size": len(gold_ids),
    }
}, indent=2))


# ================================
# 3. NORMALIZE SHARED REPRESENTATION
# ================================
shared_columns = sorted((set(fused_eval.columns) & set(gold.columns)) - {"id", "_id", "eval_id", "_eval_cluster_id"})

# Normalize list-like columns using validation representation as target
list_eval_columns = detect_list_like_columns(
    [fused_eval, gold],
    exclude_columns={"id", "_id", "eval_id", "_eval_cluster_id", "_fusion_confidence"},
)
list_eval_columns = [c for c in list_eval_columns if c in shared_columns and not c.startswith("_")]

if list_eval_columns:
    fused_eval, gold = normalize_list_like_columns([fused_eval, gold], list_eval_columns)
    for col in list_eval_columns:
        if col in fused_eval.columns:
            fused_eval[col] = fused_eval[col].apply(_normalize_list_text_case)
        if col in gold.columns:
            gold[col] = gold[col].apply(_normalize_list_text_case)

# Normalize scalar text columns symmetrically
for col in shared_columns:
    if col in list_eval_columns:
        continue
    if col == "releaseYear":
        fused_eval[col] = fused_eval[col].astype("string")
        gold[col] = gold[col].astype("string")
    else:
        fused_eval[col] = fused_eval[col].apply(_normalize_scalar_text)
        gold[col] = gold[col].apply(_normalize_scalar_text)

# Numeric coercion for score/count-like fields
numeric_cols = [
    c for c in shared_columns
    if any(tok in c.lower() for tok in ["score", "rating", "count", "sales"])
    and c != "releaseYear"
]
fused_eval = _coerce_numeric_like_columns(fused_eval, numeric_cols)
gold = _coerce_numeric_like_columns(gold, numeric_cols)


# ================================
# 4. REGISTER EVALUATION FUNCTIONS
# ================================
strategy = DataFusionStrategy("games_validation_evaluation")
eval_funcs_summary = {}
registered_columns = []

def register_eval(column, fn, fn_name, **kwargs):
    strategy.add_evaluation_function(column, fn, **kwargs)
    args = ", ".join(f"{k}={v}" for k, v in kwargs.items()) if kwargs else ""
    eval_funcs_summary[column] = f"{fn_name}({args})" if args else fn_name
    registered_columns.append(column)

for col in shared_columns:
    if col.startswith("_"):
        continue
    if not _is_meaningful_column(fused_eval, col):
        continue
    if not _is_meaningful_column(gold, col):
        continue

    col_lower = col.lower()

    if _looks_nested_structural(col) and "genre" not in col_lower:
        continue

    if col in list_eval_columns:
        register_eval(col, set_equality_match, "set_equality_match")
    elif col_lower in {"id"} or col_lower.endswith("id") and col_lower != "eval_id":
        register_eval(col, exact_match, "exact_match")
    elif "releaseyear" == col_lower or col_lower.endswith("date") or "year" in col_lower:
        register_eval(col, year_only_match, "year_only_match")
    elif "criticscore" == col_lower:
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=5.0)
    elif "userscore" == col_lower:
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
    elif "sales" in col_lower or "count" in col_lower:
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
    elif _looks_boolean_column(gold[col]):
        register_eval(col, boolean_match, "boolean_match")
    else:
        register_eval(col, tokenized_match, "tokenized_match", threshold=_choose_text_threshold(col))

print("[EVAL_FUNCS] " + " | ".join(f"{k}:{v}" for k, v in eval_funcs_summary.items()))


# ================================
# 5. RUN EVALUATION
# ================================
evaluator = DataFusionEvaluator(
    strategy,
    debug=True,
    debug_format="json",
    debug_file=DEBUG_OUTPUT_PATH,
)

evaluation_results = evaluator.evaluate(
    fused_df=fused_eval,
    fused_id_column="eval_id",
    gold_df=gold,
    gold_id_column="id",
)


# ================================
# 6. STRUCTURED REPORTING
# ================================
report = {
    "stage": "validation",
    "fused_path": FUSED_PATH,
    "gold_path": GOLD_PATH,
    "output_path": EVAL_OUTPUT_PATH,
    "registered_columns": registered_columns,
    "evaluation_functions": eval_funcs_summary,
    "metrics": evaluation_results,
}

print(json.dumps(report, indent=2, default=str))

with open(EVAL_OUTPUT_PATH, "w", encoding="utf-8") as f:
    json.dump(evaluation_results, f, indent=4, default=str)
