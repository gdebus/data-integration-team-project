# 2. LOAD DATA
# ================================
fused = pd.read_csv(FUSION_PATH)
gold = load_xml(GOLD_PATH, name="fusion_validation_set", nested_handling="aggregate")

# Build robust mapped view from _fusion_sources -> gold ids
fused_eval_mapped = build_eval_view(fused, gold)

# If pipeline-provided eval_id exists, compare coverage and keep the better option
gold_ids = set(gold["id"].dropna().astype(str).tolist()) if "id" in gold.columns else set()
provided_eval_cov = 0
if "eval_id" in fused.columns:
    provided_eval_cov = len(set(fused["eval_id"].dropna().astype(str).tolist()) & gold_ids)

mapped_eval_cov = 0
if "eval_id" in fused_eval_mapped.columns:
    mapped_eval_cov = len(set(fused_eval_mapped["eval_id"].dropna().astype(str).tolist()) & gold_ids)

if "eval_id" in fused.columns and provided_eval_cov >= mapped_eval_cov:
    fused_eval = fused.copy()
    fused_eval["eval_id"] = fused_eval["eval_id"].astype(str)
    chosen_id_column = "eval_id"
else:
    fused_eval = fused_eval_mapped
    chosen_id_column = "eval_id"

direct_cov = len(set(fused["_id"].astype(str).tolist()) & gold_ids) if "_id" in fused.columns else 0

print(json.dumps({
    "stage": "validation",
    "id_alignment": {
        "gold_records": len(gold_ids),
        "direct__id_coverage": direct_cov,
        "provided_eval_id_coverage": provided_eval_cov,
        "mapped_eval_id_coverage": mapped_eval_cov,
        "chosen_fused_id_column": chosen_id_column,
    }
}, indent=2))


# ================================
# 3. NORMALIZE REPRESENTATION FOR EVALUATION
#    Use validation-set representation as target.
# ================================
shared_columns = [c for c in fused_eval.columns if c in gold.columns and not c.startswith("_")]

# Detect and normalize list-like columns jointly
list_eval_columns = detect_list_like_columns(
    [fused_eval, gold],
    exclude_columns={"id", "_id", "eval_id", "_eval_cluster_id", "_fusion_confidence"},
)
list_eval_columns = [c for c in list_eval_columns if c in shared_columns]

if list_eval_columns:
    fused_eval, gold = normalize_list_like_columns([fused_eval, gold], list_eval_columns)
    for col in list_eval_columns:
        if col in fused_eval.columns:
            fused_eval[col] = fused_eval[col].apply(_normalize_list_text_case)
        if col in gold.columns:
            gold[col] = gold[col].apply(_normalize_list_text_case)

# Keep releaseYear/date-like columns as strings for year_only_match
for df in (fused_eval, gold):
    if "releaseYear" in df.columns:
        df["releaseYear"] = df["releaseYear"].where(df["releaseYear"].isna(), df["releaseYear"].astype(str).str.strip())

# Coerce numeric-like columns consistently in both dataframes
numeric_like_columns = []
for col in shared_columns:
    low = col.lower()
    if any(key in low for key in ["score", "rating", "count", "price", "sales", "duration"]):
        numeric_like_columns.append(col)

for col in numeric_like_columns:
    _coerce_numeric_like(fused_eval, col)
    _coerce_numeric_like(gold, col)


# ================================
# 4. REGISTER EVALUATION FUNCTIONS
# ================================
strategy = DataFusionStrategy("games_validation_evaluation")
eval_funcs_summary = {}
registered_columns = []

def register_eval(column, fn, fn_name, **kwargs):
    strategy.add_evaluation_function(column, fn, **kwargs)
    args = ", ".join(f"{k}={v}" for k, v in kwargs.items()) if kwargs else ""
    eval_funcs_summary[column] = f"{fn_name}({args})" if args else fn_name
    registered_columns.append(column)

for col in shared_columns:
    if col in {"id"}:
        continue
    if col.startswith("_"):
        continue
    if _is_nested_structural_column(col):
        continue
    if not _has_meaningful_values(fused_eval, col):
        continue
    if not _has_meaningful_values(gold, col):
        continue

    low = col.lower()

    if col in list_eval_columns:
        register_eval(col, set_equality_match, "set_equality_match")
    elif low in {"releaseyear", "founded", "publish_year", "year"}:
        register_eval(col, year_only_match, "year_only_match")
    elif "criticscore" in low:
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=5.0)
    elif "userscore" in low or "rating" in low:
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
    elif any(key in low for key in ["sales", "duration", "price", "count"]):
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
    elif low in {"isactive", "active", "available"}:
        register_eval(col, boolean_match, "boolean_match")
    elif low in {"id", "code"}:
        register_eval(col, exact_match, "exact_match")
    else:
        threshold = 0.85
        if low in {"platform", "developer", "publisher", "esrb"}:
            threshold = 0.80
        register_eval(col, tokenized_match, "tokenized_match", threshold=threshold)

print("[EVAL_FUNCS] " + " | ".join(f"{k}:{v}" for k, v in eval_funcs_summary.items()))


# ================================
# 5. RUN EVALUATION
# ================================
evaluator = DataFusionEvaluator(
    strategy,
    debug=True,
    debug_format="json",
    debug_file=DEBUG_OUTPUT,
)

evaluation_results = evaluator.evaluate(
    fused_df=fused_eval,
    fused_id_column=chosen_id_column,
    expected_df=gold,
    expected_id_column="id",
)


# ================================
# 6. PRINT STRUCTURED METRICS
# ================================
structured_output = {
    "stage": "validation",
    "fused_path": FUSION_PATH,
    "gold_path": GOLD_PATH,
    "fused_rows": int(len(fused)),
    "fused_eval_rows": int(len(fused_eval)),
