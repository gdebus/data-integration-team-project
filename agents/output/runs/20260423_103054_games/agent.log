for df in [fused_eval, gold]:
    if "releaseYear" in df.columns:
        df["releaseYear"] = df["releaseYear"].astype("string")

# 4. Register evaluation functions only for meaningful shared columns
shared_columns = sorted(set(fused_eval.columns) & set(gold.columns))
strategy = DataFusionStrategy("sealed_test_evaluation_strategy")
eval_funcs_summary = {}

def register_eval(column, fn, fn_name, **kwargs):
    strategy.add_evaluation_function(column, fn, **kwargs)
    args = ", ".join(f"{k}={v}" for k, v in kwargs.items()) if kwargs else ""
    eval_funcs_summary[column] = f"{fn_name}({args})" if args else fn_name

for col in shared_columns:
    if col in {"id", "_id", "eval_id", "_eval_cluster_id"}:
        continue
    if _is_nested_structural_column(col):
        continue
    if not _has_meaningful_values(fused_eval, col):
        continue
    if not _has_meaningful_values(gold, col):
        continue

    col_lower = col.lower()

    if col in list_eval_columns:
        register_eval(col, set_equality_match, "set_equality_match")
    elif col_lower in {"releaseyear", "founded", "date", "year"} or "date" in col_lower or "year" in col_lower:
        register_eval(col, year_only_match, "year_only_match")
    elif col_lower in {"criticscore"}:
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=5.0)
    elif col_lower in {"userscore"}:
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
    elif col_lower in {"globalsales"}:
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=0.01)
    elif col_lower in {"id", "isbn", "issn", "doi", "code"}:
        register_eval(col, exact_match, "exact_match")
    elif col_lower.startswith("is_") or col_lower.startswith("has_") or col_lower in {"active", "available"}:
        register_eval(col, boolean_match, "boolean_match")
    else:
        register_eval(col, tokenized_match, "tokenized_match", threshold=0.85)

# 5. Diagnostics
gold_ids = set(gold["id"].dropna().astype(str).tolist()) if "id" in gold.columns else set()
direct_cov = len(set(fused["_id"].astype(str).tolist()) & gold_ids) if "_id" in fused.columns else 0
chosen_cov = len(set(fused_eval[fused_id_column].astype(str).tolist()) & gold_ids) if fused_id_column in fused_eval.columns else 0

print(json.dumps({
