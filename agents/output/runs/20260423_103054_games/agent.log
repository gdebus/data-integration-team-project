    },
    "list_eval_columns": list_eval_columns,
}, indent=2))

print("[EVAL_FUNCS]", _compact_eval_fn_summary(eval_funcs_summary))

# 6. Evaluate
evaluator = DataFusionEvaluator(
    strategy,
    debug=True,
    debug_format="json",
    debug_file=DEBUG_OUTPUT,
    fusion_debug_logs=os.path.join(OUTPUT_DIR, "data_fusion", "debug_fusion_data.jsonl"),
)

evaluation_results = evaluator.evaluate(
    fused_df=fused_eval,
    fused_id_column=fused_id_column,
    expected_df=gold,
    expected_id_column="id",
)

# 7. Print structured metrics
print(json.dumps({
    "stage": "sealed_test",
    "metrics": evaluation_results
}, indent=2, default=str))

# 8. Save results
with open(EVAL_OUTPUT, "w", encoding="utf-8") as f:
    json.dump(evaluation_results, f, indent=4, ensure_ascii=False)
