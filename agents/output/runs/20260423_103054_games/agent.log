def _safe_is_missing(value):
    if value is None:
        return True
    try:
        out = pd.isna(value)
        if hasattr(out, "__len__") and not isinstance(out, str):
            return False
        return bool(out)
    except Exception:
        return False


def _parse_source_ids(value):
    if value is None:
        return []
    if isinstance(value, (list, tuple, set)):
        return [str(v) for v in value if str(v).strip()]
    text = str(value).strip()
    if not text:
        return []
    for parser in (json.loads, ast.literal_eval):
        try:
            parsed = parser(text)
            if isinstance(parsed, (list, tuple, set)):
                return [str(v) for v in parsed if str(v).strip()]
        except Exception:
            pass
    return []


def _normalize_scalar_text(value):
    if _safe_is_missing(value):
        return value
    text = str(value).strip()
    return text if text != "" else pd.NA


def _normalize_list_text_case(value):
    if _safe_is_missing(value):
        return value
    if isinstance(value, (list, tuple, set)):
        vals = [str(v).strip().lower() for v in value if str(v).strip()]
        return vals if vals else pd.NA
    text = str(value).strip().lower()
    return text if text else pd.NA


def _meaningful_series(series):
    s = series.copy()
    s = s.dropna()
    if s.empty:
        return s
    s = s.astype(str).str.strip()
    s = s.replace("", pd.NA).dropna()
    return s


def _is_meaningful_column(df, col):
    if col not in df.columns:
        return False
    return not _meaningful_series(df[col]).empty


def _looks_nested_structural(col):
    parts = str(col).split("_")
    return len(parts) >= 2 and parts[0] != "" and parts[1] != ""


def _coerce_numeric_like(df, cols):
    for col in cols:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce")
            non_null = df[col].dropna()
            if not non_null.empty:
                try:
                    if non_null.apply(lambda x: float(x).is_integer()).all():
                        df[col] = df[col].astype("Int64")
                except Exception:
                    pass
    return df


def build_eval_view(fused_df, gold_df):
    gold_ids = set(gold_df["id"].dropna().astype(str).tolist()) if "id" in gold_df.columns else set()
    expanded_rows = []

    for _, row in fused_df.iterrows():
        row_dict = row.to_dict()
        cluster_id = str(row_dict.get("_id", ""))
        source_ids = _parse_source_ids(row_dict.get("_fusion_sources"))

        matched_gold_ids = [sid for sid in source_ids if sid in gold_ids]
        if matched_gold_ids:
            for gid in matched_gold_ids:
                enriched = dict(row_dict)
                enriched["eval_id"] = gid
                enriched["_eval_cluster_id"] = cluster_id
                expanded_rows.append(enriched)

    if expanded_rows:
        fused_eval = pd.DataFrame(expanded_rows)
        if "_fusion_confidence" in fused_eval.columns:
            fused_eval["_fusion_confidence"] = pd.to_numeric(
                fused_eval["_fusion_confidence"], errors="coerce"
            ).fillna(0.0)
            fused_eval = fused_eval.sort_values("_fusion_confidence", ascending=False)
        fused_eval = fused_eval.drop_duplicates(subset=["eval_id"], keep="first")
        return fused_eval

    fallback = fused_df.copy()
    if "eval_id" in fallback.columns:
        fallback["_eval_cluster_id"] = fallback["_id"].astype(str)
        return fallback
    fallback["eval_id"] = fallback["_id"].astype(str)
    fallback["_eval_cluster_id"] = fallback["_id"].astype(str)
    return fallback


fused = pd.read_csv(FUSION_PATH)
gold = load_xml(GOLD_PATH, name="fusion_validation_set", nested_handling="aggregate")

