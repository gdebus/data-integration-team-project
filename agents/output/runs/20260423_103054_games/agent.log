10:37:47,444 root INFO RESULT:import pandas as pd
import json
import ast
import os
import re
from pathlib import Path
import sys

from PyDI.io import load_xml
from PyDI.fusion import (
    DataFusionStrategy,
    DataFusionEvaluator,
    tokenized_match,
    year_only_match,
    set_equality_match,
    numeric_tolerance_match,
    exact_match,
    boolean_match,
)

try:
    from list_normalization import detect_list_like_columns, normalize_list_like_columns
except ModuleNotFoundError:
    _candidates = [
        Path.cwd(),
        Path.cwd() / "agents",
        Path(__file__).resolve().parent if "__file__" in globals() else Path.cwd(),
        (Path(__file__).resolve().parent.parent if "__file__" in globals() else Path.cwd()),
        (Path(__file__).resolve().parent.parent.parent if "__file__" in globals() else Path.cwd()),
    ]
    for _path in _candidates:
        if (_path / "list_normalization.py").is_file():
            if str(_path.resolve()) not in sys.path:
                sys.path.append(str(_path.resolve()))
    from list_normalization import detect_list_like_columns, normalize_list_like_columns


# ================================
# 0. OUTPUT DIRECTORY
# ================================
OUTPUT_DIR = "output/runs/20260423_103054_games"

FUSION_PATH = os.path.join(OUTPUT_DIR, "data_fusion", "fusion_data.csv")
EVAL_DIR = os.path.join(OUTPUT_DIR, "pipeline_evaluation")
EVAL_OUTPUT = os.path.join(EVAL_DIR, "pipeline_evaluation.json")
DEBUG_OUTPUT = os.path.join(EVAL_DIR, "debug_fusion_eval.jsonl")
GOLD_PATH = "input/datasets/games/testsets/validation_set_fusion.xml"

os.makedirs(EVAL_DIR, exist_ok=True)


# ================================
# 1. HELPERS
# ================================
def _safe_is_missing(value):
    if value is None:
        return True
    try:
        if isinstance(value, str):
            return value.strip() == ""
        result = pd.isna(value)
        if hasattr(result, "__len__") and not isinstance(result, str):
            return False
        return bool(result)
    except Exception:
        return False


def _parse_source_ids(value):
    if value is None:
        return []
    if isinstance(value, (list, tuple, set)):
        return [str(v) for v in value if not _safe_is_missing(v)]
    text = str(value).strip()
    if not text:
        return []
    for parser in (ast.literal_eval, json.loads):
        try:
            parsed = parser(text)
            if isinstance(parsed, (list, tuple, set)):
                return [str(v) for v in parsed if not _safe_is_missing(v)]
        except Exception:
            pass
    return []


def _meaningful_series(s):
    if s is None:
        return pd.Series(dtype="object")
    s = s.dropna()
    if s.empty:
        return s
    s = s.astype(str).str.strip()
    s = s.replace("", pd.NA).dropna()
    return s


def _canonicalize_list_value(value):
    if _safe_is_missing(value):
        return []
    if isinstance(value, (list, tuple, set)):
        vals = [str(v).strip().lower() for v in value if str(v).strip()]
        return sorted(set(vals))
    text = str(value).strip()
    if not text:
        return []
    try:
        parsed = ast.literal_eval(text)
        if isinstance(parsed, (list, tuple, set)):
            vals = [str(v).strip().lower() for v in parsed if str(v).strip()]
            return sorted(set(vals))
    except Exception:
        pass
    parts = [p.strip().lower() for p in re.split(r"[|;,]", text) if p.strip()]
    return sorted(set(parts)) if len(parts) > 1 else [text.lower()]


def _maybe_boolean_column(col):
    name = str(col).lower()
    return any(k in name for k in ["is_", "has_", "flag", "bool", "boolean", "active", "available"])


def _maybe_date_column(col):
    name = str(col).lower()
    return any(k in name for k in ["date", "year", "founded", "released", "releaseyear"])


def _maybe_numeric_column(col):
    name = str(col).lower()
    return any(k in name for k in ["score", "rating", "sales", "revenue", "price", "count", "duration", "number"])


def _nested_like_column(col):
    parts = str(col).split("_")
    return len(parts) >= 3


def _coerce_numeric_consistently(df, cols):
    for col in cols:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce")
            non_null = df[col].dropna()
            if len(non_null) > 0:
                try:
                    if non_null.apply(lambda x: float(x).is_integer()).all():
                        df[col] = df[col].astype("Int64")
                except Exception:
                    pass
    return df


def build_eval_view(fused_df, gold_df):
    """
    Robustly map fused rows to gold IDs using:
    1) precomputed eval_id if coverage is good
    2) exhaustive expansion from _fusion_sources
    """
    gold_ids = set(gold_df["id"].dropna().astype(str).tolist()) if "id" in gold_df.columns else set()

    if "eval_id" in fused_df.columns:
        eval_cov = len(set(fused_df["eval_id"].dropna().astype(str)) & gold_ids)
    else:
        eval_cov = 0

    if "_id" in fused_df.columns:
        direct_cov = len(set(fused_df["_id"].dropna().astype(str)) & gold_ids)
    else:
        direct_cov = 0

    expanded_rows = []
    for _, row in fused_df.iterrows():
        row_dict = row.to_dict()
        cluster_id = str(row_dict.get("_id", "")) if not _safe_is_missing(row_dict.get("_id", "")) else ""
        candidates = set()

        if "eval_id" in row_dict and not _safe_is_missing(row_dict.get("eval_id")):
            candidates.add(str(row_dict["eval_id"]).strip())

        for sid in _parse_source_ids(row_dict.get("_fusion_sources")):
            if sid in gold_ids:
                candidates.add(sid)

        if not candidates and cluster_id in gold_ids:
            candidates.add(cluster_id)

        if not candidates:
            candidates.add(cluster_id if cluster_id else str(row_dict.get("id", "")))

        for eval_id in candidates:
            enriched = dict(row_dict)
            enriched["eval_id"] = str(eval_id)
            enriched["_eval_cluster_id"] = cluster_id
            expanded_rows.append(enriched)

    fused_eval = pd.DataFrame(expanded_rows) if expanded_rows else fused_df.copy()

    if "eval_id" not in fused_eval.columns:
        fallback = fused_eval.copy()
        fallback["eval_id"] = fallback["_id"].astype(str) if "_id" in fallback.columns else fallback.index.astype(str)
        fallback["_eval_cluster_id"] = fallback["eval_id"]
        fused_eval = fallback

    if "_fusion_confidence" in fused_eval.columns:
        fused_eval["_fusion_confidence"] = pd.to_numeric(fused_eval["_fusion_confidence"], errors="coerce").fillna(0.0)
        fused_eval = fused_eval.sort_values("_fusion_confidence", ascending=False)

    fused_eval = fused_eval.drop_duplicates(subset=["eval_id"], keep="first")

    mapped_cov = len(set(fused_eval["eval_id"].dropna().astype(str)) & gold_ids)

    print(json.dumps({
        "id_alignment": {
            "gold_ids": len(gold_ids),
            "direct__id_coverage": direct_cov,
            "original_eval_id_coverage": eval_cov,
            "mapped_eval_id_coverage": mapped_cov,
        }
    }, indent=2))

    return fused_eval


# ================================
# 2. LOAD DATA
# ================================
fused = pd.read_csv(FUSION_PATH)
gold = load_xml(GOLD_PATH, name="fusion_validation_set", nested_handling="aggregate")
fused_eval = build_eval_view(fused, gold)


# ================================
# 3. NORMALIZE TO GOLD REPRESENTATION
# ================================
shared_columns = sorted((set(fused_eval.columns) & set(gold.columns)) - {"id", "_id", "eval_id", "_eval_cluster_id"})
list_eval_columns = detect_list_like_columns(
    [fused_eval, gold],
    exclude_columns={"id", "_id", "eval_id", "_eval_cluster_id", "_fusion_confidence"},
)
list_eval_columns = [c for c in list_eval_columns if c in shared_columns and not c.startswith("_")]

if list_eval_columns:
    fused_eval, gold = normalize_list_like_columns([fused_eval, gold], list_eval_columns)
    for col in list_eval_columns:
        if col in fused_eval.columns:
            fused_eval[col] = fused_eval[col].apply(_canonicalize_list_value)
        if col in gold.columns:
            gold[col] = gold[col].apply(_canonicalize_list_value)

numeric_cols = [c for c in shared_columns if _maybe_numeric_column(c) and c not in list_eval_columns]
fused_eval = _coerce_numeric_consistently(fused_eval, numeric_cols)
gold = _coerce_numeric_consistently(gold, numeric_cols)

for col in shared_columns:
    if col in list_eval_columns or col in numeric_cols:
        continue
    if _maybe_date_column(col):
        if col in fused_eval.columns:
            fused_eval[col] = fused_eval[col].where(fused_eval[col].isna(), fused_eval[col].astype(str).str.strip())
        if col in gold.columns:
            gold[col] = gold[col].where(gold[col].isna(), gold[col].astype(str).str.strip())
    else:
        if col in fused_eval.columns:
            fused_eval[col] = fused_eval[col].apply(
                lambda x: x if _safe_is_missing(x) else str(x).strip()
            )
        if col in gold.columns:
            gold[col] = gold[col].apply(
                lambda x: x if _safe_is_missing(x) else str(x).strip()
            )


# ================================
# 4. REGISTER EVALUATION FUNCTIONS
# ================================
strategy = DataFusionStrategy("evaluation_strategy")
eval_funcs_summary = {}
skipped_columns = {}

def register_eval(column, fn, fn_name, **kwargs):
    strategy.add_evaluation_function(column, fn, **kwargs)
    arg_str = ",".join(f"{k}={v}" for k, v in kwargs.items())
    eval_funcs_summary[column] = f"{column}:{fn_name}" + (f"({arg_str})" if arg_str else "")

for col in shared_columns:
    if col.startswith("_"):
        skipped_columns[col] = "internal_column"
        continue

    gold_nonempty = _meaningful_series(gold[col]) if col in gold.columns else pd.Series(dtype="object")
    fused_nonempty = _meaningful_series(fused_eval[col]) if col in fused_eval.columns else pd.Series(dtype="object")

    if gold_nonempty.empty:
        skipped_columns[col] = "gold_empty"
        continue
    if fused_nonempty.empty:
        skipped_columns[col] = "fused_empty"
        continue

    if _nested_like_column(col):
        skipped_columns[col] = "nested_structural_column"
        continue

    if col in list_eval_columns:
        register_eval(col, set_equality_match, "set_equality_match")
    elif _maybe_boolean_column(col):
        register_eval(col, boolean_match, "boolean_match")
    elif col == "id":
        register_eval(col, exact_match, "exact_match")
    elif _maybe_date_column(col):
        register_eval(col, year_only_match, "year_only_match")
    elif col == "criticScore":
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=5.0)
    elif col == "userScore":
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
    elif col == "globalSales":
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=0.01)
    elif _maybe_numeric_column(col):
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=0.05)
    else:
        register_eval(col, tokenized_match, "tokenized_match", threshold=0.85)

print("[EVALUATION_FUNCTIONS] " + " | ".join(eval_funcs_summary[c] for c in sorted(eval_funcs_summary)))
print(json.dumps({
    "registered_columns": sorted(eval_funcs_summary.keys()),
    "skipped_columns": skipped_columns,
    "list_eval_columns": list_eval_columns,
    "numeric_cols": numeric_cols,
}, indent=2))


# ================================
# 5. RUN EVALUATION
# ================================
evaluator = DataFusionEvaluator(
    strategy,
    debug=True,
    debug_format="json",
    debug_file=DEBUG_OUTPUT,
)

evaluation_results = evaluator.evaluate(
    fused_df=fused_eval,
    fused_id_column="eval_id",
    gold_df=gold,
    gold_id_column="id",
)


# ================================
# 6. PRINT STRUCTURED METRICS
# ================================
print(json.dumps({
    "evaluation_stage": "validation",
    "fusion_path": FUSION_PATH,
    "gold_path": GOLD_PATH,
    "metrics": evaluation_results,
}, indent=2, default=str))


# ================================
# 7. SAVE RESULTS
# ================================
with open(EVAL_OUTPUT, "w", encoding="utf-8") as f:
    json.dump(evaluation_results, f, indent=4, default=str)
