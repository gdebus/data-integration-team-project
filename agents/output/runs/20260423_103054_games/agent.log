DEBUG_OUTPUT = os.path.join(EVAL_DIR, "debug_fusion_eval.jsonl")
GOLD_PATH = "input/datasets/games/testsets/test_set_fusion.xml"

os.makedirs(EVAL_DIR, exist_ok=True)


def _safe_is_missing(value):
    if value is None:
        return True
    try:
        if pd.isna(value):
            return True
    except Exception:
        pass
    if isinstance(value, str) and not value.strip():
        return True
    if isinstance(value, (list, tuple, set)) and len(value) == 0:
        return True
    return False


def _parse_sources(value):
    if value is None:
        return []
    if isinstance(value, (list, tuple, set)):
        return [str(v) for v in value if str(v).strip()]
    text = str(value).strip()
    if not text:
        return []
    for parser in (ast.literal_eval, json.loads):
        try:
            parsed = parser(text)
            if isinstance(parsed, (list, tuple, set)):
                return [str(v) for v in parsed if str(v).strip()]
        except Exception:
            pass
    return []


def _normalize_text_scalar(x):
    if _safe_is_missing(x):
        return x
    return str(x).strip()


def _normalize_list_text_case(value):
    if _safe_is_missing(value):
        return value
    if isinstance(value, (list, tuple, set)):
        return sorted([str(v).strip().lower() for v in value if str(v).strip()])
    text = str(value).strip()
    return text.lower() if text else text


def _meaningful_series(s):
    if s is None:
        return pd.Series(dtype="object")
    s = s.dropna()
    if s.empty:
        return s
    s = s.astype(str).str.strip()
    s = s.replace("", pd.NA).dropna()
    return s


def _has_meaningful_values(df, col):
    return col in df.columns and not _meaningful_series(df[col]).empty


def _is_nested_structural_column(col):
    if col.startswith("_"):
        return True
    if col in {"id", "_id", "eval_id", "_eval_cluster_id"}:
        return True
    return len(col.split("_")) >= 3


def _build_eval_view_by_sources(fused_df, gold_df):
    gold_ids = set(gold_df["id"].dropna().astype(str).tolist()) if "id" in gold_df.columns else set()
    rows = []

    for _, row in fused_df.iterrows():
        row_dict = row.to_dict()
        cluster_id = str(row_dict.get("_id", ""))
        sources = _parse_sources(row_dict.get("_fusion_sources"))
        matched_gold_ids = [sid for sid in sources if sid in gold_ids]

        if matched_gold_ids:
            for gid in matched_gold_ids:
                out = dict(row_dict)
                out["eval_id"] = gid
                out["_eval_cluster_id"] = cluster_id
                rows.append(out)

    if rows:
        expanded = pd.DataFrame(rows)
        if "_fusion_confidence" in expanded.columns:
            expanded["_fusion_confidence"] = pd.to_numeric(expanded["_fusion_confidence"], errors="coerce").fillna(0.0)
            expanded = expanded.sort_values("_fusion_confidence", ascending=False)
        expanded = expanded.drop_duplicates(subset=["eval_id"], keep="first")
        return expanded

    fallback = fused_df.copy()
    fallback["eval_id"] = fallback["_id"].astype(str)
    fallback["_eval_cluster_id"] = fallback["_id"].astype(str)
    return fallback


def _coerce_numeric_like(df, cols):
    for col in cols:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce")
            non_null = df[col].dropna()
            if len(non_null) > 0:
                try:
                    if non_null.apply(lambda x: float(x).is_integer()).all():
                        df[col] = df[col].astype("Int64")
                except Exception:
                    pass
    return df


def _compact_eval_fn_summary(summary_dict):
    return " | ".join(f"{k}:{v}" for k, v in summary_dict.items())


# 1. Load data
fused = pd.read_csv(FUSION_PATH)
