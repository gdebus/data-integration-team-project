mapped_cov = 0
if "eval_id" in fused_eval_mapped.columns and "id" in gold.columns:
    mapped_cov = len(set(fused_eval_mapped["eval_id"].astype(str)) & set(gold["id"].astype(str)))

if "eval_id" in fused.columns and fused_eval_prebuilt_cov >= mapped_cov:
    fused_eval = fused.copy()
    fused_id_column = "eval_id"
else:
    fused_eval = fused_eval_mapped
    fused_id_column = "eval_id"

# 3. Normalize to same representation for evaluation
for df in [fused_eval, gold]:
    for col in df.columns:
        if col in {"releaseYear"}:
