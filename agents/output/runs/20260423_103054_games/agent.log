    and col not in {"id", "_id", "eval_id", "_eval_cluster_id", "_fusion_confidence", "_fusion_sources", "_fusion_source_datasets", "_fusion_metadata", "id"}
    and _is_meaningful_column(gold, col)
    and _is_meaningful_column(fused_eval, col)
]

for col in candidate_columns:
    lc = str(col).lower()

    if _looks_nested_structural(col) and col not in list_eval_columns:
        continue

    if col in list_eval_columns:
        register_eval(col, set_equality_match, "set_equality_match")
    elif "year" in lc or "date" in lc or col == "releaseYear":
        fused_eval[col] = fused_eval[col].astype("string")
        gold[col] = gold[col].astype("string")
        register_eval(col, year_only_match, "year_only_match")
    elif "userscore" in lc or lc == "userscore":
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
    elif "criticscore" in lc or lc == "criticscore":
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=5.0)
    elif any(tok in lc for tok in ["sales", "price", "duration", "count", "rating", "score"]):
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
    elif any(tok in lc for tok in ["is_", "has_", "flag", "enabled", "active", "available"]):
        register_eval(col, boolean_match, "boolean_match")
    elif lc in {"code", "identifier"}:
        register_eval(col, exact_match, "exact_match")
    else:
        threshold = 0.85 if lc in {"name", "title"} else 0.75
        register_eval(col, tokenized_match, "tokenized_match", threshold=threshold)

print("EVAL_FUNCS " + " | ".join(f"{k}:{v}" for k, v in sorted(eval_funcs_summary.items())))

evaluator = DataFusionEvaluator(
    strategy,
    debug=True,
    debug_format="json",
    debug_file=DEBUG_OUTPUT,
)

evaluation_results = evaluator.evaluate(
    fused_df=fused_eval,
    fused_id_column="eval_id" if "eval_id" in fused_eval.columns else "_id",
    gold_df=gold,
    gold_id_column="id",
)

structured_output = {
    "stage": "validation",
    "fused_path": FUSION_PATH,
    "gold_path": GOLD_PATH,
    "id_alignment": {
        "gold_records": int(len(gold)),
        "direct__id_coverage": int(direct_cov),
        "mapped_eval_id_coverage": int(mapped_cov),
        "fused_eval_rows": int(len(fused_eval)),
    },
    "evaluated_columns": sorted(list(eval_funcs_summary.keys())),
    "evaluation_functions": eval_funcs_summary,
    "metrics": evaluation_results,
}

print(json.dumps(structured_output, indent=2, default=str))

with open(EVAL_OUTPUT, "w", encoding="utf-8") as f:
    json.dump(structured_output, f, indent=2, default=str)
