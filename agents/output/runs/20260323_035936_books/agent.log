def _safe_is_missing(value):
    if value is None:
        return True
    try:
        out = pd.isna(value)
        if hasattr(out, "__len__") and not isinstance(out, str):
            return False
        return bool(out)
    except Exception:
        return False


def _parse_source_ids(value):
    if value is None:
        return []
    if isinstance(value, (list, tuple, set)):
        return [str(v) for v in value if str(v)]
    text = str(value).strip()
    if not text or text[0] not in "[({":
        return []
    for parser in (json.loads, ast.literal_eval):
        try:
            parsed = parser(text)
            if isinstance(parsed, (list, tuple, set)):
                return [str(v) for v in parsed if str(v)]
        except Exception:
            pass
    return []


def _detect_gold_prefix(gold_ids):
    prefixes = [g.split("_", 1)[0] for g in gold_ids if "_" in g]
    if not prefixes:
        return None
    return Counter(prefixes).most_common(1)[0][0] + "_"


def build_eval_view(fused_df, gold_df):
    gold_ids = set(gold_df["id"].dropna().astype(str).tolist()) if "id" in gold_df.columns else set()
    gold_prefix = _detect_gold_prefix(gold_ids)
    expanded_rows = []

    for _, row in fused_df.iterrows():
        row_dict = row.to_dict()
        cluster_id = str(row_dict.get("_id", ""))
        source_ids = _parse_source_ids(row_dict.get("_fusion_sources"))

        candidates = []
        if "eval_id" in row_dict and not _safe_is_missing(row_dict.get("eval_id")):
            candidates = [str(row_dict["eval_id"])]
        if not candidates and gold_prefix:
            candidates = [sid for sid in source_ids if sid.startswith(gold_prefix)]
        if not candidates:
            candidates = [sid for sid in source_ids if sid in gold_ids]
        if not candidates and cluster_id:
            candidates = [cluster_id]

        seen = set()
        for eval_id in candidates:
            if eval_id in seen:
                continue
            seen.add(eval_id)
            enriched = dict(row_dict)
            enriched["eval_id"] = str(eval_id)
            enriched["_eval_cluster_id"] = cluster_id
            expanded_rows.append(enriched)

    if not expanded_rows:
        fallback = fused_df.copy()
        if "eval_id" not in fallback.columns:
            fallback["eval_id"] = fallback["_id"].astype(str) if "_id" in fallback.columns else fallback.index.astype(str)
        fallback["_eval_cluster_id"] = fallback["eval_id"].astype(str)
        return fallback

    fused_eval = pd.DataFrame(expanded_rows)
    if "_fusion_confidence" in fused_eval.columns:
        fused_eval["_fusion_confidence"] = pd.to_numeric(fused_eval["_fusion_confidence"], errors="coerce").fillna(0.0)
        fused_eval = fused_eval.sort_values("_fusion_confidence", ascending=False)
    fused_eval = fused_eval.drop_duplicates(subset=["eval_id"], keep="first")
    return fused_eval


def _flatten_nested(obj):
    if isinstance(obj, (list, tuple, set)):
        out = []
        for item in obj:
            out.extend(_flatten_nested(item))
        return out
    return [obj]


def _parse_listish_text(value):
    if _safe_is_missing(value):
        return []
    if isinstance(value, (list, tuple, set)):
        return [str(v).strip() for v in _flatten_nested(value) if str(v).strip()]

    text = str(value).strip()
    if not text:
        return []

    for parser in (json.loads, ast.literal_eval):
        try:
            parsed = parser(text)
            if isinstance(parsed, (list, tuple, set)):
                return [str(v).strip() for v in _flatten_nested(parsed) if str(v).strip()]
        except Exception:
            pass

    parts = re.split(r"\s*[;,|]\s*", text)
    return [p.strip() for p in parts if p.strip()]


def _canonicalize_genres(value):
    if _safe_is_missing(value):
        return value
    items = _parse_listish_text(value)
    if not items:
        text = str(value).strip()
        return text if text else value
    cleaned = []
    for item in items:
        item = re.sub(r"\s+", " ", str(item)).strip().strip("'\"")
        if item:
            cleaned.append(item.lower())
    return cleaned


def _normalize_text(value):
    if _safe_is_missing(value):
        return value
    text = str(value).strip()
    text = re.sub(r"\s+", " ", text)
    return text


def _coerce_numeric_columns(df, numeric_cols):
    for col in numeric_cols:
        if col not in df.columns:
            continue
        df[col] = pd.to_numeric(df[col], errors="coerce")
        non_null = df[col].dropna()
        if not non_null.empty:
            try:
                if non_null.apply(lambda x: float(x).is_integer()).all():
                    df[col] = df[col].astype("Int64")
            except Exception:
                pass
    return df


def _is_meaningful_column(df, col):
    return col in df.columns and df[col].notna().any()


def _looks_nested_subfield(col):
    parts = str(col).split("_")
    return len(parts) >= 3 and len(set(parts[:-1])) < len(parts[:-1])


# ================================
# 1. LOAD FUSED OUTPUT AND GOLD SET
# ================================

fused = pd.read_csv(os.path.join(FUSION_DIR, "fusion_data.csv"))
gold = load_csv(
    "input/datasets/books/testsets/test_set.csv",
    name="fusion_test_set",
)

fused_eval = build_eval_view(fused, gold)


# ================================
# 2. SHARED NORMALIZATION TO GOLD REPRESENTATION
# ================================

for df in (fused_eval, gold):
    for col in [c for c in ["title", "author", "language", "publisher"] if c in df.columns]:
        df[col] = df[col].apply(_normalize_text)

numeric_cols = [
    c for c in [
        "publish_year",
        "page_count",
        "year",
        "count",
        "rating",
        "score",
        "numratings",
        "price",
    ]
    if c in fused_eval.columns or c in gold.columns
]
fused_eval = _coerce_numeric_columns(fused_eval, numeric_cols)
gold = _coerce_numeric_columns(gold, numeric_cols)

if "genres" in fused_eval.columns and "genres" in gold.columns:
    fused_eval["genres"] = fused_eval["genres"].apply(_canonicalize_genres)
    gold["genres"] = gold["genres"].apply(_canonicalize_genres)

list_eval_columns = detect_list_like_columns(
    [fused_eval, gold],
    exclude_columns={"id", "_id", "eval_id", "_eval_cluster_id", "_fusion_confidence", "isbn_clean"},
)
list_eval_columns = [c for c in list_eval_columns if not c.startswith("_")]

# Keep genres under explicit canonicalization logic rather than generic normalization.
list_eval_columns = [c for c in list_eval_columns if c != "genres"]

if list_eval_columns:
    fused_eval, gold = normalize_list_like_columns([fused_eval, gold], list_eval_columns)


# ================================
# 3. ID ALIGNMENT DIAGNOSTICS
# ================================

gold_ids = set(gold["id"].dropna().astype(str).tolist()) if "id" in gold.columns else set()
direct_cov = len(set(fused["_id"].astype(str).tolist()) & gold_ids) if "_id" in fused.columns else 0
mapped_cov = len(set(fused_eval["eval_id"].astype(str).tolist()) & gold_ids) if "eval_id" in fused_eval.columns else 0

print(json.dumps({
    "stage": "sealed_test",
    "id_alignment": {
        "direct_id_coverage": {"matched": direct_cov, "total_gold": len(gold_ids)},
        "mapped_eval_id_coverage": {"matched": mapped_cov, "total_gold": len(gold_ids)},
    }
}, indent=2))


# ================================
# 4. REGISTER EVALUATION FUNCTIONS
# ================================

strategy = DataFusionStrategy("books_evaluation_strategy")
eval_funcs_summary = {}


def register_eval(column, fn, fn_name, **kwargs):
    strategy.add_evaluation_function(column, fn, **kwargs)
    args = ",".join(f"{k}={v}" for k, v in kwargs.items()) if kwargs else ""
    eval_funcs_summary[column] = f"{fn_name}({args})" if args else fn_name


candidate_columns = sorted(set(fused_eval.columns) & set(gold.columns))
skip_columns = {
    "id", "_id", "eval_id", "_eval_cluster_id", "_fusion_confidence", "_fusion_sources"
}
skip_columns.update([c for c in candidate_columns if c.endswith("_provenance")])
skip_columns.update([c for c in candidate_columns if _looks_nested_subfield(c)])

for col in candidate_columns:
    if col in skip_columns:
        continue
    if not (_is_meaningful_column(fused_eval, col) and _is_meaningful_column(gold, col)):
        continue

    col_l = col.lower()

    if col_l in {"isbn", "isbn13", "isbn10", "isbn_clean"}:
        register_eval(col, exact_match, "exact_match")
    elif col_l in {"publish_year", "year"}:
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=0.0)
    elif col_l in {"page_count", "count", "numratings"}:
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=0.0)
    elif any(tok in col_l for tok in ["rating", "score", "price", "latitude", "longitude", "revenue"]):
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=0.01)
    elif col_l in {"genres", "categories", "tags"}:
        register_eval(col, set_equality_match, "set_equality_match")
    elif col_l.startswith("is_") or col_l.startswith("has_") or "boolean" in col_l or col_l in {"active", "available"}:
        register_eval(col, boolean_match, "boolean_match")
    elif "date" in col_l or "founded" in col_l:
        register_eval(col, year_only_match, "year_only_match")
    elif col_l in {"title", "name"}:
        register_eval(col, tokenized_match, "tokenized_match", threshold=0.85)
    elif col_l in {"author", "artist", "creator"}:
        register_eval(col, tokenized_match, "tokenized_match", threshold=0.85)
    elif col_l in {"publisher", "label", "language", "country", "city", "street"}:
        register_eval(col, tokenized_match, "tokenized_match", threshold=0.75)
    elif col in list_eval_columns:
        register_eval(col, tokenized_match, "tokenized_match", threshold=0.75)
    else:
        register_eval(col, tokenized_match, "tokenized_match", threshold=0.80)

print("[EVAL_FUNCS] " + " | ".join(f"{k}:{v}" for k, v in sorted(eval_funcs_summary.items())))


# ================================
# 5. RUN EVALUATION
# ================================

evaluator = DataFusionEvaluator(
    strategy,
    debug=True,
    debug_format="json",
    debug_file=os.path.join(EVAL_DIR, "debug_fusion_eval.jsonl"),
    fusion_debug_logs=os.path.join(FUSION_DIR, "debug_fusion_data.jsonl"),
)

evaluation_results = evaluator.evaluate(
    fused_df=fused_eval,
    fused_id_column="eval_id" if "eval_id" in fused_eval.columns else "_id",
    expected_df=gold,
    expected_id_column="id",
)


# ================================
# 6. PRINT STRUCTURED METRICS
# ================================

print(json.dumps({
    "stage": "sealed_test",
    "metrics": evaluation_results,
}, indent=2, default=str))


# ================================
# 7. WRITE RESULTS
# ================================

evaluation_output = os.path.join(EVAL_DIR, "pipeline_evaluation.json")
with open(evaluation_output, "w", encoding="utf-8") as f:
    json.dump(evaluation_results, f, indent=4, default=str)
