            out["_eval_cluster_id"] = out["_id"].astype(str)
        if "_fusion_confidence" in out.columns:
            out["_fusion_confidence"] = pd.to_numeric(out["_fusion_confidence"], errors="coerce").fillna(0.0)
            out = out.sort_values("_fusion_confidence", ascending=False)
        out = out.drop_duplicates(subset=["eval_id"], keep="first")
        return out

    gold_ids = set(gold_df["id"].dropna().astype(str).tolist()) if "id" in gold_df.columns else set()
    gold_prefix = _detect_gold_prefix(gold_ids)
    expanded_rows = []

    for _, row in fused_df.iterrows():
        row_dict = row.to_dict()
        cluster_id = str(row_dict.get("_id", ""))
        source_ids = _parse_source_ids(row_dict.get("_fusion_sources"))

        candidates = []
        if gold_prefix:
            candidates = [sid for sid in source_ids if sid.startswith(gold_prefix)]
        if not candidates:
            candidates = [sid for sid in source_ids if sid in gold_ids]
        if not candidates and cluster_id:
            candidates = [cluster_id]

        seen = set()
        for eval_id in candidates:
            if eval_id in seen:
                continue
            seen.add(eval_id)
            enriched = dict(row_dict)
            enriched["eval_id"] = str(eval_id)
            enriched["_eval_cluster_id"] = cluster_id
            expanded_rows.append(enriched)

    if not expanded_rows:
        fallback = fused_df.copy()
        fallback["eval_id"] = fallback["_id"].astype(str) if "_id" in fallback.columns else fallback.index.astype(str)
        fallback["_eval_cluster_id"] = fallback["eval_id"]
        return fallback

    fused_eval = pd.DataFrame(expanded_rows)
    if "_fusion_confidence" in fused_eval.columns:
        fused_eval["_fusion_confidence"] = pd.to_numeric(fused_eval["_fusion_confidence"], errors="coerce").fillna(0.0)
        fused_eval = fused_eval.sort_values("_fusion_confidence", ascending=False)
    fused_eval = fused_eval.drop_duplicates(subset=["eval_id"], keep="first")
    return fused_eval


def _compact_text(value):
    if _safe_is_missing(value):
        return value
    text = str(value)
    text = re.sub(r"\s+", " ", text).strip()
    return text


def _normalize_text_case(value):
    if _safe_is_missing(value):
        return value
    return _compact_text(value)


def _looks_like_int_series(series):
    s = pd.to_numeric(series, errors="coerce").dropna()
    if s.empty:
        return False
    return s.apply(lambda x: float(x).is_integer()).all()


def _coerce_numeric_columns(df, columns):
    for col in columns:
        if col not in df.columns:
            continue
        df[col] = pd.to_numeric(df[col], errors="coerce")
        if _looks_like_int_series(df[col]):
            df[col] = df[col].astype("Int64")
    return df


def _parse_textual_list(value):
    if _safe_is_missing(value):
        return []
    if isinstance(value, (list, tuple, set)):
        raw_items = list(value)
    else:
        text = str(value).strip()
        if not text:
            return []
        parsed = None
        if text[:1] in "[({":
            for parser in (json.loads, ast.literal_eval):
                try:
                    parsed = parser(text)
                    break
                except Exception:
                    pass
        if isinstance(parsed, (list, tuple, set)):
            raw_items = list(parsed)
        else:
            raw_items = [text]

    out = []
    for item in raw_items:
        if isinstance(item, (list, tuple, set)):
            out.extend(_parse_textual_list(list(item)))
            continue
        text = str(item).strip()
        if not text:
            continue
        parts = re.split(r"\s*[;,|]\s*", text)
        for part in parts:
            part = re.sub(r"^[\[\(\{\"']+|[\]\)\}\"']+$", "", part).strip()
            if part:
                out.append(part.lower())
    return out


def _normalize_list_text_case(value):
    if _safe_is_missing(value):
        return value
    if isinstance(value, (list, tuple, set)):
        return [str(v).strip().lower() for v in value if str(v).strip()]
    text = str(value).strip()
    return text.lower() if text else text


def _drop_unusable_columns(fused_df, gold_df):
    shared = [c for c in fused_df.columns if c in gold_df.columns]
    keep = []
    for col in shared:
        if col.startswith("_"):
            continue
        if col in {"id", "eval_id"}:
            continue
        if gold_df[col].notna().sum() == 0:
            continue
        if fused_df[col].notna().sum() == 0:
            continue
        keep.append(col)
    return keep


# ================================
# 2. LOAD DATA
# ================================
fused = pd.read_csv(FUSED_PATH)
gold = pd.read_csv(EVAL_SET_PATH)

fused_eval = build_eval_view(fused, gold)

# ================================
# 3. NORMALIZE TO VALIDATION REPRESENTATION
# ================================
# Remove provenance-only gold columns from evaluation consideration
gold = gold.copy()
provenance_cols = [c for c in gold.columns if c.endswith("_provenance")]
if provenance_cols:
    gold = gold.drop(columns=provenance_cols)

# Whitespace/text normalization
for df in (fused_eval, gold):
    for col in df.columns:
        if col.startswith("_"):
            continue
        if df[col].dtype == "object" or str(df[col].dtype).startswith("string"):
            df[col] = df[col].apply(_normalize_text_case)

# Numeric coercion to avoid float/int mismatches
numeric_like_candidates = [
    c for c in set(fused_eval.columns).intersection(gold.columns)
    if any(tok in c.lower() for tok in ["year", "count", "rating", "score", "price", "page", "num"])
]
fused_eval = _coerce_numeric_columns(fused_eval, numeric_like_candidates)
gold = _coerce_numeric_columns(gold, numeric_like_candidates)

# Normalize list-like columns consistently when genuinely list-like in either side
list_eval_columns = detect_list_like_columns(
    [fused_eval, gold],
    exclude_columns={"id", "_id", "eval_id", "_eval_cluster_id", "_fusion_confidence", "isbn_clean"},
)
list_eval_columns = [c for c in list_eval_columns if not c.startswith("_")]

if list_eval_columns:
    fused_eval, gold = normalize_list_like_columns([fused_eval, gold], list_eval_columns)
    for col in list_eval_columns:
        if col in fused_eval.columns:
            fused_eval[col] = fused_eval[col].apply(_normalize_list_text_case)
        if col in gold.columns:
            gold[col] = gold[col].apply(_normalize_list_text_case)

# Validation-specific canonicalization for genres:
# treat as textual list if needed, then compare as set equality
if "genres" in fused_eval.columns and "genres" in gold.columns:
    fused_eval["genres"] = fused_eval["genres"].apply(_parse_textual_list)
    gold["genres"] = gold["genres"].apply(_parse_textual_list)

# ISBN/code normalization
if "isbn_clean" in fused_eval.columns and "isbn_clean" in gold.columns:
    fused_eval["isbn_clean"] = fused_eval["isbn_clean"].apply(
        lambda x: str(int(x)) if pd.notna(x) and str(x).strip() not in {"", "nan"} and str(x).replace(".", "", 1).isdigit() else (str(x).strip() if pd.notna(x) else x)
    )
    gold["isbn_clean"] = gold["isbn_clean"].apply(
        lambda x: str(int(x)) if pd.notna(x) and str(x).strip() not in {"", "nan"} and str(x).replace(".", "", 1).isdigit() else (str(x).strip() if pd.notna(x) else x)
    )

# ================================
# 4. ID ALIGNMENT DIAGNOSTICS
# ================================
gold_ids = set(gold["id"].dropna().astype(str).tolist()) if "id" in gold.columns else set()
direct_cov = len(set(fused["_id"].astype(str).tolist()) & gold_ids) if "_id" in fused.columns else 0
mapped_cov = len(set(fused_eval["eval_id"].astype(str).tolist()) & gold_ids) if "eval_id" in fused_eval.columns else 0

print(json.dumps({
    "stage": "validation",
    "fused_rows": int(len(fused)),
    "fused_eval_rows": int(len(fused_eval)),
    "gold_rows": int(len(gold)),
    "id_alignment": {
        "direct__id_coverage": f"{direct_cov}/{len(gold_ids)}",
        "mapped_eval_id_coverage": f"{mapped_cov}/{len(gold_ids)}",
    }
}, indent=2))

# ================================
# 5. REGISTER EVALUATION FUNCTIONS
# ================================
strategy = DataFusionStrategy("books_validation_evaluation")
eval_funcs_summary = {}

def register_eval(column, fn, fn_name, **kwargs):
    strategy.add_evaluation_function(column, fn, **kwargs)
    args = ",".join(f"{k}={v}" for k, v in kwargs.items()) if kwargs else ""
    eval_funcs_summary[column] = f"{fn_name}({args})" if args else fn_name

usable_columns = _drop_unusable_columns(fused_eval, gold)

# IDs / canonical codes
if "isbn_clean" in usable_columns:
    register_eval("isbn_clean", exact_match, "exact_match")

# Text attributes
for col in ["title", "author", "publisher", "language"]:
    if col in usable_columns:
        register_eval(col, tokenized_match, "tokenized_match", threshold=0.85)

# Genres should be treated as normalized textual sets
if "genres" in usable_columns:
    register_eval("genres", set_equality_match, "set_equality_match")

# Numeric / count / year-like attributes
if "publish_year" in usable_columns:
    register_eval("publish_year", numeric_tolerance_match, "numeric_tolerance_match", tolerance=0.01)
if "page_count" in usable_columns:
    register_eval("page_count", numeric_tolerance_match, "numeric_tolerance_match", tolerance=0.01)
if "rating" in usable_columns:
    register_eval("rating", numeric_tolerance_match, "numeric_tolerance_match", tolerance=0.05)
if "numratings" in usable_columns:
    register_eval("numratings", numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
if "price" in usable_columns:
    register_eval("price", numeric_tolerance_match, "numeric_tolerance_match", tolerance=0.05)

# Optional fallback registration for any other shared, meaningful top-level columns
already_registered = set(eval_funcs_summary.keys())
for col in usable_columns:
    if col in already_registered:
        continue
    lowered = col.lower()
    if re.match(r".+_.+_.+", lowered):
        continue
    if "date" in lowered and "year" not in lowered:
        register_eval(col, year_only_match, "year_only_match")
    elif any(tok in lowered for tok in ["year", "count", "rating", "score", "price", "page", "num"]):
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=0.01)
    elif "is_" in lowered or lowered.startswith("has_") or lowered.startswith("flag_"):
        register_eval(col, boolean_match, "boolean_match")
    else:
        register_eval(col, tokenized_match, "tokenized_match", threshold=0.85)

print("[EVAL_FUNCS] " + " | ".join(f"{k}:{v}" for k, v in sorted(eval_funcs_summary.items())))

# ================================
# 6. RUN EVALUATION
# ================================
evaluator = DataFusionEvaluator(
    strategy,
    debug=True,
    debug_format="json",
    debug_file=DEBUG_PATH,
)

evaluation_results = evaluator.evaluate(
    fused_df=fused_eval,
    fused_id_column="eval_id",
    gold_df=gold,
    gold_id_column="id",
)

# ================================
# 7. PRINT STRUCTURED METRICS
# ================================
print(json.dumps({
    "stage": "validation",
    "evaluation_functions": eval_funcs_summary,
    "metrics": evaluation_results,
}, indent=2, default=str))

# ================================
# 8. WRITE RESULTS
# ================================
with open(EVAL_OUTPUT_PATH, "w", encoding="utf-8") as f:
    json.dump(evaluation_results, f, indent=4, default=str)
