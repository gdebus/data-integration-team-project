rings ("pop; rock; jazz") to Python lists so list_strategy\n# comparators and list fusers (union, intersection) work correctly.\n\nlist_like_columns = detect_list_like_columns(\n    [good_dataset_name_1, good_dataset_name_2, good_dataset_name_3],\n    exclude_columns={"id", "_id"},\n)\nif list_like_columns:\n    (good_dataset_name_1, good_dataset_name_2, good_dataset_name_3,\n     ) = normalize_list_like_columns(\n        [good_dataset_name_1, good_dataset_name_2, good_dataset_name_3], list_like_columns)\n    print(f"Normalized list-like columns: {\', \'.join(list_like_columns)}")\n\ndatasets = [good_dataset_name_1, good_dataset_name_2, good_dataset_name_3]\n\n# === 4. BLOCKING ===\n# CRITICAL: Use the precomputed blocking config from "5. **BLOCKING CONFIGURATION**".\n#\n# Blocker types and their signatures:\n#   StandardBlocker(df_l, df_r, on=[\'col\'], id_column=\'id\')                  — exact equality\n#   TokenBlocker(df_l, df_r, column=\'name\', id_column=\'id\', min_token_len=3) — token overlap\n#   SortedNeighbourhoodBlocker(df_l, df_r, key=\'name\', window=20, id_column=\'id\')\n#   EmbeddingBlocker(df_l, df_r, text_cols=[\'name\',\'city\'], id_column=\'id\', top_k=20)\n#     ⚠ EmbeddingBlocker: uses text_cols=[...] (list), NOT column=\'...\'\n#     ⚠ EmbeddingBlocker: uses .materialize(), NOT .block()\n\nprint("Performing Blocking")\n\nblocker_1_2 = StandardBlocker(\n    good_dataset_name_1, good_dataset_name_2,\n    on=["city"], id_column="id", batch_size=100000,\n)\nblocker_1_3 = StandardBlocker(\n    good_dataset_name_1, good_dataset_name_3,\n    on=["city"], id_column="id", batch_size=100000,\n)\nblocker_2_3 = StandardBlocker(\n    good_dataset_name_2, good_dataset_name_3,\n    on=["city"], id_column="id", batch_size=100000,\n)\n\n# === 5. ENTITY MATCHING ===\n# CRITICAL: Use the matching config from "6. **MATCHING CONFIGURATION**".\n# Define threshold variables as: threshold_<pair_key> = <value>\n#\n# Comparator signatures:\n#   StringComparator(column, similarity_function=\'jaro_winkler\', preprocess=None, list_strategy=None)\n#     similarity_function: \'jaro_winkler\', \'levenshtein\', \'jaccard\', \'cosine\', etc.\n#     list_strategy: \'best_match\', \'set_jaccard\', \'set_overlap\' (avoid \'concatenate\')\n#   NumericComparator(column, method=\'absolute_difference\', max_difference=None, list_strategy=None)\n#     list_strategy: \'average\', \'best_match\', \'range_overlap\', \'set_jaccard\'\n#   DateComparator(column, max_days_difference=None, list_strategy=None)\n#     list_strategy: \'closest_dates\', \'range_overlap\', \'average_dates\', \'latest_dates\', \'earliest_dates\'\n#\n# ⚠ For list-valued columns: ALWAYS set list_strategy explicitly.\n\nprint("Matching Entities")\n\nthreshold_dataset_name_1_dataset_name_2 = 0.7\nthreshold_dataset_name_1_dataset_name_3 = 0.7\nthreshold_dataset_name_2_dataset_name_3 = 0.7\n\ncomparators_1_2 = [\n    StringComparator(column="name", similarity_function="jaro_winkler"),\n    StringComparator(column="city", similarity_function="jaro_winkler", preprocess=str.lower),\n    NumericComparator(column="house_number", method="absolute_difference", max_difference=2),\n    DateComparator(column="founded", max_days_difference=365),\n    # List column → MUST set list_strategy\n    StringComparator(column="categories", similarity_function="jaccard",\n                     preprocess=str.lower, list_strategy="set_jaccard"),\n]\n\ncomparators_1_3 = [\n    StringComparator(column="name", similarity_function="jaro_winkler"),\n    StringComparator(column="city", similarity_function="jaro_winkler", preprocess=str.lower),\n    NumericComparator(column="house_number", max_difference=2),\n    StringComparator(column="categories", similarity_function="jaccard",\n                     preprocess=str.lower, list_strategy="set_jaccard"),\n]\n\ncomparators_2_3 = [\n    StringComparator(column="name", similarity_function="jaro_winkler"),\n    StringComparator(column="city", similarity_function="jaro_winkler", preprocess=str.lower),\n    NumericComparator(column="house_number", max_difference=2),\n    StringComparator(column="categories", similarity_function="jaccard",\n                     preprocess=str.lower, list_strategy="set_jaccard"),\n]\n\nmatcher = RuleBasedMatcher()\n\nrb_correspondences_1_2 = matcher.match(\n    df_left=good_dataset_name_1, df_right=good_dataset_name_2,\n    candidates=blocker_1_2, comparators=comparators_1_2,\n    weights=[0.4, 0.2, 0.1, 0.15, 0.15],\n    threshold=threshold_dataset_name_1_dataset_name_2, id_column="id",\n)\nrb_correspondences_1_3 = matcher.match(\n    df_left=good_dataset_name_1, df_right=good_dataset_name_3,\n    candidates=blocker_1_3, comparators=comparators_1_3,\n    weights=[0.5, 0.2, 0.1, 0.2],\n    threshold=threshold_dataset_name_1_dataset_name_3, id_column="id",\n)\nrb_correspondences_2_3 = matcher.match(\n    df_left=good_dataset_name_2, df_right=good_dataset_name_3,\n    candidates=blocker_2_3, comparators=comparators_2_3,\n    weights=[0.5, 0.2, 0.1, 0.2],\n    threshold=threshold_dataset_name_2_dataset_name_3, id_column="id",\n)\n\n# === 6. SAVE CORRESPONDENCES (MANDATORY) ===\n# Save per-pair CSVs BEFORE merging. Naming: correspondences_<left>_<right>.csv\n\nCORR_DIR = os.path.join(OUTPUT_DIR, "correspondences")\nos.makedirs(CORR_DIR, exist_ok=True)\nrb_correspondences_1_2.to_csv(os.path.join(CORR_DIR, "correspondences_dataset_name_1_dataset_name_2.csv"), index=False)\nrb_correspondences_1_3.to_csv(os.path.join(CORR_DIR, "correspondences_dataset_name_1_dataset_name_3.csv"), index=False)\nrb_correspondences_2_3.to_csv(os.path.join(CORR_DIR, "correspondences_dataset_name_2_dataset_name_3.csv"), index=False)\n\nall_rb_correspondences = pd.concat(\n    [rb_correspondences_1_2, rb_correspondences_1_3, rb_correspondences_2_3], ignore_index=True)\n\n# === 7. DATA FUSION ===\n#\n# RESOLVER QUICK REFERENCE — prefer built-in resolvers over custom code:\n#   String:  voting (majority), longest_string, shortest_string, most_complete\n#   Numeric: median (robust default), average, maximum, minimum, sum_values\n#   Date:    earliest (founding/birth), most_recent (last updated)\n#   List:    union(separator="; "), intersection(separator="; "),\n#            intersection_k_sources(k=2, separator="; ")   — pass separator= always\n#   Trust:   prefer_higher_trust(trust_map={"src": score})\n#            favour_sources(source_preferences=["best", "ok", "worst"])\n#\n# CHOOSING A RESOLVER:\n#   names/titles        → voting or most_complete\n#   geographic (city)   → prefer_higher_trust if one source is better\n#   numeric (revenue)   → median\n#   dates (founded)     → earliest;  dates (updated) → most_recent\n#   list (categories)   → union(separator="; ") if clean, intersection_k_sources if noisy\n#   one source better   → prefer_higher_trust with trust_map\n#\n# DO NOT write custom fusers. Use only PyDI built-in resolvers listed above.\n\nprint("Fusing Data")\n\ntrust_map = {"dataset_name_1": 3, "dataset_name_2": 2, "dataset_name_3": 1}\n\nstrategy = DataFusionStrategy("fusion_strategy")\n\n# String attributes\nstrategy.add_attribute_fuser("name", voting)\nstrategy.add_attribute_fuser("street", most_complete)\nstrategy.add_attribute_fuser("city", prefer_higher_trust, trust_map=trust_map)\nstrategy.add_attribute_fuser("state", prefer_higher_trust, trust_map=trust_map)\nstrategy.add_attribute_fuser("country", prefer_higher_trust, trust_map=trust_map)\n\n# Numeric attributes\nstrategy.add_attribute_fuser("revenue", median)\nstrategy.add_attribute_fuser("latitude", average)\nstrategy.add_attribute_fuser("longitude", average)\nstrategy.add_attribute_fuser("house_number", voting)\n\n# Date attributes\nstrategy.add_attribute_fuser("founded", earliest)\n\n# List attributes — always pass separator= for delimited strings\nstrategy.add_attribute_fuser("categories", union, separator="; ")\n# For noisy lists: intersection_k_sources(k=2, separator="; ")\n\n# === 8. RUN FUSION ===\n# CRITICAL: Always include_singletons=True for full fused dataset.\n# CRITICAL: Use OUTPUT_DIR for all output paths.\n\nFUSION_DIR = os.path.join(OUTPUT_DIR, "data_fusion")\nos.makedirs(FUSION_DIR, exist_ok=True)\nengine = DataFusionEngine(\n    strategy, debug=True, debug_format="json",\n    debug_file=os.path.join(FUSION_DIR, "debug_fusion_data.jsonl"),\n)\n\nfused_result = engine.run(\n    datasets=[good_dataset_name_1, good_dataset_name_2, good_dataset_name_3],\n    correspondences=all_rb_correspondences,\n    id_column="id",\n    include_singletons=True,\n)\n\nfused_result.to_csv(os.path.join(FUSION_DIR, "fusion_data.csv"), index=False)\n\n\n        2. A list of dataset file paths (LOAD THESE EXACT PATHS — do NOT invent or assume different paths):\n        [\n  "output/runs/20260322_171209_music/normalization/attempt_1/discogs.csv",\n  "output/runs/20260322_171209_music/normalization/attempt_1/lastfm.csv",\n  "output/runs/20260322_171209_music/normalization/attempt_1/musicbrainz.csv"\n]\n\n        IMPORTANT: Set OUTPUT_DIR = "output/runs/20260322_171209_music/" at the top of your code and use it for ALL output paths:\n        - Correspondences: os.path.join(OUTPUT_DIR, "correspondences")\n        - Fusion output: os.path.join(OUTPUT_DIR, "data_fusion")\n        - Debug file: os.path.join(OUTPUT_DIR, "data_fusion/debug_fusion_data.jsonl")\n        Do NOT hardcode "output/" anywhere.\n\n        \n\n        3. The first row of each dataset to help understand the structure:\n        {\n  "output/runs/20260322_171209_music/normalization/attempt_1/discogs.csv": {\n    "id": "discogs_3",\n    "name": "Fermats Theorem / Sight Beyond",\n    "artist": "John B",\n    "release-date": "1996-01-01",\n    "release-country": "Uganda",\n    "duration": 0,\n    "label": "New Identity Recordings",\n    "genre": "Electronic",\n    "tracks_track_name": "[\'Fermats Theorem\', \'Sight Beyond\']",\n    "tracks_track_position": "[\'1\', \'2\']",\n    "tracks_track_duration": "[]"\n  },\n  "output/runs/20260322_171209_music/normalization/attempt_1/lastfm.csv": {\n    "id": "lastFM_1",\n    "name": "John B -  Fermats Theorem / Sight Beyond",\n    "artist": "John B",\n    "duration": 903.0,\n    "tracks_track_name": "[\'Fermats Theorem\', \'Sight Beyond\']",\n    "tracks_track_duration": "[\'406\', \'497\']",\n    "tracks_track_position": "[\'1\', \'2\']"\n  },\n  "output/runs/20260322_171209_music/normalization/attempt_1/musicbrainz.csv": {\n    "id": "mbrainz_1",\n    "name": "Fermats Theorem / Sight Beyond",\n    "artist": "John B",\n    "release-date": "1996-01-01",\n    "release-country": "United Kingdom of Great Britain and Northern Ireland",\n    "duration": "1055",\n    "tracks_track_name": "[\'Fermats Theorem\', \'Sight Beyond\']",\n    "tracks_track_duration": "[\'558\', \'497\']",\n    "tracks_track_position": "[\'1\', \'2\']"\n  }\n}\n\n        4. A dictionary containing the profile data of the datasets\n        (including number of rows, nulls_per_column and dtypes of\n        the columns):\n        {\n  "output/runs/20260322_171209_music/schema-matching/discogs.csv": "{\\"rows\\": 22627, \\"columns\\": 11, \\"nulls_total\\": 12568, \\"nulls_per_column\\": {\\"id\\": 0, \\"name\\": 0, \\"artist\\": 0, \\"release-date\\": 2234, \\"release-country\\": 600, \\"duration\\": 0, \\"label\\": 0, \\"genre\\": 0, \\"tracks_track_name\\": 1, \\"tracks_track_position\\": 0, \\"tracks_track_duration\\": 9733}, \\"dtypes\\": {\\"id\\": \\"object\\", \\"name\\": \\"object\\", \\"artist\\": \\"object\\", \\"release-date\\": \\"object\\", \\"release-country\\": \\"object\\", \\"duration\\": \\"int64\\", \\"label\\": \\"object\\", \\"genre\\": \\"object\\", \\"tracks_track_name\\": \\"object\\", \\"tracks_track_position\\": \\"object\\", \\"tracks_track_duration\\": \\"object\\"}}",\n  "output/runs/20260322_171209_music/schema-matching/lastfm.csv": "{\\"rows\\": 9865, \\"columns\\": 7, \\"nulls_total\\": 21019, \\"nulls_per_column\\": {\\"id\\": 0, \\"name\\": 0, \\"artist\\": 0, \\"duration\\": 5230, \\"tracks_track_name\\": 5263, \\"tracks_track_duration\\": 5263, \\"tracks_track_position\\": 5263}, \\"dtypes\\": {\\"id\\": \\"object\\", \\"name\\": \\"object\\", \\"artist\\": \\"object\\", \\"duration\\": \\"float64\\", \\"tracks_track_name\\": \\"object\\", \\"tracks_track_duration\\": \\"object\\", \\"tracks_track_position\\": \\"object\\"}}",\n  "output/runs/20260322_171209_music/schema-matching/musicbrainz.csv": "{\\"rows\\": 4763, \\"columns\\": 9, \\"nulls_total\\": 1545, \\"nulls_per_column\\": {\\"id\\": 0, \\"name\\": 0, \\"artist\\": 0, \\"release-date\\": 313, \\"release-country\\": 748, \\"duration\\": 0, \\"tracks_track_name\\": 0, \\"tracks_track_duration\\": 484, \\"tracks_track_position\\": 0}, \\"dtypes\\": {\\"id\\": \\"object\\", \\"name\\": \\"object\\", \\"artist\\": \\"object\\", \\"release-date\\": \\"object\\", \\"release-country\\": \\"object\\", \\"duration\\": \\"object\\", \\"tracks_track_name\\": \\"object\\", \\"tracks_track_duration\\": \\"object\\", \\"tracks_track_position\\": \\"object\\"}}"\n}\n        \n\n        4b. NORMALIZATION CONTEXT (important for robust generation):\n        {\n  "normalization_execution_result": "success",\n  "normalization_attempts": 1,\n  "normalization_directives": {\n    "specs": {\n      "discogs": {\n        "release-date": {\n          "output_type": "datetime",\n          "date_format": "%Y-%m-%dT%H:%M:%S.%f",\n          "on_failure": "keep"\n        },\n        "release-country": {\n          "strip_whitespace": true,\n          "country_format": "name",\n          "on_failure": "keep"\n        },\n        "duration": {\n          "output_type": "string",\n          "on_failure": "keep"\n        },\n        "tracks_track_name": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        },\n        "tracks_track_position": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        },\n        "tracks_track_duration": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        }\n      },\n      "lastfm": {\n        "duration": {\n          "output_type": "string",\n          "on_failure": "keep"\n        },\n        "tracks_track_name": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        },\n        "tracks_track_duration": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        },\n        "tracks_track_position": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        }\n      },\n      "musicbrainz": {\n        "release-date": {\n          "output_type": "datetime",\n          "date_format": "%Y-%m-%dT%H:%M:%S.%f",\n          "on_failure": "keep"\n        },\n        "duration": {\n          "output_type": "string",\n          "on_failure": "keep"\n        },\n        "tracks_track_name": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        },\n        "tracks_track_duration": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        },\n        "tracks_track_position": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        }\n      }\n    },\n    "list_columns": [\n      "tracks_track_name",\n      "tracks_track_duration",\n      "tracks_track_position"\n    ]\n  },\n  "normalization_report": {\n    "status": "success",\n    "attempt": 1,\n    "max_attempts": 3,\n    "validation_set": "input/datasets/music/testsets/test_set.xml",\n    "llm_specs": {\n      "discogs": {\n        "release-date": {\n          "output_type": "datetime",\n          "date_format": "%Y-%m-%dT%H:%M:%S.%f",\n          "on_failure": "keep"\n        },\n        "release-country": {\n          "strip_whitespace": true,\n          "country_format": "name",\n          "on_failure": "keep"\n        },\n        "duration": {\n          "output_type": "string",\n          "on_failure": "keep"\n        },\n        "tracks_track_name": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        },\n        "tracks_track_position": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        },\n        "tracks_track_duration": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        }\n      },\n      "lastfm": {\n        "duration": {\n          "output_type": "string",\n          "on_failure": "keep"\n        },\n        "tracks_track_name": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        },\n        "tracks_track_duration": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        },\n        "tracks_track_position": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        }\n      },\n      "musicbrainz": {\n        "release-date": {\n          "output_type": "datetime",\n          "date_format": "%Y-%m-%dT%H:%M:%S.%f",\n          "on_failure": "keep"\n        },\n        "duration": {\n          "output_type": "string",\n          "on_failure": "keep"\n        },\n        "tracks_track_name": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        },\n        "tracks_track_duration": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        },\n        "tracks_track_position": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        }\n      }\n    },\n    "llm_list_columns": [\n      "tracks_track_name",\n      "tracks_track_duration",\n      "tracks_track_position"\n    ],\n    "llm_reasoning": "Target uses full country names, ISO-like datetimes with time component, and stores duration values as strings. Discogs needs country normalization from values like UK to full names and date normalization from YYYY or YYYY-MM-DD to target datetime style. MusicBrainz dates also need datetime formatting. Track columns in all sources often contain serialized Python-list strings or single scalars, while the target uses list-like values, so they are flagged as list_columns. ID columns are preserved and omitted.",\n    "datasets": {\n      "discogs": {\n        "input_path": "output/runs/20260322_171209_music/schema-matching/discogs.csv",\n        "output_path": "output/runs/20260322_171209_music/normalization/attempt_1/discogs.csv",\n        "row_count": 22627,\n        "id_column": "id",\n        "spec_applied": {\n          "release-date": {\n            "output_type": "datetime",\n            "date_format": "%Y-%m-%dT%H:%M:%S.%f",\n            "on_failure": "keep"\n          },\n          "release-country": {\n            "strip_whitespace": true,\n            "country_format": "name",\n            "on_failure": "keep"\n          },\n          "duration": {\n            "output_type": "string",\n            "on_failure": "keep"\n          },\n          "tracks_track_name": {\n            "strip_whitespace": true,\n            "on_failure": "keep"\n          },\n          "tracks_track_position": {\n            "strip_whitespace": true,\n            "on_failure": "keep"\n          },\n          "tracks_track_duration": {\n            "strip_whitespace": true,\n            "on_failure": "keep"\n          }\n        },\n        "list_columns_applied": [\n          "tracks_track_name",\n          "tracks_track_duration",\n          "tracks_track_position"\n        ]\n      },\n      "lastfm": {\n        "input_path": "output/runs/20260322_171209_music/schema-matching/lastfm.csv",\n        "output_path": "output/runs/20260322_171209_music/normalization/attempt_1/lastfm.csv",\n        "row_count": 9865,\n        "id_column": "id",\n        "spec_applied": {\n          "duration": {\n            "output_type": "string",\n            "on_failure": "keep"\n          },\n          "tracks_track_name": {\n            "strip_whitespace": true,\n            "on_failure": "keep"\n          },\n          "tracks_track_duration": {\n            "strip_whitespace": true,\n            "on_failure": "keep"\n          },\n          "tracks_track_position": {\n            "strip_whitespace": true,\n            "on_failure": "keep"\n          }\n        },\n        "list_columns_applied": [\n          "tracks_track_name",\n          "tracks_track_duration",\n          "tracks_track_position"\n        ]\n      },\n      "musicbrainz": {\n        "input_path": "output/runs/20260322_171209_music/schema-matching/musicbrainz.csv",\n        "output_path": "output/runs/20260322_171209_music/normalization/attempt_1/musicbrainz.csv",\n        "row_count": 4763,\n        "id_column": "id",\n        "spec_applied": {\n          "release-date": {\n            "output_type": "datetime",\n            "date_format": "%Y-%m-%dT%H:%M:%S.%f",\n            "on_failure": "keep"\n          },\n          "duration": {\n            "output_type": "string",\n            "on_failure": "keep"\n          },\n          "tracks_track_name": {\n            "strip_whitespace": true,\n            "on_failure": "keep"\n          },\n          "tracks_track_duration": {\n            "strip_whitespace": true,\n            "on_failure": "keep"\n          },\n          "tracks_track_position": {\n            "strip_whitespace": true,\n            "on_failure": "keep"\n          }\n        },\n        "list_columns_applied": [\n          "tracks_track_name",\n          "tracks_track_duration",\n          "tracks_track_position"\n        ]\n      }\n    },\n    "warnings": [],\n    "acceptance_gate": {\n      "requested": false,\n      "request": {},\n      "pending": {}\n    },\n    "reverted_to_original": false,\n    "created_at": "2026-03-22T17:12:58.590955"\n  }\n}\n\n        IMPORTANT NORMALIZATION RULES:\n- Validation set style drives normalization. Do NOT blindly lowercase text globally.\n- Keep IDs unchanged (case and content must be preserved exactly).\n- If you convert a column to list-like values, any comparator on that column MUST set list_strategy.\n- If StringComparator is used on potentially list-like columns (artist/name/tracks/etc.), set list_strategy explicitly.\n- Prefer normalization that aligns fused output with validation representation, not a random canonical style.\n- You MAY apply targeted inline normalization in the pipeline code (e.g., str.strip(), format conversion) when it directly addresses mismatch patterns visible in the probe data. This is preferred over waiting for a separate normalization pass when the fix is simple and attribute-specific.\n\nLIST HANDLING RULES (CRITICAL):\n- After list normalization, columns like tracks_track_name, tracks_track_position, tracks_track_duration contain actual Python lists (e.g., ["track1", "track2"]).\n- NEVER apply string cleaning operations (strip, lower, isin, notna, etc.) to list-valued columns. These operations crash with "truth value of an array is ambiguous".\n- NEVER call pd.isna(x) or pd.notna(x) directly on a value that might be a list. Use isinstance(x, (list, tuple, set)) check first, or use a safe wrapper.\n- NEVER include list-valued columns in your string_columns cleaning loop. Only clean scalar string columns.\n- NEVER pass DataFrames with list-valued cells directly to EmbeddingBlocker. Flatten list columns to strings first.\n- When writing a lower_strip or preprocess function, handle list inputs: `if isinstance(x, (list, tuple, set)): return " ".join(str(v).lower().strip() for v in x if pd.notna(v))`\n- Recommended list_strategy values per comparator type:\n  * StringComparator: "best_match", "set_jaccard", "set_overlap" (avoid "concatenate" — it merges all elements into one string, producing poor match quality on real lists)\n  * NumericComparator: "average" (default), "best_match", "range_overlap", "set_jaccard"\n  * DateComparator: "closest_dates" (default), "range_overlap", "average_dates", "latest_dates", "earliest_dates"\n- When values are delimited strings (e.g., "pop; rock; jazz"), use union(separator="; ") or intersection(separator="; ") as the fuser to properly split before merging.\n- For list-like fields where source quality varies, use `favour_sources(source_preferences=[...])` or `prefer_higher_trust(trust_map={...})` rather than blind union/intersection.\n- `intersection_k_sources(k=2)` is useful when 2+ source agreement signals correctness.\n- Ensure list normalization is consistent ACROSS sources before fusion (same delimiter, same casing, same element format).\n        \n\n        5. **BLOCKING CONFIGURATION** (pre-computed optimal blocking strategies):\n        This configuration was determined by a blocking evaluation agent. Use these settings\n        for your blocking step in the pipeline:\n        {\n  "blocking_strategies": {\n    "discogs_lastfm": {\n      "strategy": "semantic_similarity",\n      "columns": [\n        "name",\n        "artist"\n      ],\n      "params": {\n        "top_k": 10\n      },\n      "pair_completeness": 0.9642857142857143,\n      "num_candidates": 225831,\n      "is_acceptable": true\n    },\n    "discogs_musicbrainz": {\n      "strategy": "sorted_neighbourhood",\n      "columns": [\n        "name"\n      ],\n      "params": {\n        "window": 15\n      },\n      "pair_completeness": 0.9,\n      "num_candidates": 115280,\n      "is_acceptable": true\n    },\n    "musicbrainz_lastfm": {\n      "strategy": "semantic_similarity",\n      "columns": [\n        "name",\n        "artist",\n        "duration"\n      ],\n      "params": {\n        "top_k": 10\n      },\n      "pair_completeness": 0.9240506329113924,\n      "num_candidates": 47615,\n      "is_acceptable": true\n    }\n  },\n  "id_columns": {\n    "discogs": "id",\n    "lastfm": "id",\n    "musicbrainz": "id"\n  }\n}\n\n        IMPORTANT: Use the id_columns and blocking_strategies from this config:\n        - Use the correct id_column for each dataset as specified\n        - Use the recommended strategy (exact_match_single/multi or semantic_similarity)\n        - Use the recommended columns for blocking\n        - Strategy to blocker mapping:\n          * exact_match_single / exact_match_multi -> StandardBlocker (exact match on columns)\n          * token_blocking / ngram_blocking -> TokenBlocker (token or n-gram blocking)\n          * sorted_neighbourhood -> SortedNeighbourhoodBlocker (window)\n          * semantic_similarity -> EmbeddingBlocker (top_k)\n        - Blocker API contract in this environment:\n          * materialize candidate pairs with `blocker.materialize()`\n          * do NOT call `.block()` on `EmbeddingBlocker`\n          * pass the materialized candidate DataFrame into `RuleBasedMatcher.match(..., candidates=...)`\n        - Correspondence artifact contract (mandatory):\n          * for each expected pair ["discogs_lastfm", "discogs_musicbrainz", "lastfm_musicbrainz"]\n          * save exactly one CSV file to `output/runs/20260322_171209_music/correspondences/correspondences_<left>_<right>.csv`\n          * each file must contain PyDI fusion-ready columns `id1` and `id2` (optional extra columns like `score` are allowed)\n          * do NOT invent alternate filename schemes\n          * do NOT rely on reloading or renaming correspondences later to make them usable\n          * fail fast if an expected pair\'s correspondence DataFrame is empty before fusion\n        \n\n        6. **MATCHING CONFIGURATION** (pre-computed comparator settings):\n        This configuration was determined by a matching evaluation agent. Use these settings\n        for your RuleBasedMatcher step in the pipeline:\n        {\n  "id_columns": {\n    "discogs": "id",\n    "lastfm": "id",\n    "musicbrainz": "id"\n  },\n  "matching_strategies": {\n    "discogs_lastfm": {\n      "comparators": [\n        {\n          "type": "string",\n          "column": "artist",\n          "similarity_function": "jaro_winkler",\n          "preprocess": "lower_strip",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "string",\n          "column": "name",\n          "similarity_function": "jaro_winkler",\n          "preprocess": "lower_strip",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "string",\n          "column": "tracks_track_name",\n          "similarity_function": "cosine",\n          "preprocess": "lower_strip",\n          "list_strategy": "set_jaccard"\n        },\n        {\n          "type": "numeric",\n          "column": "duration",\n          "max_difference": 10.0\n        }\n      ],\n      "weights": [\n        0.3,\n        0.35,\n        0.25,\n        0.1\n      ],\n      "threshold": 0.6,\n      "f1": 0.896551724137931\n    },\n    "discogs_musicbrainz": {\n      "comparators": [\n        {\n          "type": "string",\n          "column": "name",\n          "similarity_function": "jaro_winkler",\n          "preprocess": "lower_strip",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "string",\n          "column": "artist",\n          "similarity_function": "jaro_winkler",\n          "preprocess": "lower_strip",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "date",\n          "column": "release-date",\n          "max_days_difference": 365\n        },\n        {\n          "type": "string",\n          "column": "release-country",\n          "similarity_function": "cosine",\n          "preprocess": "lower_strip",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "numeric",\n          "column": "duration",\n          "max_difference": 60.0\n        }\n      ],\n      "weights": [\n        0.35,\n        0.25,\n        0.2,\n        0.1,\n        0.1\n      ],\n      "threshold": 0.7,\n      "f1": 0.8732394366197184\n    },\n    "musicbrainz_lastfm": {\n      "comparators": [\n        {\n          "type": "string",\n          "column": "artist",\n          "similarity_function": "jaro_winkler",\n          "preprocess": "lower_strip",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "string",\n          "column": "name",\n          "similarity_function": "cosine",\n          "preprocess": "lower_strip",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "string",\n          "column": "duration",\n          "similarity_function": "jaro_winkler",\n          "preprocess": "lower_strip",\n          "list_strategy": "concatenate"\n        }\n      ],\n      "weights": [\n        0.35,\n        0.45,\n        0.2\n      ],\n      "threshold": 0.75,\n      "f1": 0.8652482269503546\n    }\n  }\n}\n\n        IMPORTANT: Use the matching_strategies from this config:\n        - Build comparators (StringComparator/NumericComparator/DateComparator) for each dataset pair\n        - Use the specified weights and threshold.\n        - For each pair in `matching_strategies`, you **MUST** define a\n            variable named `threshold_[original_pair_key]` (e.g.,\n            `threshold_discogs_lastfm = 0.7`) with the corresponding threshold value.\n            Ensure your RuleBasedMatcher instances use these variables for their\n            `threshold` parameter.\n        - preprocess mapping: "lower" -> str.lower, "strip" -> str.strip, "lower_strip" -> lambda x: str(x).lower().strip()\n\n        - For NumericComparator on potentially list-valued columns (e.g., duration fields), set `list_strategy` explicitly (recommended: "average") or safely scalarize before matching.\n        - For DateComparator on multi-date columns, set `list_strategy` explicitly (recommended: "closest_dates").\n        \n\n        Your task is to **create a similar integration pipeline** so that it works with\n        the datasets provided. Output should only consist of the relevant Python code\n        for the integration pipeline.\n\n        OUTPUT PATHS (MANDATORY — use these exact paths, do NOT hardcode \'output/\'):\n        - Correspondences: save to `{correspondences_dir}/correspondences_<left>_<right>.csv`\n        - Fusion data: save to `{output_dir}/data_fusion/fusion_data.csv`\n        - Fusion debug: save to `{output_dir}/data_fusion/debug_fusion_data.jsonl`\n        - Create directories with `os.makedirs(..., exist_ok=True)` before writing.\n\n        FUSION RULES (MANDATORY):\n        - The output must always be the full fused dataset. Run `DataFusionEngine.run(..., include_singletons=True)`.\n        - Use PyDI built-in fusers as the default and strongly preferred choice.\n        - NEVER write custom fusion resolvers, lambda resolvers, or helper functions for fusion. Use ONLY PyDI built-in resolvers.\n        - The built-in resolvers cover ALL use cases: voting, longest_string, most_complete, median, average, earliest, most_recent, union, intersection, intersection_k_sources, prefer_higher_trust, favour_sources.\n        - For list-valued columns: use union(separator="; ") or intersection_k_sources(k=2, separator="; ").\n        - For trust-based selection: use prefer_higher_trust(trust_map={...}) or favour_sources(source_preferences=[...]).\n        - Do NOT manually post-process or overwrite `_fusion_confidence` outside the normal resolver return contract.\n        - ML MATCHER WARNING: When using MLBasedMatcher, clusters often contain MULTIPLE records per source dataset\n          (e.g. 5 discogs records + 3 lastfm records + 2 musicbrainz records in one cluster).\n          In this situation, `voting` is BIASED toward whichever source contributed more records to the cluster,\n          regardless of data quality. NEVER use `voting` as a primary resolver with ML matching.\n          Instead use `prefer_higher_trust` or `favour_sources` to select the most authoritative source,\n          or use `shortest_string`/`longest_string` which pick by value characteristics rather than majority.\n        - Choose fusion strategies based on EVIDENCE, not just data type:\n          * If one source is clearly more complete/accurate for an attribute (visible in input data samples or source agreement), use `prefer_higher_trust` with appropriate trust_map\n          * If sources have roughly equal quality, use `voting` for strings, `median` for numbers\n          * `longest_string` is excellent for text attributes where one source has more complete/detailed values (e.g., full label names vs abbreviations, complete genre lists vs partial). Consider it as a strong default for metadata text fields.\n          * `most_complete` is similar to longest_string but also considers non-null coverage. Good for attributes with many nulls in some sources.\n          * For numeric aggregates (e.g., total duration, page count): consider `maximum` when the target represents a "full" measurement — the maximum value often reflects the most complete source. Use `median` only when averaging across sources makes semantic sense.\n          * If mismatch samples show format differences (not value differences), fix normalization before fusion rather than switching fusers\n          * For list-like fields: use `intersection(separator=...)` or `intersection_k_sources(k=2)` when sources are noisy; use `union(separator=...)` only when both sources are clean and complementary\n          * For list-like fields where one source is clearly better, use `favour_sources(source_preferences=[...])` instead of union/intersection\n          * For dates: use `prefer_higher_trust` with data-driven trust ordering. Avoid `earliest` as a blanket default — it picks the oldest date regardless of correctness. Only use `most_recent` when diagnostics explicitly justify recency semantics\n          * IMPORTANT: Review the INPUT DATA SAMPLES section to see actual values from each source before choosing trust levels\n        - For trust-based fusion, pass trust configuration only at registration time:\n          `strategy.add_attribute_fuser(attr, prefer_higher_trust, trust_map=trust_map)`\n        - Do NOT wrap `prefer_higher_trust` in another function that hardcodes `trust_map` again.\n        - Avoid `most_recent` as a default temporal resolver unless diagnostics explicitly show recency is the correct target semantics.\n        - Avoid `union` for list-like fields when cluster purity is weak or list-format inconsistencies are present.\n\n        {PIPELINE_MATCHING_SAFETY_RULES_BLOCK}\n        \n            8. Evaluation reasoning from prior pipeline run:\n            {\n  "action": "decide",\n  "diagnosis": "The main error is in fusion strategy/post-clustering, not blocking or source normalization. Matching is reasonably strong (pairwise F1 \\u22480.87-0.90, no empty correspondence files, blocking recall probe found no issues), but fusion is choosing the wrong source/resolver and many fused entities end up without the expected MusicBrainz-based eval ID, producing widespread missing_fused_value. Current fusers conflict with the source-vs-validation evidence: label uses most_complete even though only discogs has non-null/correct labels; release-date uses prefer_higher_trust with a trust map favoring musicbrainz even though exact date agreement is 0% for all sources and the probe recommends voting; name uses favour_sources preferring musicbrainz though validation is closest to lastfm/shorter canonical names; artist uses longest_string though validation favors musicbrainz. Track-list attributes are partly structurally limited, but tracks_track_position also shows avoidable missingness likely from cluster/post-cluster selection. Overall, the pipeline is matching many right entities but fusing attributes incorrectly and preserving suboptimal cluster assignments.",\n  "next_node": "pipeline_adaption",\n  "reasoning": "This should go to pipeline_adaption because the needed fixes are resolver choice, trust ordering, and post-clustering only. The current normalization already targets validation formats (country names, datetime formatting, list parsing), and the remaining top improvable errors are not primarily source-format mismatches but wrong fused value selection or no selected fused representative. Blocking/matching metrics are already high enough that they are not the first bottleneck. Protected attributes above 85% should be left untouched. We should change only low-performing attributes with explicit source-vs-validation evidence and adopt the recommended MaximumBipartiteMatching post-clustering to reduce ambiguous many-to-many clusters that currently lead to missing fused outputs.",\n  "ceiling_assessment": "With current source content and unchanged matching/import structure, overall accuracy should plausibly rise from 0.64 toward about 0.80-0.86. Reaching the full estimated 0.881 ceiling is unlikely in one step because tracks_track_duration and tracks_track_name are structurally limited list attributes with source disagreement and formatting/content variation. Biggest safe gains are from label, release-date, tracks_track_position, plus better source preference for name/artist/duration.",\n  "recommendations": [\n    {\n      "attribute": "label",\n      "issue": "Current resolver most_complete returns empty or wrong values because musicbrainz has 0% non-null for label while discogs has 100% non-null and 64% exact to validation.",\n      "fix": "Use prefer_higher_trust for label with trust_map={\'discogs\': 3, \'musicbrainz\': 2, \'lastfm\': 1} or favour_sources(source_preferences=[\'discogs\',\'musicbrainz\',\'lastfm\']).",\n      "resolver_reasoning": "Validation expects a scalar label and probe comparison shows discogs is the only useful source (64% exact, 100% non-null) while musicbrainz contributes nothing. prefer_higher_trust is the best fit because one source is clearly dominant. most_complete fails because emptiness/completeness is not the issue once discogs is present; voting is worse because sparse disagreement and nulls would not help; longest/shortest_string are inappropriate for label semantics.",\n      "class": "improvable",\n      "expected_impact": 0.06\n    },\n    {\n      "attribute": "release-date",\n      "issue": "Current resolver prefer_higher_trust with global trust_map favoring musicbrainz chooses a source that never exactly matches validation; validation appears to prefer consensus/coarser dates rather than any single source.",\n      "fix": "Use voting for release-date. If API requires tie handling through trust, use voting with source preference discogs > lastfm > musicbrainz as indicated by probe.",\n      "resolver_reasoning": "All sources have 0% exact but substantial fuzzy agreement (discogs 64%, musicbrainz 61%, lastfm 54%), and the provided comparison explicitly recommends voting. This means the target often reflects shared/coarsened date information, not a single trusted source. prefer_higher_trust is harmful here because it deterministically picks one source\'s more specific or divergent date. earliest is unsupported by evidence; favour_sources would still overcommit to one source.",\n      "class": "improvable",\n      "expected_impact": 0.04\n    },\n    {\n      "attribute": "artist",\n      "issue": "Current resolver longest_string is misaligned with validation; probe shows musicbrainz is best by a large margin.",\n      "fix": "Use prefer_higher_trust for artist with trust_map={\'musicbrainz\': 3, \'discogs\': 2, \'lastfm\': 1}.",\n      "resolver_reasoning": "MusicBrainz has 83% exact / 87% fuzzy versus much lower alternatives, so source quality dominates. prefer_higher_trust directly encodes that. longest_string can overselect verbose artist variants like collaborations/featuring text not used in validation. voting is weaker when sources systematically differ; favour_sources is similar but less explicit than trust-based selection if later reused consistently.",\n      "class": "improvable",\n      "expected_impact": 0.02\n    },\n    {\n      "attribute": "name",\n      "issue": "Current resolver favour_sources preferring musicbrainz conflicts with validation, which is closest to lastfm and tends toward shorter canonical titles.",\n      "fix": "Use shortest_string for name; if implementation needs source bias, pair with source order lastfm > musicbrainz > discogs where available.",\n      "resolver_reasoning": "Probe shows lastfm 77% exact / 100% fuzzy, musicbrainz 70% / 96%, discogs 64% / 91%, with explicit recommendation shortest_string. Validation appears to prefer concise canonical names rather than verbose variants. favour_sources with musicbrainz-first likely selects longer or alternate titles. prefer_higher_trust to lastfm could help, but shortest_string better matches the observed pattern across sources and the probe\'s recommendation.",\n      "class": "improvable",\n      "expected_impact": 0.02\n    },\n    {\n      "attribute": "duration",\n      "issue": "Current resolver maximum likely overestimates album duration when sources disagree; probe indicates discogs is the best exact source.",\n      "fix": "Use prefer_higher_trust for duration with trust_map={\'discogs\': 3, \'musicbrainz\': 2, \'lastfm\': 1}.",\n      "resolver_reasoning": "Discogs has 46% exact while musicbrainz has 0% exact and only fuzzy agreement; lastfm is worse. maximum is only appropriate when validation expects an aggregate upper bound, which is not supported here. A dominant source exists, so prefer_higher_trust is better than median or voting. median could reduce extreme errors but lacks evidence of symmetric numeric noise.",\n      "class": "improvable",\n      "expected_impact": 0.02\n    },\n    {\n      "attribute": "tracks_track_position",\n      "issue": "Missing fused values remain despite source non-nullness, and ambiguous many-to-many correspondences likely produce poor cluster representatives or fragmented clusters.",\n      "fix": "Enable/replace post-clustering with MaximumBipartiteMatching as recommended by cluster analysis; keep existing list attribute fuser otherwise for now.",\n      "resolver_reasoning": "This attribute is marked improvable mainly due to missing_fused rather than source-format mismatch. Cluster diagnostics show high ambiguity in discogs-lastfm (87.6% top-2 gap < 0.1) and recommend MaximumBipartiteMatching. Because pipeline_adaption can change post-clustering but not matching itself, this is the highest-leverage way to reduce fused-record absence without altering upstream steps. Changing list resolver alone will not recover records that never get properly clustered.",\n      "class": "improvable",\n      "expected_impact": 0.03\n    },\n    {\n      "attribute": "tracks_track_name",\n      "issue": "Low accuracy is driven by structural list disagreement and formatting/content differences such as numbering, punctuation, and partial tracklists.",\n      "fix": "Preserve current resolver for now; do not spend this iteration on it in pipeline_adaption beyond benefiting from MaximumBipartiteMatching. Revisit in normalization later if needed.",\n      "resolver_reasoning": "This attribute is explicitly marked structurally_limited with ceiling 68.7%. Examples show numbering/punctuation differences (\'01 ...\', \'steady, as she goes\') and differing track set lengths, which are pre-fusion normalization/list-representation issues. pipeline_adaption cannot safely fix those formats. Union/intersection/favour_sources each risk regressions because validation sometimes expects a cleaned canonical list, not a raw union or strict overlap.",\n      "class": "structurally_limited",\n      "expected_impact": 0.01\n    },\n    {\n      "attribute": "tracks_track_duration",\n      "issue": "Low accuracy is driven by structural list disagreement and differing per-track values/track coverage across sources.",\n      "fix": "Preserve current resolver for now; only expect minor indirect gains from MaximumBipartiteMatching. Do not prioritize direct fusion-rule changes in this iteration.",\n      "resolver_reasoning": "This attribute is structurally_limited with ceiling 64.0%. Examples show conflicting durations and different list lengths; no single resolver can reliably recover validation when sources disagree at element level. prefer_higher_trust(discogs) was suggested by probe for scalar duration, but for track-duration lists the mismatch is not just source quality; it is missing/extra tracks and per-track disagreements. Normalization or different evaluation tolerance would matter more than a fusion swap.",\n      "class": "structurally_limited",\n      "expected_impact": 0.01\n    }\n  ]\n}\n            \n            8b. COMPACT NEXT-PASS SUMMARY:\n            {\n  "root_cause": "The main error is in fusion strategy/post-clustering, not blocking or source normalization. Matching is reasonably strong (pairwise F1 \\u22480.87-0.90, no empty correspondence files, blocking recall probe found no issues), but fusion is choosing the wrong source/resolver and many fused entities end up without the expected MusicBrainz-based eval ID, producing widespread missing_fused_value. Current fusers conflict with the source-vs-validation evidence: label uses most_complete even though only discogs has non-null/correct labels; release-date uses prefer_higher_trust with a trust map favoring musicbrainz even though exact date agreement is 0% for all sources and the probe recommends voting; name uses favour_sources preferring musicbrainz though validation is closest to lastfm/shorter canonical names; artist uses longest_string though validation favors musicbrainz. Track-list attributes are partly structurally limited, but tracks_track_position also shows avoidable missingness likely from cluster/post-cluster selection. Overall, the pipeline is matching many right entities but fusing attributes incorrectly and preserving suboptimal cluster assignments.",\n  "next_step": "This should go to pipeline_adaption because the needed fixes are resolver choice, trust ordering, and post-clustering only. The current normalization already targets validation formats (country names, datetime formatting, list parsing), and the remaining top improvable errors are not primarily source-format mismatches but wrong fused value selection or no selected fused representative. Blocking/matching metrics are already high enough that they are not the first bottleneck. Protected attributes above 85% should be left untouched. We should change only low-performing attributes with explicit source-vs-validation evidence and adopt the recommended MaximumBipartiteMatching post-clustering to reduce ambiguous many-to-many clusters that currently lead to missing fused outputs.",\n  "takeaway": "The main error is in fusion strategy/post-clustering, not blocking or source normalization. Matching is reasonably strong (pairwise F1 \\u22480.87-0.90, no empty correspondence files, blocking recall probe found no issues), but fusion is choosing the wrong source/resolver and many fused entities end up without the expected MusicBrainz-based eval ID, producing widespread missing_fused_value. Current fusers conflict with the source-vs-validation evidence: label uses most_complete even though only discogs has non-null/correct labels; release-date uses prefer_higher_trust with a trust map favoring musicbrainz even though exact date agreement is 0% for all sources and the probe recommends voting; name uses favour_sources preferring musicbrainz though validation is closest to lastfm/shorter canonical names; artist uses longest_string though validation favors musicbrainz. Track-list attributes are partly structurally limited, but tracks_track_position also shows avoidable missingness likely from cluster/post-cluster selection. Overall, the pipeline is matching many right entities but fusing attributes incorrectly and preserving suboptimal cluster assignments.",\n  "recommendations": [\n    {\n      "attribute": "label",\n      "issue": "Current resolver most_complete returns empty or wrong values because musicbrainz has 0% non-null for label while discogs has 100% non-null and 64% exact to validation.",\n      "fix": "Use prefer_higher_trust for label with trust_map={\'discogs\': 3, \'musicbrainz\': 2, \'lastfm\': 1} or favour_sources(source_preferences=[\'discogs\',\'musicbrainz\',\'lastfm\']).",\n      "resolver_reasoning": "Validation expects a scalar label and probe comparison shows discogs is the only useful source (64% exact, 100% non-null) while musicbrainz contributes nothing. prefer_higher_trust is the best fit because one source is clearly dominant. most_complete fails because emptiness/completeness is not the issue once discogs is present; voting is worse because sparse disagreement and nulls would not help; longest/shortest_string are inappropriate for label semantics.",\n      "class": "improvable",\n      "expected_impact": 0.06\n    },\n    {\n      "attribute": "release-date",\n      "issue": "Current resolver prefer_higher_trust with global trust_map favoring musicbrainz chooses a source that never exactly matches validation; validation appears to prefer consensus/coarser dates rather than any single source.",\n      "fix": "Use voting for release-date. If API requires tie handling through trust, use voting with source preference discogs > lastfm > musicbrainz as indicated by probe.",\n      "resolver_reasoning": "All sources have 0% exact but substantial fuzzy agreement (discogs 64%, musicbrainz 61%, lastfm 54%), and the provided comparison explicitly recommends voting. This means the target often reflects shared/coarsened date information, not a single trusted source. prefer_higher_trust is harmful here because it deterministically picks one source\'s more specific or divergent date. earliest is unsupported by evidence; favour_sources would still overcommit to one source.",\n      "class": "improvable",\n      "expected_impact": 0.04\n    },\n    {\n      "attribute": "artist",\n      "issue": "Current resolver longest_string is misaligned with validation; probe shows musicbrainz is best by a large margin.",\n      "fix": "Use prefer_higher_trust for artist with trust_map={\'musicbrainz\': 3, \'discogs\': 2, \'lastfm\': 1}.",\n      "resolver_reasoning": "MusicBrainz has 83% exact / 87% fuzzy versus much lower alternatives, so source quality dominates. prefer_higher_trust directly encodes that. longest_string can overselect verbose artist variants like collaborations/featuring text not used in validation. voting is weaker when sources systematically differ; favour_sources is similar but less explicit than trust-based selection if later reused consistently.",\n      "class": "improvable",\n      "expected_impact": 0.02\n    },\n    {\n      "attribute": "name",\n      "issue": "Current resolver favour_sources preferring musicbrainz conflicts with validation, which is closest to lastfm and tends toward shorter canonical titles.",\n      "fix": "Use shortest_string for name; if implementation needs source bias, pair with source order lastfm > musicbrainz > discogs where available.",\n      "resolver_reasoning": "Probe shows lastfm 77% exact / 100% fuzzy, musicbrainz 70% / 96%, discogs 64% / 91%, with explicit recommendation shortest_string. Validation appears to prefer concise canonical names rather than verbose variants. favour_sources with musicbrainz-first likely selects longer or alternate titles. prefer_higher_trust to lastfm could help, but shortest_string better matches the observed pattern across sources and the probe\'s recommendation.",\n      "class": "improvable",\n      "expected_impact": 0.02\n    },\n    {\n      "attribute": "duration",\n      "issue": "Current resolver maximum likely overestimates album duration when sources disagree; probe indicates discogs is the best exact source.",\n      "fix": "Use prefer_higher_trust for duration with trust_map={\'discogs\': 3, \'musicbrainz\': 2, \'lastfm\': 1}.",\n      "resolver_reasoning": "Discogs has 46% exact while musicbrainz has 0% exact and only fuzzy agreement; lastfm is worse. maximum is only appropriate when validation expects an aggregate upper bound, which is not supported here. A dominant source exists, so prefer_higher_trust is better than median or voting. median could reduce extreme errors but lacks evidence of symmetric numeric noise.",\n      "class": "improvable",\n      "expected_impact": 0.02\n    },\n    {\n      "attribute": "tracks_track_position",\n      "issue": "Missing fused values remain despite source non-nullness, and ambiguous many-to-many correspondences likely produce poor cluster representatives or fragmented clusters.",\n      "fix": "Enable/replace post-clustering with MaximumBipartiteMatching as recommended by cluster analysis; keep existing list attribute fuser otherwise for now.",\n      "resolver_reasoning": "This attribute is marked improvable mainly due to missing_fused rather than source-format mismatch. Cluster diagnostics show high ambiguity in discogs-lastfm (87.6% top-2 gap < 0.1) and recommend MaximumBipartiteMatching. Because pipeline_adaption can change post-clustering but not matching itself, this is the highest-leverage way to reduce fused-record absence without altering upstream steps. Changing list resolver alone will not recover records that never get properly clustered.",\n      "class": "improvable",\n      "expected_impact": 0.03\n    },\n    {\n      "attribute": "tracks_track_name",\n      "issue": "Low accuracy is driven by structural list disagreement and formatting/content differences such as numbering, punctuation, and partial tracklists.",\n      "fix": "Preserve current resolver for now; do not spend this iteration on it in pipeline_adaption beyond benefiting from MaximumBipartiteMatching. Revisit in normalization later if needed.",\n      "resolver_reasoning": "This attribute is explicitly marked structurally_limited with ceiling 68.7%. Examples show numbering/punctuation differences (\'01 ...\', \'steady, as she goes\') and differing track set lengths, which are pre-fusion normalization/list-representation issues. pipeline_adaption cannot safely fix those formats. Union/intersection/favour_sources each risk regressions because validation sometimes expects a cleaned canonical list, not a raw union or strict overlap.",\n      "class": "structurally_limited",\n      "expected_impact": 0.01\n    },\n    {\n      "attribute": "tracks_track_duration",\n      "issue": "Low accuracy is driven by structural list disagreement and differing per-track values/track coverage across sources.",\n      "fix": "Preserve current resolver for now; only expect minor indirect gains from MaximumBipartiteMatching. Do not prioritize direct fusion-rule changes in this iteration.",\n      "resolver_reasoning": "This attribute is structurally_limited with ceiling 64.0%. Examples show conflicting durations and different list lengths; no single resolver can reliably recover validation when sources disagree at element level. prefer_higher_trust(discogs) was suggested by probe for scalar duration, but for track-duration lists the mismatch is not just source quality; it is missing/extra tracks and per-track disagreements. Normalization or different evaluation tolerance would matter more than a fusion swap.",\n      "class": "structurally_limited",\n      "expected_impact": 0.01\n    }\n  ],\n  "next_node": "pipeline_adaption",\n  "ceiling_assessment": "With current source content and unchanged matching/import structure, overall accuracy should plausibly rise from 0.64 toward about 0.80-0.86. Reaching the full estimated 0.881 ceiling is unlikely in one step because tracks_track_duration and tracks_track_name are structurally limited list attributes with source disagreement and formatting/content variation. Biggest safe gains are from label, release-date, tracks_track_position, plus better source preference for name/artist/duration."\n}\n\n            Treat this as the highest-signal summary of what went wrong and what to try next.\n            \n            9. AUTO DIAGNOSTICS FROM THE LAST EXECUTION (summarized):\n            ID alignment: direct=30.4%, mapped=100.0%\n  ⚠ Low direct ID coverage — fused entities may use different ID format than evaluation set\nTop mismatch reasons:\n  - missing_fused_value: 63.4%\n  - mismatch: 36.6%\n\n            You MUST react to these diagnostics:\n            - Always set `include_singletons=True`. The goal is the full fused dataset, never matched-only output.\n            - Preserve source IDs for evaluation alignment when mapped ID coverage is low or missing_fused_value is high.\n            - If list-attribute accuracy is very low, do not blindly union noisy lists; use a robust strategy (trusted-source selection or consensus with normalization).\n            - Always write correspondence files for every evaluated pair to `output/runs/20260322_171209_music/correspondences/` so cluster analysis uses current run artifacts.\n            - When passing correspondences into PyDI fusion, the required schema is `id1`/`id2`. Do not invent alternate required columns such as `id_l`/`id_r`.\n            \n            11. INVESTIGATOR ACTION PLAN (RANKED):\n            [\n  {\n    "action": "Use prefer_higher_trust for label with trust_map={\'discogs\': 3, \'musicbrainz\': 2, \'lastfm\': 1} or favour_sources(source_preferences=[\'discogs\',\'musicbrainz\',\'lastfm\']).",\n    "target_attributes": [\n      "label"\n    ],\n    "priority_score": 0.06,\n    "confidence": 0.8,\n    "source": "investigation",\n    "attribute_class": "improvable"\n  },\n  {\n    "action": "Use voting for release-date. If API requires tie handling through trust, use voting with source preference discogs > lastfm > musicbrainz as indicated by probe.",\n    "target_attributes": [\n      "release-date"\n    ],\n    "priority_score": 0.04,\n    "confidence": 0.8,\n    "source": "investigation",\n    "attribute_class": "improvable"\n  },\n  {\n    "action": "Use prefer_higher_trust for artist with trust_map={\'musicbrainz\': 3, \'discogs\': 2, \'lastfm\': 1}.",\n    "target_attributes": [\n      "artist"\n    ],\n    "priorit