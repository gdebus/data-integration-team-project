11:49:55,268 root INFO RESULT:import pandas as pd
import json
import ast
import re
import os
from collections import Counter
from pathlib import Path
import sys

from PyDI.io import load_xml
from PyDI.fusion import (
    DataFusionStrategy,
    DataFusionEvaluator,
    tokenized_match,
    year_only_match,
    set_equality_match,
    numeric_tolerance_match,
    exact_match,
    boolean_match,
)

try:
    from list_normalization import detect_list_like_columns, normalize_list_like_columns
except ModuleNotFoundError:
    _candidates = [
        Path.cwd(),
        Path.cwd() / "agents",
        Path(__file__).resolve().parent if "__file__" in globals() else Path.cwd(),
        (Path(__file__).resolve().parent.parent if "__file__" in globals() else Path.cwd()),
        (Path(__file__).resolve().parent.parent.parent if "__file__" in globals() else Path.cwd()),
    ]
    for _path in _candidates:
        if (_path / "list_normalization.py").is_file():
            if str(_path.resolve()) not in sys.path:
                sys.path.append(str(_path.resolve()))
    from list_normalization import detect_list_like_columns, normalize_list_like_columns


# ================================
# 0. OUTPUT DIRECTORY
# ================================
OUTPUT_DIR = "output/runs/20260423_111733_games"
FUSION_DIR = os.path.join(OUTPUT_DIR, "data_fusion")
EVAL_DIR = os.path.join(OUTPUT_DIR, "pipeline_evaluation")
os.makedirs(EVAL_DIR, exist_ok=True)


# ================================
# HELPERS
# ================================
def _safe_is_missing(value):
    if value is None:
        return True
    try:
        if pd.isna(value):
            return True
    except Exception:
        pass
    if isinstance(value, str) and not value.strip():
        return True
    if isinstance(value, (list, tuple, set)) and len(value) == 0:
        return True
    return False


def _meaningful_series(s):
    if s is None:
        return pd.Series(dtype="object")
    out = s.dropna()
    if out.empty:
        return out
    out = out.astype(str).str.strip().replace("", pd.NA).dropna()
    return out


def _parse_source_ids(value):
    if value is None:
        return []
    if isinstance(value, (list, tuple, set)):
        return [str(v) for v in value if str(v).strip()]
    text = str(value).strip()
    if not text:
        return []
    if text[0] not in "[({":
        return []
    for parser in (json.loads, ast.literal_eval):
        try:
            parsed = parser(text)
            if isinstance(parsed, (list, tuple, set)):
                return [str(v) for v in parsed if str(v).strip()]
        except Exception:
            pass
    return []


def _detect_gold_prefix(gold_ids):
    prefixes = [g.split("_", 1)[0] for g in gold_ids if "_" in g]
    if not prefixes:
        return None
    return Counter(prefixes).most_common(1)[0][0] + "_"


def _normalize_text_scalar(value):
    if _safe_is_missing(value):
        return value
    return str(value).strip()


def _normalize_list_text_case(value):
    if _safe_is_missing(value):
        return value
    if isinstance(value, (list, tuple, set)):
        cleaned = [str(v).strip().lower() for v in value if str(v).strip()]
        return cleaned
    text = str(value).strip()
    return text.lower() if text else text


def _looks_like_bool_column(series):
    vals = set(_meaningful_series(series).str.lower().unique().tolist())
    if not vals:
        return False
    allowed = {"true", "false", "yes", "no", "0", "1", "t", "f"}
    return vals.issubset(allowed)


def _coerce_numeric_pair(fused_df, gold_df, columns):
    for col in columns:
        if col in fused_df.columns:
            fused_df[col] = pd.to_numeric(fused_df[col], errors="coerce")
            nz = fused_df[col].dropna()
            if len(nz) > 0 and nz.apply(lambda x: float(x).is_integer()).all():
                fused_df[col] = fused_df[col].astype("Int64")
        if col in gold_df.columns:
            gold_df[col] = pd.to_numeric(gold_df[col], errors="coerce")
            nz = gold_df[col].dropna()
            if len(nz) > 0 and nz.apply(lambda x: float(x).is_integer()).all():
                gold_df[col] = gold_df[col].astype("Int64")


def _is_meaningful_in_both(fused_df, gold_df, col):
    if col not in fused_df.columns or col not in gold_df.columns:
        return False
    fused_vals = _meaningful_series(fused_df[col])
    gold_vals = _meaningful_series(gold_df[col])
    return (not fused_vals.empty) and (not gold_vals.empty)


def _is_nested_artifact(col):
    if col in {"id", "_id", "eval_id", "_eval_cluster_id", "_fusion_sources", "_fusion_confidence"}:
        return False
    return len(str(col).split("_")) >= 3


def build_eval_view(fused_df, gold_df):
    """
    Build evaluation-aligned fused view.
    Priority:
      1) robust mapping by searching _fusion_sources for gold IDs
      2) fallback to eval_id if already present and useful
      3) fallback to cluster _id
    """
    gold_ids = set(gold_df["id"].dropna().astype(str).tolist()) if "id" in gold_df.columns else set()
    gold_prefix = _detect_gold_prefix(gold_ids)
    expanded_rows = []

    if "_fusion_sources" in fused_df.columns:
        for _, row in fused_df.iterrows():
            row_dict = row.to_dict()
            cluster_id = str(row_dict.get("_id", ""))
            source_ids = _parse_source_ids(row_dict.get("_fusion_sources"))

            candidates = []
            if gold_prefix:
                candidates = [sid for sid in source_ids if sid.startswith(gold_prefix)]
            if not candidates:
                candidates = [sid for sid in source_ids if sid in gold_ids]
            if not candidates and "eval_id" in row_dict and str(row_dict.get("eval_id", "")).strip():
                candidates = [str(row_dict["eval_id"])]
            if not candidates and cluster_id:
                candidates = [cluster_id]

            seen = set()
            for eval_id in candidates:
                if eval_id in seen:
                    continue
                seen.add(eval_id)
                enriched = dict(row_dict)
                enriched["eval_id"] = str(eval_id)
                enriched["_eval_cluster_id"] = cluster_id
                expanded_rows.append(enriched)

    if expanded_rows:
        fused_eval = pd.DataFrame(expanded_rows)
        if "_fusion_confidence" in fused_eval.columns:
            fused_eval["_fusion_confidence"] = pd.to_numeric(
                fused_eval["_fusion_confidence"], errors="coerce"
            ).fillna(0.0)
            fused_eval = fused_eval.sort_values("_fusion_confidence", ascending=False)
        fused_eval = fused_eval.drop_duplicates(subset=["eval_id"], keep="first")
        return fused_eval

    fallback = fused_df.copy()
    if "eval_id" in fallback.columns:
        fallback["eval_id"] = fallback["eval_id"].astype(str)
    elif "_id" in fallback.columns:
        fallback["eval_id"] = fallback["_id"].astype(str)
    else:
        fallback["eval_id"] = fallback.index.astype(str)
    fallback["_eval_cluster_id"] = fallback.get("_id", fallback["eval_id"]).astype(str)
    return fallback


# ================================
# 1. LOAD FUSED OUTPUT AND GOLD SET
# ================================
fused = pd.read_csv(os.path.join(FUSION_DIR, "fusion_data.csv"))
fusion_eval_set = load_xml(
    "input/datasets/games/testsets/validation_set_fusion.xml",
    name="fusion_validation_set",
    nested_handling="aggregate",
)

fused_eval = build_eval_view(fused, fusion_eval_set)

# ================================
# 2. ID ALIGNMENT DIAGNOSTICS
# ================================
gold_ids = set(fusion_eval_set["id"].dropna().astype(str).tolist()) if "id" in fusion_eval_set.columns else set()
direct_cov = len(set(fused["_id"].astype(str).tolist()) & gold_ids) if "_id" in fused.columns else 0
eval_cov = len(set(fused["eval_id"].astype(str).tolist()) & gold_ids) if "eval_id" in fused.columns else 0
mapped_cov = len(set(fused_eval["eval_id"].astype(str).tolist()) & gold_ids) if "eval_id" in fused_eval.columns else 0

print(json.dumps({
    "id_alignment": {
        "gold_count": len(gold_ids),
        "direct__id_coverage": direct_cov,
        "pipeline_eval_id_coverage": eval_cov,
        "mapped_eval_id_coverage": mapped_cov,
    }
}, indent=2))

# ================================
# 3. NORMALIZE REPRESENTATION FOR EVALUATION
# Use validation-set representation as target.
# DO NOT country-normalize here.
# ================================
shared_columns = sorted(set(fused_eval.columns) & set(fusion_eval_set.columns))

list_eval_columns = detect_list_like_columns(
    [fused_eval, fusion_eval_set],
    exclude_columns={"id", "_id", "eval_id", "_eval_cluster_id", "_fusion_confidence", "_fusion_sources"},
)
list_eval_columns = [c for c in list_eval_columns if c in shared_columns and not c.startswith("_")]

if list_eval_columns:
    fused_eval, fusion_eval_set = normalize_list_like_columns([fused_eval, fusion_eval_set], list_eval_columns)
    for col in list_eval_columns:
        if col in fused_eval.columns:
            fused_eval[col] = fused_eval[col].apply(_normalize_list_text_case)
        if col in fusion_eval_set.columns:
            fusion_eval_set[col] = fusion_eval_set[col].apply(_normalize_list_text_case)

# text cleanup
for col in shared_columns:
    if col in {"id", "eval_id", "_id", "_eval_cluster_id", "_fusion_sources", "_fusion_confidence"}:
        continue
    if col in list_eval_columns:
        continue
    if fused_eval[col].dtype == object:
        fused_eval[col] = fused_eval[col].apply(_normalize_text_scalar)
    if fusion_eval_set[col].dtype == object:
        fusion_eval_set[col] = fusion_eval_set[col].apply(_normalize_text_scalar)

# numeric coercion
numeric_like_patterns = [
    "score", "rating", "sales", "count", "price", "duration", "year", "number", "total"
]
numeric_columns = []
for col in shared_columns:
    cl = str(col).lower()
    if any(tok in cl for tok in numeric_like_patterns):
        if col not in list_eval_columns and col not in {"id", "eval_id", "_id"}:
            numeric_columns.append(col)
numeric_columns = sorted(set(numeric_columns))
_coerce_numeric_pair(fused_eval, fusion_eval_set, numeric_columns)

# ================================
# 4. REGISTER EVALUATION FUNCTIONS
# ================================
strategy = DataFusionStrategy("games_validation_evaluation")
eval_funcs_summary = {}

def register_eval(column, fn, fn_name, **kwargs):
    strategy.add_evaluation_function(column, fn, **kwargs)
    args = ", ".join(f"{k}={v}" for k, v in kwargs.items()) if kwargs else ""
    eval_funcs_summary[column] = f"{fn_name}({args})" if args else fn_name

candidate_columns = []
for col in shared_columns:
    if col in {"id", "eval_id", "_id", "_eval_cluster_id", "_fusion_sources", "_fusion_confidence"}:
        continue
    if _is_nested_artifact(col):
        continue
    if not _is_meaningful_in_both(fused_eval, fusion_eval_set, col):
        continue
    candidate_columns.append(col)

for col in candidate_columns:
    cl = str(col).lower()

    if col in list_eval_columns:
        register_eval(col, set_equality_match, "set_equality_match")
    elif _looks_like_bool_column(fused_eval[col]) and _looks_like_bool_column(fusion_eval_set[col]):
        register_eval(col, boolean_match, "boolean_match")
    elif col == "releaseYear" or "releaseyear" in cl or (cl.endswith("year") and col not in numeric_columns):
        # keep as strings for year_only_match if possible
        fused_eval[col] = fused_eval[col].astype(str).replace({"<NA>": pd.NA, "nan": pd.NA, "None": pd.NA})
        fusion_eval_set[col] = fusion_eval_set[col].astype(str).replace({"<NA>": pd.NA, "nan": pd.NA, "None": pd.NA})
        register_eval(col, year_only_match, "year_only_match")
    elif "criticscore" in cl or cl == "criticscore":
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=5.0)
    elif "userscore" in cl or cl == "userscore":
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
    elif any(tok in cl for tok in ["sales", "count", "price", "duration", "rating", "score", "number", "total"]):
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
    elif cl in {"esrb", "platform", "publisher", "developer"}:
        register_eval(col, tokenized_match, "tokenized_match", threshold=0.75)
    elif cl in {"name", "title"}:
        register_eval(col, tokenized_match, "tokenized_match", threshold=0.85)
    else:
        register_eval(col, tokenized_match, "tokenized_match", threshold=0.80)

print("EVAL_FUNCTIONS " + " | ".join(f"{k}:{v}" for k, v in sorted(eval_funcs_summary.items())))

# ================================
# 5. RUN EVALUATION
# ================================
evaluator = DataFusionEvaluator(
    strategy,
    debug=True,
    debug_format="json",
    debug_file=os.path.join(EVAL_DIR, "debug_fusion_eval.jsonl"),
    fusion_debug_logs=os.path.join(FUSION_DIR, "debug_fusion_data.jsonl"),
)

evaluation_results = evaluator.evaluate(
    fused_df=fused_eval,
    fused_id_column="eval_id",
    gold_df=fusion_eval_set,
    gold_id_column="id",
)

# ================================
# 6. PRINT STRUCTURED METRICS
# ================================
structured_output = {
    "stage": "validation",
    "fused_path": os.path.join(FUSION_DIR, "fusion_data.csv"),
    "gold_path": "input/datasets/games/testsets/validation_set_fusion.xml",
    "registered_evaluation_functions": eval_funcs_summary,
    "metrics": evaluation_results,
}
print(json.dumps(structured_output, indent=2, default=str))

# ================================
# 7. WRITE RESULTS
# ================================
evaluation_output = os.path.join(EVAL_DIR, "pipeline_evaluation.json")
with open(evaluation_output, "w", encoding="utf-8") as f:
    json.dump(evaluation_results, f, indent=4, default=str)
