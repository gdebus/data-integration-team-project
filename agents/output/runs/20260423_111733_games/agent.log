import re
from collections import Counter
from pathlib import Path
import sys

from PyDI.io import load_xml
from PyDI.fusion import (
    DataFusionStrategy,
    DataFusionEvaluator,
    tokenized_match,
    year_only_match,
    set_equality_match,
    numeric_tolerance_match,
    exact_match,
    boolean_match,
)

try:
    from list_normalization import detect_list_like_columns, normalize_list_like_columns
except ModuleNotFoundError:
    _candidates = [
        Path.cwd(),
        Path.cwd() / "agents",
        Path(__file__).resolve().parent if "__file__" in globals() else Path.cwd(),
        (Path(__file__).resolve().parent.parent if "__file__" in globals() else Path.cwd()),
        (Path(__file__).resolve().parent.parent.parent if "__file__" in globals() else Path.cwd()),
    ]
    for _path in _candidates:
        if (_path / "list_normalization.py").is_file():
            if str(_path.resolve()) not in sys.path:
                sys.path.append(str(_path.resolve()))
    from list_normalization import detect_list_like_columns, normalize_list_like_columns


OUTPUT_DIR = "output/runs/20260423_111733_games"
FUSION_PATH = os.path.join(OUTPUT_DIR, "data_fusion", "fusion_data.csv")
EVAL_DIR = os.path.join(OUTPUT_DIR, "pipeline_evaluation")
EVAL_OUTPUT = os.path.join(EVAL_DIR, "pipeline_evaluation.json")
DEBUG_OUTPUT = os.path.join(EVAL_DIR, "debug_fusion_eval.jsonl")
GOLD_PATH = "input/datasets/games/testsets/validation_set_fusion.xml"

os.makedirs(EVAL_DIR, exist_ok=True)


def _safe_is_missing(value):
    if value is None:
        return True
    try:
        if pd.isna(value):
            return True
    except Exception:
        pass
    if isinstance(value, (list, tuple, set)):
        return len(value) == 0
    return False


def _parse_source_ids(value):
    if value is None:
        return []
    if isinstance(value, (list, tuple, set)):
        return [str(v) for v in value if str(v).strip()]
    text = str(value).strip()
    if not text:
        return []
    for parser in (json.loads, ast.literal_eval):
        try:
            parsed = parser(text)
            if isinstance(parsed, (list, tuple, set)):
                return [str(v) for v in parsed if str(v).strip()]
        except Exception:
            pass
    return []


def _detect_gold_prefix(gold_ids):
    prefixes = [g.split("_", 1)[0] for g in gold_ids if "_" in g]
    if not prefixes:
        return None
    return Counter(prefixes).most_common(1)[0][0] + "_"


def _normalize_list_text_case(value):
    if _safe_is_missing(value):
        return value
    if isinstance(value, (list, tuple, set)):
        return sorted([str(v).strip().lower() for v in value if str(v).strip()])
    text = str(value).strip()
    return text.lower() if text else text


def _normalize_text(value):
    if _safe_is_missing(value):
        return value
    if isinstance(value, (list, tuple, set)):
        return [_normalize_text(v) for v in value]
    text = str(value).strip()
    text = re.sub(r"\s+", " ", text)
    return text


def _meaningful_series(series):
    s = series.dropna()
    if s.empty:
        return s
    s = s.astype(str).str.strip().replace("", pd.NA).dropna()
    return s


def _coerce_numeric_pair(fused_df, gold_df, columns):
    for col in columns:
        if col in fused_df.columns:
            fused_df[col] = pd.to_numeric(fused_df[col], errors="coerce")
            if fused_df[col].dropna().apply(lambda x: float(x).is_integer()).all() if not fused_df[col].dropna().empty else False:
                fused_df[col] = fused_df[col].astype("Int64")
        if col in gold_df.columns:
            gold_df[col] = pd.to_numeric(gold_df[col], errors="coerce")
            if gold_df[col].dropna().apply(lambda x: float(x).is_integer()).all() if not gold_df[col].dropna().empty else False:
                gold_df[col] = gold_df[col].astype("Int64")


def _build_source_index(fused_df):
    source_to_rows = {}
    for idx, row in fused_df.iterrows():
        srcs = _parse_source_ids(row.get("_fusion_sources"))
        for sid in srcs:
            source_to_rows.setdefault(str(sid), []).append(idx)
    return source_to_rows


def build_eval_view(fused_df, gold_df):
    gold_ids = set(gold_df["id"].dropna().astype(str).tolist()) if "id" in gold_df.columns else set()
    gold_prefix = _detect_gold_prefix(gold_ids)
    source_index = _build_source_index(fused_df)

    expanded_rows = []
    used_eval_ids = set()

    for gold_id in gold_df["id"].dropna().astype(str).tolist():
        candidate_indices = source_index.get(gold_id, [])
        if candidate_indices:
            candidate_rows = fused_df.loc[candidate_indices].copy()
            if "_fusion_confidence" in candidate_rows.columns:
                candidate_rows["_fusion_confidence"] = pd.to_numeric(candidate_rows["_fusion_confidence"], errors="coerce").fillna(0.0)
                candidate_rows = candidate_rows.sort_values("_fusion_confidence", ascending=False)
            best_row = candidate_rows.iloc[0].to_dict()
            best_row["eval_id"] = gold_id
            best_row["_eval_cluster_id"] = str(best_row.get("_id", ""))
            expanded_rows.append(best_row)
            used_eval_ids.add(gold_id)

    if not expanded_rows:
        for _, row in fused_df.iterrows():
            row_dict = row.to_dict()
            cluster_id = str(row_dict.get("_id", ""))
            source_ids = _parse_source_ids(row_dict.get("_fusion_sources"))

            candidates = []
            if gold_prefix:
                candidates = [sid for sid in source_ids if sid.startswith(gold_prefix)]
            if not candidates:
                candidates = [sid for sid in source_ids if sid in gold_ids]
            if not candidates and "eval_id" in row_dict and str(row_dict.get("eval_id", "")).strip():
                candidates = [str(row_dict["eval_id"])]
            if not candidates and cluster_id:
                candidates = [cluster_id]

            seen = set()
            for eval_id in candidates:
                if eval_id in seen:
                    continue
                seen.add(eval_id)
                enriched = dict(row_dict)
                enriched["eval_id"] = eval_id
                enriched["_eval_cluster_id"] = cluster_id
                expanded_rows.append(enriched)

    if not expanded_rows:
        fallback = fused_df.copy()
        fallback["eval_id"] = fallback["_id"].astype(str)
        fallback["_eval_cluster_id"] = fallback["_id"].astype(str)
        return fallback

    fused_eval = pd.DataFrame(expanded_rows)

    if "_fusion_confidence" in fused_eval.columns:
        fused_eval["_fusion_confidence"] = pd.to_numeric(fused_eval["_fusion_confidence"], errors="coerce").fillna(0.0)
        fused_eval = fused_eval.sort_values("_fusion_confidence", ascending=False)

    fused_eval = fused_eval.drop_duplicates(subset=["eval_id"], keep="first")
    return fused_eval


fused = pd.read_csv(FUSION_PATH)
gold = load_xml(GOLD_PATH, name="fusion_validation_set", nested_handling="aggregate")

fused_eval = build_eval_view(fused, gold)

list_eval_columns = detect_list_like_columns(
    [fused_eval, gold],
    exclude_columns={"id", "_id", "eval_id", "_eval_cluster_id", "_fusion_confidence"},
)
list_eval_columns = [c for c in list_eval_columns if not str(c).startswith("_")]

if list_eval_columns:
    fused_eval, gold = normalize_list_like_columns([fused_eval, gold], list_eval_columns)
    for col in list_eval_columns:
        if col in fused_eval.columns:
            fused_eval[col] = fused_eval[col].apply(_normalize_list_text_case)
        if col in gold.columns:
            gold[col] = gold[col].apply(_normalize_list_text_case)

shared_columns = sorted((set(fused_eval.columns) & set(gold.columns)) - {"id", "_id", "eval_id", "_eval_cluster_id"})
for col in shared_columns:
    if col not in list_eval_columns:
        if col in fused_eval.columns:
            fused_eval[col] = fused_eval[col].apply(_normalize_text)
        if col in gold.columns:
            gold[col] = gold[col].apply(_normalize_text)

numeric_cols = []
for col in shared_columns:
    col_l = col.lower()
    if any(key in col_l for key in ["score", "rating", "sales", "count", "price", "duration"]):
        numeric_cols.append(col)
_coerce_numeric_pair(fused_eval, gold, numeric_cols)

gold_ids = set(gold["id"].dropna().astype(str).tolist()) if "id" in gold.columns else set()
direct_cov = len(set(fused["_id"].astype(str).tolist()) & gold_ids) if "_id" in fused.columns else 0
eval_id_cov = len(set(fused["eval_id"].astype(str).tolist()) & gold_ids) if "eval_id" in fused.columns else 0
mapped_cov = len(set(fused_eval["eval_id"].astype(str).tolist()) & gold_ids) if "eval_id" in fused_eval.columns else 0

print(json.dumps({
    "stage": "validation",
    "id_alignment": {
        "gold_records": len(gold_ids),
        "direct__id_coverage": direct_cov,
        "pipeline_eval_id_coverage": eval_id_cov,
        "rebuilt_eval_view_coverage": mapped_cov,
    }
}, indent=2))

strategy = DataFusionStrategy("evaluation_strategy")
eval_funcs_summary = {}

def register_eval(column, fn, fn_name, **kwargs):
    strategy.add_evaluation_function(column, fn, **kwargs)
    args = ",".join(f"{k}={v}" for k, v in kwargs.items()) if kwargs else ""
    eval_funcs_summary[column] = f"{fn_name}({args})" if args else fn_name

candidate_columns = []
for col in shared_columns:
    gold_nonempty = _meaningful_series(gold[col]) if col in gold.columns else pd.Series(dtype="object")
    fused_nonempty = _meaningful_series(fused_eval[col]) if col in fused_eval.columns else pd.Series(dtype="object")
    if gold_nonempty.empty or fused_nonempty.empty:
        continue
    candidate_columns.append(col)

for col in candidate_columns:
    col_l = col.lower()

    if col in list_eval_columns:
        register_eval(col, set_equality_match, "set_equality_match")
    elif col in {"releaseYear", "founded"} or "year" in col_l or "date" in col_l:
        fused_eval[col] = fused_eval[col].astype(str)
        gold[col] = gold[col].astype(str)
        register_eval(col, year_only_match, "year_only_match")
    elif any(key in col_l for key in ["userscore", "user_score"]):
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
    elif any(key in col_l for key in ["criticscore", "critic_score"]):
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=5.0)
    elif any(key in col_l for key in ["globalsales", "sales", "count", "duration", "price", "rating", "score"]):
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
    elif any(key in col_l for key in ["is_", "has_", "flag", "active", "available", "enabled"]) or col_l.endswith("boolean"):
        register_eval(col, boolean_match, "boolean_match")
    elif col in {"id", "_id", "eval_id"} or col_l.endswith("code"):
        register_eval(col, exact_match, "exact_match")
    else:
        threshold = 0.85 if col_l in {"name", "title"} else 0.75
        register_eval(col, tokenized_match, "tokenized_match", threshold=threshold)

print("EVAL_FUNCTIONS " + " | ".join(f"{k}:{v}" for k, v in sorted(eval_funcs_summary.items())))

evaluator = DataFusionEvaluator(
    strategy,
    debug=True,
    debug_format="json",
    debug_file=DEBUG_OUTPUT,
)

evaluation_results = evaluator.evaluate(
    fused_df=fused_eval,
    fused_id_column="eval_id",
    expected_df=gold,
    expected_id_column="id",
)

print(json.dumps({
    "stage": "validation",
    "evaluation_metrics": evaluation_results
}, indent=2, default=str))

with open(EVAL_OUTPUT, "w") as f:
    json.dump(evaluation_results, f, indent=4, default=str)
