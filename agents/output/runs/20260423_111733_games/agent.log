11:53:26,149 root INFO RESULT:import pandas as pd
import json
import ast
import os
import re
from pathlib import Path
import sys

from PyDI.io import load_xml
from PyDI.fusion import (
    DataFusionStrategy,
    DataFusionEvaluator,
    tokenized_match,
    year_only_match,
    set_equality_match,
    numeric_tolerance_match,
    exact_match,
    boolean_match,
)

try:
    from list_normalization import detect_list_like_columns, normalize_list_like_columns
except ModuleNotFoundError:
    _candidates = [
        Path.cwd(),
        Path.cwd() / "agents",
        Path(__file__).resolve().parent if "__file__" in globals() else Path.cwd(),
        (Path(__file__).resolve().parent.parent if "__file__" in globals() else Path.cwd()),
        (Path(__file__).resolve().parent.parent.parent if "__file__" in globals() else Path.cwd()),
    ]
    for _path in _candidates:
        if (_path / "list_normalization.py").is_file():
            if str(_path.resolve()) not in sys.path:
                sys.path.append(str(_path.resolve()))
    from list_normalization import detect_list_like_columns, normalize_list_like_columns


OUTPUT_DIR = "output/runs/20260423_111733_games"
FUSION_PATH = os.path.join(OUTPUT_DIR, "data_fusion", "fusion_data.csv")
EVAL_DIR = os.path.join(OUTPUT_DIR, "pipeline_evaluation")
EVAL_OUTPUT = os.path.join(EVAL_DIR, "pipeline_evaluation.json")
DEBUG_OUTPUT = os.path.join(EVAL_DIR, "debug_fusion_eval.jsonl")
GOLD_PATH = "input/datasets/games/testsets/test_set_fusion.xml"

os.makedirs(EVAL_DIR, exist_ok=True)


def _safe_is_missing(value):
    if value is None:
        return True
    try:
        if pd.isna(value):
            return True
    except Exception:
        pass
    if isinstance(value, str) and value.strip() == "":
        return True
    if isinstance(value, (list, tuple, set)) and len(value) == 0:
        return True
    return False


def _parse_sources(value):
    if value is None:
        return []
    if isinstance(value, (list, tuple, set)):
        return [str(v) for v in value if not _safe_is_missing(v)]
    text = str(value).strip()
    if not text:
        return []
    for parser in (ast.literal_eval, json.loads):
        try:
            parsed = parser(text)
            if isinstance(parsed, (list, tuple, set)):
                return [str(v) for v in parsed if not _safe_is_missing(v)]
        except Exception:
            continue
    return []


def _canonicalize_text(value):
    if _safe_is_missing(value):
        return value
    if isinstance(value, (list, tuple, set)):
        return [str(v).strip().lower() for v in value if not _safe_is_missing(v)]
    return str(value).strip()


def _canonicalize_list_text(value):
    if _safe_is_missing(value):
        return value
    if isinstance(value, (list, tuple, set)):
        return [str(v).strip().lower() for v in value if str(v).strip()]
    text = str(value).strip()
    if not text:
        return []
    try:
        parsed = ast.literal_eval(text)
        if isinstance(parsed, (list, tuple, set)):
            return [str(v).strip().lower() for v in parsed if str(v).strip()]
    except Exception:
        pass
    parts = [p.strip().lower() for p in re.split(r"\s*[;,|]\s*", text) if p.strip()]
    return parts if len(parts) > 1 else [text.lower()]


def _meaningful_series(s):
    if s is None:
        return pd.Series(dtype="object")
    def _ok(v):
        if _safe_is_missing(v):
            return False
        if isinstance(v, str):
            return v.strip() != ""
        if isinstance(v, (list, tuple, set)):
            return len([x for x in v if not _safe_is_missing(x) and str(x).strip() != ""]) > 0
        return True
    return s[s.apply(_ok)]


def _coerce_numeric(df, cols):
    for col in cols:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce")
            non_null = df[col].dropna()
            if len(non_null) > 0 and non_null.apply(lambda x: float(x).is_integer()).all():
                df[col] = df[col].astype("Int64")
    return df


def _looks_nested_artifact(col):
    parts = str(col).split("_")
    return len(parts) >= 3 and parts[0] == parts[1] or len(parts) >= 3


def build_eval_view(fused_df, gold_df):
    gold_ids = set(gold_df["id"].dropna().astype(str).tolist()) if "id" in gold_df.columns else set()
    rows = []

    for _, row in fused_df.iterrows():
        row_dict = row.to_dict()
        cluster_id = str(row_dict.get("_id", ""))
        sources = _parse_sources(row_dict.get("_fusion_sources"))

        matched_gold_ids = [sid for sid in sources if sid in gold_ids]

        if matched_gold_ids:
            for gid in matched_gold_ids:
                r = dict(row_dict)
                r["eval_id"] = gid
                r["_eval_cluster_id"] = cluster_id
                rows.append(r)

    if rows:
        fused_eval = pd.DataFrame(rows)
        if "_fusion_confidence" in fused_eval.columns:
            fused_eval["_fusion_confidence"] = pd.to_numeric(fused_eval["_fusion_confidence"], errors="coerce").fillna(0.0)
            fused_eval = fused_eval.sort_values("_fusion_confidence", ascending=False)
        fused_eval = fused_eval.drop_duplicates(subset=["eval_id"], keep="first")
        return fused_eval

    fallback = fused_df.copy()
    if "eval_id" not in fallback.columns:
        fallback["eval_id"] = fallback["_id"].astype(str) if "_id" in fallback.columns else fallback.index.astype(str)
    fallback["_eval_cluster_id"] = fallback.get("_id", fallback["eval_id"]).astype(str)
    return fallback


fused = pd.read_csv(FUSION_PATH)
gold = load_xml(GOLD_PATH, name="fusion_test_set", nested_handling="aggregate")

fused_eval = build_eval_view(fused, gold)

gold_ids = set(gold["id"].dropna().astype(str).tolist()) if "id" in gold.columns else set()
eval_cov = len(set(fused_eval["eval_id"].astype(str).tolist()) & gold_ids) if "eval_id" in fused_eval.columns else 0
id_cov_ratio = (eval_cov / len(gold_ids)) if gold_ids else 0.0

if id_cov_ratio < 0.8:
    fused_eval = build_eval_view(fused.drop(columns=["eval_id"], errors="ignore"), gold)

common_columns = sorted((set(fused_eval.columns) & set(gold.columns)) - {"id", "_id", "eval_id", "_eval_cluster_id"})
list_eval_columns = detect_list_like_columns(
    [fused_eval[["eval_id"] + common_columns] if "eval_id" in fused_eval.columns else fused_eval[common_columns], gold],
    exclude_columns={"id", "_id", "eval_id", "_eval_cluster_id", "_fusion_confidence"},
)
list_eval_columns = [c for c in list_eval_columns if c in common_columns and not c.startswith("_")]

if list_eval_columns:
    fused_eval, gold = normalize_list_like_columns([fused_eval, gold], list_eval_columns)
    for col in list_eval_columns:
        if col in fused_eval.columns:
            fused_eval[col] = fused_eval[col].apply(_canonicalize_list_text)
        if col in gold.columns:
            gold[col] = gold[col].apply(_canonicalize_list_text)

numeric_columns = []
for col in common_columns:
    cl = col.lower()
    if any(k in cl for k in ["score", "rating", "sales", "count", "price", "duration"]):
        numeric_columns.append(col)

fused_eval = _coerce_numeric(fused_eval, numeric_columns)
gold = _coerce_numeric(gold, numeric_columns)

strategy = DataFusionStrategy("evaluation_strategy")
eval_funcs_summary = {}

def register_eval(column, fn, fn_name, **kwargs):
    strategy.add_evaluation_function(column, fn, **kwargs)
    args = ", ".join(f"{k}={v}" for k, v in kwargs.items()) if kwargs else ""
    eval_funcs_summary[column] = f"{fn_name}({args})" if args else fn_name

for col in common_columns:
    if col.startswith("_"):
        continue

    gold_nonempty = _meaningful_series(gold[col]) if col in gold.columns else pd.Series(dtype="object")
    fused_nonempty = _meaningful_series(fused_eval[col]) if col in fused_eval.columns else pd.Series(dtype="object")

    if gold_nonempty.empty or fused_nonempty.empty:
        continue

    col_lower = col.lower()

    if _looks_nested_artifact(col) and col not in list_eval_columns:
        continue

    if col in list_eval_columns:
        register_eval(col, set_equality_match, "set_equality_match")
    elif col_lower in {"id", "code"} or col_lower.endswith("_id"):
        register_eval(col, exact_match, "exact_match")
    elif any(k in col_lower for k in ["releaseyear", "founded", "date", "year"]):
        if col in fused_eval.columns:
            fused_eval[col] = fused_eval[col].astype(str)
        if col in gold.columns:
            gold[col] = gold[col].astype(str)
        register_eval(col, year_only_match, "year_only_match")
    elif any(k in col_lower for k in ["criticscore"]):
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=5.0)
    elif any(k in col_lower for k in ["userscore", "rating"]):
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
    elif any(k in col_lower for k in ["sales", "price", "duration", "count"]):
        register_eval(col, numeric_tolerance_match, "numeric_tolerance_match", tolerance=1.0)
    elif fused_eval[col].dropna().map(lambda x: isinstance(x, bool)).all() and gold[col].dropna().map(lambda x: isinstance(x, bool)).all():
        register_eval(col, boolean_match, "boolean_match")
    else:
        register_eval(col, tokenized_match, "tokenized_match", threshold=0.85)

print("[ID ALIGNMENT]", json.dumps({
    "gold_records": len(gold_ids),
    "mapped_eval_ids": int(eval_cov),
    "coverage_ratio": round(id_cov_ratio, 4),
}, indent=2))

print("[EVAL FUNCTIONS]", "; ".join(f"{k}={v}" for k, v in sorted(eval_funcs_summary.items())))

evaluator = DataFusionEvaluator(
    strategy,
    debug=True,
    debug_format="json",
    debug_file=DEBUG_OUTPUT,
)

evaluation_results = evaluator.evaluate(
    fused_df=fused_eval,
    fused_id_column="eval_id" if "eval_id" in fused_eval.columns else "_id",
    gold_df=gold,
    gold_id_column="id",
)

print("[EVALUATION RESULTS]")
print(json.dumps(evaluation_results, indent=2, default=str))

with open(EVAL_OUTPUT, "w") as f:
    json.dump(evaluation_results, f, indent=4, default=str)
