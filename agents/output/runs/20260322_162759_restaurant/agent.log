"\n          },\n          "categories": {\n            "strip_whitespace": true\n          }\n        },\n        "list_columns_applied": [\n          "categories"\n        ]\n      },\n      "uber_eats_small": {\n        "input_path": "output/runs/20260322_162759_restaurant/schema-matching/uber_eats_small.parquet",\n        "output_path": "output/runs/20260322_162759_restaurant/normalization/attempt_1/uber_eats_small.csv",\n        "row_count": 10000,\n        "id_column": "id",\n        "spec_applied": {\n          "house_number": {\n            "output_type": "int",\n            "on_failure": "keep"\n          },\n          "postal_code": {\n            "output_type": "int",\n            "on_failure": "keep"\n          },\n          "country": {\n            "strip_whitespace": true,\n            "country_format": "alpha_2",\n            "on_failure": "keep"\n          },\n          "categories": {\n            "strip_whitespace": true\n          },\n          "rating_count": {\n            "output_type": "float",\n            "on_failure": "keep"\n          }\n        },\n        "list_columns_applied": [\n          "categories"\n        ]\n      },\n      "yelp_small": {\n        "input_path": "output/runs/20260322_162759_restaurant/schema-matching/yelp_small.parquet",\n        "output_path": "output/runs/20260322_162759_restaurant/normalization/attempt_1/yelp_small.csv",\n        "row_count": 10000,\n        "id_column": "id",\n        "spec_applied": {\n          "phone_raw": {\n            "output_type": "int",\n            "on_failure": "keep"\n          },\n          "phone_e164": {\n            "output_type": "int",\n            "on_failure": "keep",\n            "phone_format": "e164"\n          },\n          "house_number": {\n            "output_type": "keep",\n            "strip_whitespace": true,\n            "on_failure": "keep"\n          },\n          "postal_code": {\n            "output_type": "int",\n            "on_failure": "keep"\n          },\n          "country": {\n            "strip_whitespace": true,\n            "country_format": "alpha_2",\n            "on_failure": "keep"\n          },\n          "categories": {\n            "strip_whitespace": true\n          },\n          "rating_count": {\n            "output_type": "float",\n            "on_failure": "keep"\n          }\n        },\n        "list_columns_applied": [\n          "categories"\n        ]\n      }\n    },\n    "warnings": [],\n    "acceptance_gate": {\n      "requested": false,\n      "request": {},\n      "pending": {}\n    },\n    "reverted_to_original": false,\n    "created_at": "2026-03-22T16:28:13.130954"\n  }\n}\n\n        IMPORTANT NORMALIZATION RULES:\n- Validation set style drives normalization. Do NOT blindly lowercase text globally.\n- Keep IDs unchanged (case and content must be preserved exactly).\n- If you convert a column to list-like values, any comparator on that column MUST set list_strategy.\n- If StringComparator is used on potentially list-like columns (artist/name/tracks/etc.), set list_strategy explicitly.\n- Prefer normalization that aligns fused output with validation representation, not a random canonical style.\n- You MAY apply targeted inline normalization in the pipeline code (e.g., str.strip(), format conversion) when it directly addresses mismatch patterns visible in the probe data. This is preferred over waiting for a separate normalization pass when the fix is simple and attribute-specific.\n\nLIST HANDLING RULES (CRITICAL):\n- After list normalization, columns like tracks_track_name, tracks_track_position, tracks_track_duration contain actual Python lists (e.g., ["track1", "track2"]).\n- NEVER apply string cleaning operations (strip, lower, isin, notna, etc.) to list-valued columns. These operations crash with "truth value of an array is ambiguous".\n- NEVER call pd.isna(x) or pd.notna(x) directly on a value that might be a list. Use isinstance(x, (list, tuple, set)) check first, or use a safe wrapper.\n- NEVER include list-valued columns in your string_columns cleaning loop. Only clean scalar string columns.\n- NEVER pass DataFrames with list-valued cells directly to EmbeddingBlocker. Flatten list columns to strings first.\n- When writing a lower_strip or preprocess function, handle list inputs: `if isinstance(x, (list, tuple, set)): return " ".join(str(v).lower().strip() for v in x if pd.notna(v))`\n- Recommended list_strategy values per comparator type:\n  * StringComparator: "best_match", "set_jaccard", "set_overlap" (avoid "concatenate" — it merges all elements into one string, producing poor match quality on real lists)\n  * NumericComparator: "average" (default), "best_match", "range_overlap", "set_jaccard"\n  * DateComparator: "closest_dates" (default), "range_overlap", "average_dates", "latest_dates", "earliest_dates"\n- When values are delimited strings (e.g., "pop; rock; jazz"), use union(separator="; ") or intersection(separator="; ") as the fuser to properly split before merging.\n- For list-like fields where source quality varies, use `favour_sources(source_preferences=[...])` or `prefer_higher_trust(trust_map={...})` rather than blind union/intersection.\n- `intersection_k_sources(k=2)` is useful when 2+ source agreement signals correctness.\n- Ensure list normalization is consistent ACROSS sources before fusion (same delimiter, same casing, same element format).\n        \n\n        5. **BLOCKING CONFIGURATION** (pre-computed optimal blocking strategies):\n        This configuration was determined by a blocking evaluation agent. Use these settings\n        for your blocking step in the pipeline:\n        {\n  "blocking_strategies": {\n    "kaggle_small_uber_eats_small": {\n      "strategy": "semantic_similarity",\n      "columns": [\n        "name_norm",\n        "city",\n        "state"\n      ],\n      "params": {\n        "top_k": 20\n      },\n      "pair_completeness": 1.0,\n      "num_candidates": 199719,\n      "is_acceptable": true\n    },\n    "kaggle_small_yelp_small": {\n      "strategy": "exact_match_multi",\n      "columns": [\n        "phone_e164",\n        "postal_code"\n      ],\n      "params": {},\n      "pair_completeness": 1.0,\n      "num_candidates": 179,\n      "is_acceptable": true\n    },\n    "uber_eats_small_yelp_small": {\n      "strategy": "semantic_similarity",\n      "columns": [\n        "name_norm",\n        "street",\n        "city"\n      ],\n      "params": {\n        "top_k": 20\n      },\n      "pair_completeness": 1.0,\n      "num_candidates": 199972,\n      "is_acceptable": true\n    }\n  },\n  "id_columns": {\n    "kaggle_small": "id",\n    "uber_eats_small": "id",\n    "yelp_small": "id"\n  }\n}\n\n        IMPORTANT: Use the id_columns and blocking_strategies from this config:\n        - Use the correct id_column for each dataset as specified\n        - Use the recommended strategy (exact_match_single/multi or semantic_similarity)\n        - Use the recommended columns for blocking\n        - Strategy to blocker mapping:\n          * exact_match_single / exact_match_multi -> StandardBlocker (exact match on columns)\n          * token_blocking / ngram_blocking -> TokenBlocker (token or n-gram blocking)\n          * sorted_neighbourhood -> SortedNeighbourhoodBlocker (window)\n          * semantic_similarity -> EmbeddingBlocker (top_k)\n        - Blocker API contract in this environment:\n          * materialize candidate pairs with `blocker.materialize()`\n          * do NOT call `.block()` on `EmbeddingBlocker`\n          * pass the materialized candidate DataFrame into `RuleBasedMatcher.match(..., candidates=...)`\n        - Correspondence artifact contract (mandatory):\n          * for each expected pair ["kaggle_small_uber_eats_small", "kaggle_small_yelp_small", "uber_eats_small_yelp_small"]\n          * save exactly one CSV file to `output/runs/20260322_162759_restaurant/correspondences/correspondences_<left>_<right>.csv`\n          * each file must contain PyDI fusion-ready columns `id1` and `id2` (optional extra columns like `score` are allowed)\n          * do NOT invent alternate filename schemes\n          * do NOT rely on reloading or renaming correspondences later to make them usable\n          * fail fast if an expected pair\'s correspondence DataFrame is empty before fusion\n        \n\n        6. **MATCHING CONFIGURATION** (pre-computed comparator settings):\n        This configuration was determined by a matching evaluation agent. Use these settings\n        for your RuleBasedMatcher step in the pipeline:\n        {\n  "id_columns": {\n    "kaggle_small": "id",\n    "uber_eats_small": "id",\n    "yelp_small": "id"\n  },\n  "matching_strategies": {\n    "kaggle_small_uber_eats_small": {\n      "comparators": [\n        {\n          "type": "string",\n          "column": "name_norm",\n          "similarity_function": "cosine",\n          "preprocess": "lower_strip",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "string",\n          "column": "street",\n          "similarity_function": "jaro_winkler",\n          "preprocess": "lower_strip",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "string",\n          "column": "city",\n          "similarity_function": "jaro_winkler",\n          "preprocess": "lower_strip",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "string",\n          "column": "state",\n          "similarity_function": "jaro_winkler",\n          "preprocess": "lower_strip",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "numeric",\n          "column": "latitude",\n          "max_difference": 0.01\n        },\n        {\n          "type": "numeric",\n          "column": "longitude",\n          "max_difference": 0.01\n        },\n        {\n          "type": "string",\n          "column": "categories",\n          "similarity_function": "jaccard",\n          "preprocess": "lower_strip",\n          "list_strategy": "set_jaccard"\n        }\n      ],\n      "weights": [\n        0.35,\n        0.12,\n        0.08,\n        0.05,\n        0.16,\n        0.16,\n        0.08\n      ],\n      "threshold": 0.75,\n      "f1": 0.8947368421052632\n    },\n    "kaggle_small_yelp_small": {\n      "comparators": [\n        {\n          "type": "string",\n          "column": "phone_e164",\n          "similarity_function": "jaro_winkler",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "string",\n          "column": "name_norm",\n          "similarity_function": "cosine",\n          "preprocess": "lower_strip",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "string",\n          "column": "postal_code",\n          "similarity_function": "jaro_winkler",\n          "preprocess": "strip",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "string",\n          "column": "city",\n          "similarity_function": "jaro_winkler",\n          "preprocess": "lower_strip",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "numeric",\n          "column": "latitude",\n          "max_difference": 0.002\n        },\n        {\n          "type": "numeric",\n          "column": "longitude",\n          "max_difference": 0.002\n        },\n        {\n          "type": "string",\n          "column": "categories",\n          "similarity_function": "jaccard",\n          "preprocess": "lower_strip",\n          "list_strategy": "set_jaccard"\n        }\n      ],\n      "weights": [\n        0.2,\n        0.25,\n        0.15,\n        0.1,\n        0.1,\n        0.1,\n        0.1\n      ],\n      "threshold": 0.75,\n      "f1": 0.983050847457627\n    },\n    "uber_eats_small_yelp_small": {\n      "comparators": [\n        {\n          "type": "string",\n          "column": "name_norm",\n          "similarity_function": "jaro_winkler",\n          "preprocess": "lower_strip",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "string",\n          "column": "street",\n          "similarity_function": "jaro_winkler",\n          "preprocess": "lower_strip",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "string",\n          "column": "city",\n          "similarity_function": "jaro_winkler",\n          "preprocess": "lower_strip",\n          "list_strategy": "concatenate"\n        },\n        {\n          "type": "numeric",\n          "column": "latitude",\n          "max_difference": 0.002\n        },\n        {\n          "type": "numeric",\n          "column": "longitude",\n          "max_difference": 0.002\n        },\n        {\n          "type": "string",\n          "column": "categories",\n          "similarity_function": "jaccard",\n          "preprocess": "lower_strip",\n          "list_strategy": "set_jaccard"\n        }\n      ],\n      "weights": [\n        0.28,\n        0.16,\n        0.12,\n        0.16,\n        0.16,\n        0.12\n      ],\n      "threshold": 0.72,\n      "f1": 0.9302325581395349\n    }\n  }\n}\n\n        IMPORTANT: Use the matching_strategies from this config:\n        - Build comparators (StringComparator/NumericComparator/DateComparator) for each dataset pair\n        - Use the specified weights and threshold.\n        - For each pair in `matching_strategies`, you **MUST** define a\n            variable named `threshold_[original_pair_key]` (e.g.,\n            `threshold_discogs_lastfm = 0.7`) with the corresponding threshold value.\n            Ensure your RuleBasedMatcher instances use these variables for their\n            `threshold` parameter.\n        - preprocess mapping: "lower" -> str.lower, "strip" -> str.strip, "lower_strip" -> lambda x: str(x).lower().strip()\n\n        - For NumericComparator on potentially list-valued columns (e.g., duration fields), set `list_strategy` explicitly (recommended: "average") or safely scalarize before matching.\n        - For DateComparator on multi-date columns, set `list_strategy` explicitly (recommended: "closest_dates").\n        \n\n        Your task is to **create a similar integration pipeline** so that it works with\n        the datasets provided. Output should only consist of the relevant Python code\n        for the integration pipeline.\n\n        OUTPUT PATHS (MANDATORY — use these exact paths, do NOT hardcode \'output/\'):\n        - Correspondences: save to `{correspondences_dir}/correspondences_<left>_<right>.csv`\n        - Fusion data: save to `{output_dir}/data_fusion/fusion_data.csv`\n        - Fusion debug: save to `{output_dir}/data_fusion/debug_fusion_data.jsonl`\n        - Create directories with `os.makedirs(..., exist_ok=True)` before writing.\n\n        FUSION RULES (MANDATORY):\n        - The output must always be the full fused dataset. Run `DataFusionEngine.run(..., include_singletons=True)`.\n        - Use PyDI built-in fusers as the default and strongly preferred choice.\n        - NEVER write custom fusion resolvers, lambda resolvers, or helper functions for fusion. Use ONLY PyDI built-in resolvers.\n        - The built-in resolvers cover ALL use cases: voting, longest_string, most_complete, median, average, earliest, most_recent, union, intersection, intersection_k_sources, prefer_higher_trust, favour_sources.\n        - For list-valued columns: use union(separator="; ") or intersection_k_sources(k=2, separator="; ").\n        - For trust-based selection: use prefer_higher_trust(trust_map={...}) or favour_sources(source_preferences=[...]).\n        - Do NOT manually post-process or overwrite `_fusion_confidence` outside the normal resolver return contract.\n        - ML MATCHER WARNING: When using MLBasedMatcher, clusters often contain MULTIPLE records per source dataset\n          (e.g. 5 discogs records + 3 lastfm records + 2 musicbrainz records in one cluster).\n          In this situation, `voting` is BIASED toward whichever source contributed more records to the cluster,\n          regardless of data quality. NEVER use `voting` as a primary resolver with ML matching.\n          Instead use `prefer_higher_trust` or `favour_sources` to select the most authoritative source,\n          or use `shortest_string`/`longest_string` which pick by value characteristics rather than majority.\n        - Choose fusion strategies based on EVIDENCE, not just data type:\n          * If one source is clearly more complete/accurate for an attribute (visible in input data samples or source agreement), use `prefer_higher_trust` with appropriate trust_map\n          * If sources have roughly equal quality, use `voting` for strings, `median` for numbers\n          * `longest_string` is excellent for text attributes where one source has more complete/detailed values (e.g., full label names vs abbreviations, complete genre lists vs partial). Consider it as a strong default for metadata text fields.\n          * `most_complete` is similar to longest_string but also considers non-null coverage. Good for attributes with many nulls in some sources.\n          * For numeric aggregates (e.g., total duration, page count): consider `maximum` when the target represents a "full" measurement — the maximum value often reflects the most complete source. Use `median` only when averaging across sources makes semantic sense.\n          * If mismatch samples show format differences (not value differences), fix normalization before fusion rather than switching fusers\n          * For list-like fields: use `intersection(separator=...)` or `intersection_k_sources(k=2)` when sources are noisy; use `union(separator=...)` only when both sources are clean and complementary\n          * For list-like fields where one source is clearly better, use `favour_sources(source_preferences=[...])` instead of union/intersection\n          * For dates: use `prefer_higher_trust` with data-driven trust ordering. Avoid `earliest` as a blanket default — it picks the oldest date regardless of correctness. Only use `most_recent` when diagnostics explicitly justify recency semantics\n          * IMPORTANT: Review the INPUT DATA SAMPLES section to see actual values from each source before choosing trust levels\n        - For trust-based fusion, pass trust configuration only at registration time:\n          `strategy.add_attribute_fuser(attr, prefer_higher_trust, trust_map=trust_map)`\n        - Do NOT wrap `prefer_higher_trust` in another function that hardcodes `trust_map` again.\n        - Avoid `most_recent` as a default temporal resolver unless diagnostics explicitly show recency is the correct target semantics.\n        - Avoid `union` for list-like fields when cluster purity is weak or list-format inconsistencies are present.\n\n        {PIPELINE_MATCHING_SAFETY_RULES_BLOCK}\n        \n            8. Evaluation reasoning from prior pipeline run:\n            {\n  "action": "decide",\n  "diagnosis": "The dominant failure is not normalization or matching; it is fusion/output ID handling caused by keeping singleton records and extracting eval_id from arbitrary source prefixes. Matching quality is already high (F1 0.89-0.98, correspondence files non-empty, cluster analysis clean), yet 94.2% of errors are missing_fused_value and many mismatch samples have fused_id=\'nan\'. This means the evaluator cannot align most validation rows to the correct fused entity. Additionally, several low-accuracy attributes use suboptimal fusion resolvers/trust: the current trust map prefers yelp_small over better sources for source/name/address_line1, and map_url/source/name/rating/address_line1 evidence shows different best resolvers. So the next fix is pipeline adaptation: correct post-clustering/output identity selection and update attribute fusers/trust, while preserving the 24 already-good attributes.",\n  "next_node": "pipeline_adaption",\n  "reasoning": "Routing to matching/blocking is not justified because correspondences exist for all pairs, blocking probes found no recall issues, and pairwise F1 is strong. Routing to normalization is also not primary because the main error class is missing fused output, not systematic format mismatch; the one visible name format issue is minor compared with the alignment problem. pipeline_adaption is the correct frozen-stage lever because it can change post-clustering and fusion strategy. The post-clustering recommendation is already MaximumBipartiteMatching, and current include_singletons/eval-id behavior is likely emitting many singleton fused rows whose chosen eval_id does not correspond to the validation IDs, producing blank fused matches. On top of that, resolver evidence from source-vs-validation comparison is strong: uber_eats_small is best for source/name/address_line1, yelp_small is best for rating and often for map_url, so current prefer_higher_trust(yelp>kaggle>uber) is actively wrong for several attributes. Protected attributes above 85% should be left untouched.",\n  "ceiling_assessment": "With current source data and frozen matching/import stages, overall accuracy can likely move substantially upward from 0.265 toward roughly 0.70-0.82 if post-clustering/ID alignment is corrected and the worst attribute fusers are fixed. The stated structural ceiling is 82.5%; the current gap is mostly operational rather than inherent because 94% missing_fused errors are recoverable. Remaining gap will come from structurally limited attributes like heterogeneous categories/list content and occasional source disagreements.",\n  "recommendations": [\n    {\n      "attribute": "post_clustering / fused entity identity",\n      "issue": "Most evaluation misses are caused by fused entities not aligning to validation IDs (fused_id nan or wrong source-prefixed ID), despite good correspondences. Current output keeps singletons and eval_id is derived by taking the first matching prefix from _fusion_sources, which can miss the validation anchor record for many rows.",\n      "fix": "Enable/keep post-clustering as MaximumBipartiteMatching and adapt fusion output identity logic so fused records consistently retain source-specific IDs needed by validation (prefer existing kaggle380k_id / uber_eats_id / yelp_id columns or deterministic source-ID retention per cluster rather than arbitrary first prefix from _fusion_sources). If configurable in the adaptation stage, disable harmful singleton-driven evaluation rows or ensure singleton records still expose the proper source-prefixed IDs.",\n      "resolver_reasoning": "Evidence points to alignment, not value synthesis: matching is high quality, correspondence files are present, cluster ambiguity is low, and 94.2% of mismatches are missing_fused. No attribute-level resolver can fix rows that never align to validation. MaximumBipartiteMatching is already recommended by cluster analysis and should reduce fragmented/duplicated clusters. Alternatives like changing blocking or thresholds are worse because they target pair generation, not the observed evaluator join failure.",\n      "class": "improvable",\n      "expected_impact": 0.35\n    },\n    {\n      "attribute": "source",\n      "issue": "Current prefer_higher_trust uses yelp_small > kaggle_small > uber_eats_small, but validation expects uber_eats_small\'s source label most often when sources disagree. This directly causes source=\'yelp\' when expected=\'kaggle_380k\' or \'uber_eats\' in samples.",\n      "fix": "Change source fuser to prefer_higher_trust with trust_map={\'uber_eats_small\':3,\'yelp_small\':2,\'kaggle_small\':1}.",\n      "resolver_reasoning": "Source-vs-validation comparison shows exact match rates: uber_eats_small 100%, yelp_small 62%, kaggle_small 30%. This is a textbook prefer_higher_trust case with a clear best source. voting would fail whenever sources disagree and there is no majority; favour_sources would also work but prefer_higher_trust is simpler and equivalent given the clear ranking.",\n      "class": "improvable",\n      "expected_impact": 0.04\n    },\n    {\n      "attribute": "name",\n      "issue": "Current name resolver prefers yelp_small via trust, but validation names are most often the shortest/canonical version, with uber_eats_small exact at 100%. Current configuration causes truncation/expansion mismatches like missing venue suffixes or extra noise.",\n      "fix": "Change name fuser to shortest_string.",\n      "resolver_reasoning": "Measured exact rates: uber_eats_small 100%, kaggle_small 90%, yelp_small 81%, and the probe explicitly recommends shortest_string. Validation examples use concise canonical names (\'Cornish Pasty Co\', \'Longitude 118\', \'For The Win\'). shortest_string best approximates this across sources without hard-coding a trust map. longest_string would worsen cases like \'Pier 88 Boiling Seafood & Bar Avondale\' only if another source adds extra context inconsistently; prefer_higher_trust is worse because yelp is not the best source for names.",\n      "class": "improvable",\n      "expected_impact": 0.04\n    },\n    {\n      "attribute": "address_line1",\n      "issue": "Current most_complete can pick a longer but non-target variant, while validation most often matches uber_eats_small exactly and yelp_small nearly as well.",\n      "fix": "Change address_line1 fuser to voting; if voting underperforms in implementation, fallback to prefer_higher_trust with trust_map={\'uber_eats_small\':3,\'yelp_small\':2,\'kaggle_small\':1}.",\n      "resolver_reasoning": "Evidence: uber_eats_small 100% exact, yelp_small 94%, kaggle_small 75%; probe recommendation is voting. Because top two sources often agree on the canonical street line, voting should recover the expected value without always forcing a single source. most_complete is worse when one source includes extra tokens not present in validation. prefer_higher_trust(uber-first) is a strong fallback but slightly less robust when uber is null and yelp agrees with kaggle.",\n      "class": "improvable",\n      "expected_impact": 0.03\n    },\n    {\n      "attribute": "rating",\n      "issue": "Current median can synthesize values not present in validation or drift from the better source. Validation is closer to source values, especially yelp_small.",\n      "fix": "Change rating fuser to voting; if PyDI voting on numeric values is unsuitable, use prefer_higher_trust with trust_map={\'yelp_small\':3,\'kaggle_small\':2,\'uber_eats_small\':1} only if uber ratings are largely absent.",\n      "resolver_reasoning": "Source comparison: yelp_small 62% exact vs kaggle_small 50%, and probe recommends voting. Validation examples show discrete source ratings like 4.3, 4.2, 4.6, not necessarily an aggregate statistic. median is appropriate for noisy measurements, but here exact source values matter more. voting preserves commonly shared values; prefer_higher_trust(yelp-first) is second-best if numeric voting behaves poorly.",\n      "class": "improvable",\n      "expected_impact": 0.03\n    },\n    {\n      "attribute": "map_url",\n      "issue": "Current prefer_higher_trust always favors yelp_small, but validation alternates between yelp URLs and google maps URLs from kaggle_small. Samples show wrong yelp chosen when expected is google maps.",\n      "fix": "Change map_url fuser to voting; if ties are common, prefer_higher_trust with trust_map={\'yelp_small\':3,\'kaggle_small\':2,\'uber_eats_small\':1}.",\n      "resolver_reasoning": "Comparison shows yelp_small 62% exact, kaggle_small 50% exact, and probe recommends voting(yelp > kaggle). This indicates no single source dominates enough to justify current fixed trust selection. voting is better when exact expected URL depends on agreement pattern; always preferring yelp causes the observed google-vs-yelp mismatches. longest/shortest/most_complete are not semantically meaningful for URLs.",\n      "class": "improvable",\n      "expected_impact": 0.03\n    }\n  ]\n}\n            \n            8b. COMPACT NEXT-PASS SUMMARY:\n            {\n  "root_cause": "The dominant failure is not normalization or matching; it is fusion/output ID handling caused by keeping singleton records and extracting eval_id from arbitrary source prefixes. Matching quality is already high (F1 0.89-0.98, correspondence files non-empty, cluster analysis clean), yet 94.2% of errors are missing_fused_value and many mismatch samples have fused_id=\'nan\'. This means the evaluator cannot align most validation rows to the correct fused entity. Additionally, several low-accuracy attributes use suboptimal fusion resolvers/trust: the current trust map prefers yelp_small over better sources for source/name/address_line1, and map_url/source/name/rating/address_line1 evidence shows different best resolvers. So the next fix is pipeline adaptation: correct post-clustering/output identity selection and update attribute fusers/trust, while preserving the 24 already-good attributes.",\n  "next_step": "Routing to matching/blocking is not justified because correspondences exist for all pairs, blocking probes found no recall issues, and pairwise F1 is strong. Routing to normalization is also not primary because the main error class is missing fused output, not systematic format mismatch; the one visible name format issue is minor compared with the alignment problem. pipeline_adaption is the correct frozen-stage lever because it can change post-clustering and fusion strategy. The post-clustering recommendation is already MaximumBipartiteMatching, and current include_singletons/eval-id behavior is likely emitting many singleton fused rows whose chosen eval_id does not correspond to the validation IDs, producing blank fused matches. On top of that, resolver evidence from source-vs-validation comparison is strong: uber_eats_small is best for source/name/address_line1, yelp_small is best for rating and often for map_url, so current prefer_higher_trust(yelp>kaggle>uber) is actively wrong for several attributes. Protected attributes above 85% should be left untouched.",\n  "takeaway": "The dominant failure is not normalization or matching; it is fusion/output ID handling caused by keeping singleton records and extracting eval_id from arbitrary source prefixes. Matching quality is already high (F1 0.89-0.98, correspondence files non-empty, cluster analysis clean), yet 94.2% of errors are missing_fused_value and many mismatch samples have fused_id=\'nan\'. This means the evaluator cannot align most validation rows to the correct fused entity. Additionally, several low-accuracy attributes use suboptimal fusion resolvers/trust: the current trust map prefers yelp_small over better sources for source/name/address_line1, and map_url/source/name/rating/address_line1 evidence shows different best resolvers. So the next fix is pipeline adaptation: correct post-clustering/output identity selection and update attribute fusers/trust, while preserving the 24 already-good attributes.",\n  "recommendations": [\n    {\n      "attribute": "post_clustering / fused entity identity",\n      "issue": "Most evaluation misses are caused by fused entities not aligning to validation IDs (fused_id nan or wrong source-prefixed ID), despite good correspondences. Current output keeps singletons and eval_id is derived by taking the first matching prefix from _fusion_sources, which can miss the validation anchor record for many rows.",\n      "fix": "Enable/keep post-clustering as MaximumBipartiteMatching and adapt fusion output identity logic so fused records consistently retain source-specific IDs needed by validation (prefer existing kaggle380k_id / uber_eats_id / yelp_id columns or deterministic source-ID retention per cluster rather than arbitrary first prefix from _fusion_sources). If configurable in the adaptation stage, disable harmful singleton-driven evaluation rows or ensure singleton records still expose the proper source-prefixed IDs.",\n      "resolver_reasoning": "Evidence points to alignment, not value synthesis: matching is high quality, correspondence files are present, cluster ambiguity is low, and 94.2% of mismatches are missing_fused. No attribute-level resolver can fix rows that never align to validation. MaximumBipartiteMatching is already recommended by cluster analysis and should reduce fragmented/duplicated clusters. Alternatives like changing blocking or thresholds are worse because they target pair generation, not the observed evaluator join failure.",\n      "class": "improvable",\n      "expected_impact": 0.35\n    },\n    {\n      "attribute": "source",\n      "issue": "Current prefer_higher_trust uses yelp_small > kaggle_small > uber_eats_small, but validation expects uber_eats_small\'s source label most often when sources disagree. This directly causes source=\'yelp\' when expected=\'kaggle_380k\' or \'uber_eats\' in samples.",\n      "fix": "Change source fuser to prefer_higher_trust with trust_map={\'uber_eats_small\':3,\'yelp_small\':2,\'kaggle_small\':1}.",\n      "resolver_reasoning": "Source-vs-validation comparison shows exact match rates: uber_eats_small 100%, yelp_small 62%, kaggle_small 30%. This is a textbook prefer_higher_trust case with a clear best source. voting would fail whenever sources disagree and there is no majority; favour_sources would also work but prefer_higher_trust is simpler and equivalent given the clear ranking.",\n      "class": "improvable",\n      "expected_impact": 0.04\n    },\n    {\n      "attribute": "name",\n      "issue": "Current name resolver prefers yelp_small via trust, but validation names are most often the shortest/canonical version, with uber_eats_small exact at 100%. Current configuration causes truncation/expansion mismatches like missing venue suffixes or extra noise.",\n      "fix": "Change name fuser to shortest_string.",\n      "resolver_reasoning": "Measured exact rates: uber_eats_small 100%, kaggle_small 90%, yelp_small 81%, and the probe explicitly recommends shortest_string. Validation examples use concise canonical names (\'Cornish Pasty Co\', \'Longitude 118\', \'For The Win\'). shortest_string best approximates this across sources without hard-coding a trust map. longest_string would worsen cases like \'Pier 88 Boiling Seafood & Bar Avondale\' only if another source adds extra context inconsistently; prefer_higher_trust is worse because yelp is not the best source for names.",\n      "class": "improvable",\n      "expected_impact": 0.04\n    },\n    {\n      "attribute": "address_line1",\n      "issue": "Current most_complete can pick a longer but non-target variant, while validation most often matches uber_eats_small exactly and yelp_small nearly as well.",\n      "fix": "Change address_line1 fuser to voting; if voting underperforms in implementation, fallback to prefer_higher_trust with trust_map={\'uber_eats_small\':3,\'yelp_small\':2,\'kaggle_small\':1}.",\n      "resolver_reasoning": "Evidence: uber_eats_small 100% exact, yelp_small 94%, kaggle_small 75%; probe recommendation is voting. Because top two sources often agree on the canonical street line, voting should recover the expected value without always forcing a single source. most_complete is worse when one source includes extra tokens not present in validation. prefer_higher_trust(uber-first) is a strong fallback but slightly less robust when uber is null and yelp agrees with kaggle.",\n      "class": "improvable",\n      "expected_impact": 0.03\n    },\n    {\n      "attribute": "rating",\n      "issue": "Current median can synthesize values not present in validation or drift from the better source. Validation is closer to source values, especially yelp_small.",\n      "fix": "Change rating fuser to voting; if PyDI voting on numeric values is unsuitable, use prefer_higher_trust with trust_map={\'yelp_small\':3,\'kaggle_small\':2,\'uber_eats_small\':1} only if uber ratings are largely absent.",\n      "resolver_reasoning": "Source comparison: yelp_small 62% exact vs kaggle_small 50%, and probe recommends voting. Validation examples show discrete source ratings like 4.3, 4.2, 4.6, not necessarily an aggregate statistic. median is appropriate for noisy measurements, but here exact source values matter more. voting preserves commonly shared values; prefer_higher_trust(yelp-first) is second-best if numeric voting behaves poorly.",\n      "class": "improvable",\n      "expected_impact": 0.03\n    },\n    {\n      "attribute": "map_url",\n      "issue": "Current prefer_higher_trust always favors yelp_small, but validation alternates between yelp URLs and google maps URLs from kaggle_small. Samples show wrong yelp chosen when expected is google maps.",\n      "fix": "Change map_url fuser to voting; if ties are common, prefer_higher_trust with trust_map={\'yelp_small\':3,\'kaggle_small\':2,\'uber_eats_small\':1}.",\n      "resolver_reasoning": "Comparison shows yelp_small 62% exact, kaggle_small 50% exact, and probe recommends voting(yelp > kaggle). This indicates no single source dominates enough to justify current fixed trust selection. voting is better when exact expected URL depends on agreement pattern; always preferring yelp causes the observed google-vs-yelp mismatches. longest/shortest/most_complete are not semantically meaningful for URLs.",\n      "class": "improvable",\n      "expected_impact": 0.03\n    }\n  ],\n  "next_node": "pipeline_adaption",\n  "ceiling_assessment": "With current source data and frozen matching/import stages, overall accuracy can likely move substantially upward from 0.265 toward roughly 0.70-0.82 if post-clustering/ID alignment is corrected and the worst attribute fusers are fixed. The stated structural ceiling is 82.5%; the current gap is mostly operational rather than inherent because 94% missing_fused errors are recoverable. Remaining gap will come from structurally limited attributes like heterogeneous categories/list content and occasional source disagreements."\n}\n\n            Treat this as the highest-signal summary of what went wrong and what to try next.\n            \n            9. AUTO DIAGNOSTICS FROM THE LAST EXECUTION (summarized):\n            ID alignment: direct=30.0%, mapped=100.0%\n  ⚠ Low direct ID coverage — fused entities may use different ID format than evaluation set\nTop mismatch reasons:\n  - missing_fused_value: 94.2%\n  - mismatch: 5.8%\n\n            You MUST react to these diagnostics:\n            - Always set `include_singletons=True`. The goal is the full fused dataset, never matched-only output.\n            - Preserve source IDs for evaluation alignment when mapped ID coverage is low or missing_fused_value is high.\n            - If list-attribute accuracy is very low, do not blindly union noisy lists; use a robust strategy (trusted-source selection or consensus with normalization).\n            - Always write correspondence files for every evaluated pair to `output/runs/20260322_162759_restaurant/correspondences/` so cluster analysis uses current run artifacts.\n            - When passing correspondences into PyDI fusion, the required schema is `id1`/`id2`. Do not invent alternate required columns such as `id_l`/`id_r`.\n            \n            11. INVESTIGATOR ACTION PLAN (RANKED):\n            [\n  {\n    "action": "Enable/keep post-clustering as MaximumBipartiteMatching and adapt fusion output identity logic so fused records consistently retain source-specific IDs needed by validation (prefer existing kaggle380k_id / uber_eats_id / yelp_id columns or deterministic source-ID retention per cluster rather than arbitrary first prefix from _fusion_sources). If configurable in the adaptation stage, disable harmful singleton-driven evaluation rows or ensure singleton records still expose the proper source-prefixed IDs.",\n    "target_attributes": [\n      "post_clustering / fused entity identity"\n    ],\n    "priority_score": 0.35,\n    "confidence": 0.8,\n    "source": "