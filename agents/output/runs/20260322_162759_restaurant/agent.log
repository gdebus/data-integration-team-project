e": true,\n        "on_failure": "keep"\n      },\n      "postal_code": {\n        "output_type": "int",\n        "on_failure": "keep"\n      },\n      "country": {\n        "strip_whitespace": true,\n        "country_format": "alpha_2",\n        "on_failure": "keep"\n      },\n      "categories": {\n        "strip_whitespace": true\n      },\n      "rating_count": {\n        "output_type": "float",\n        "on_failure": "keep"\n      }\n    }\n  },\n  "llm_list_columns": [\n    "categories"\n  ],\n  "llm_reasoning": "Target uses US alpha-2 country codes, numeric postal_code, numeric house_number where possible, phone fields stored as digits without leading plus, and categories are list-like strings. Yelp and Kaggle phone_e164 values need e164 normalization then integer casting; Kaggle phone_raw also has plus-prefixed values. Uber Eats and Yelp rating_count should be float to match target. Yelp house_number includes hyphenated values in samples, so it is preserved as text aside from whitespace stripping.",\n  "datasets": {\n    "kaggle_small": {\n      "input_path": "output/runs/20260322_162759_restaurant/schema-matching/kaggle_small.parquet",\n      "output_path": "output/runs/20260322_162759_restaurant/normalization/attempt_1/kaggle_small.csv",\n      "row_count": 10000,\n      "id_column": "id",\n      "spec_applied": {\n        "phone_raw": {\n          "output_type": "int",\n          "on_failure": "keep",\n          "phone_format": "e164"\n        },\n        "phone_e164": {\n          "output_type": "int",\n          "on_failure": "keep",\n          "phone_format": "e164"\n        },\n        "house_number": {\n          "output_type": "int",\n          "on_failure": "keep"\n        },\n        "postal_code": {\n          "output_type": "int",\n          "on_failure": "keep"\n        },\n        "country": {\n          "strip_whitespace": true,\n          "country_format": "alpha_2",\n          "on_failure": "keep"\n        },\n        "categories": {\n          "strip_whitespace": true\n        }\n      },\n      "list_columns_applied": [\n        "categories"\n      ]\n    },\n    "uber_eats_small": {\n      "input_path": "output/runs/20260322_162759_restaurant/schema-matching/uber_eats_small.parquet",\n      "output_path": "output/runs/20260322_162759_restaurant/normalization/attempt_1/uber_eats_small.csv",\n      "row_count": 10000,\n      "id_column": "id",\n      "spec_applied": {\n        "house_number": {\n          "output_type": "int",\n          "on_failure": "keep"\n        },\n        "postal_code": {\n          "output_type": "int",\n          "on_failure": "keep"\n        },\n        "country": {\n          "strip_whitespace": true,\n          "country_format": "alpha_2",\n          "on_failure": "keep"\n        },\n        "categories": {\n          "strip_whitespace": true\n        },\n        "rating_count": {\n          "output_type": "float",\n          "on_failure": "keep"\n        }\n      },\n      "list_columns_applied": [\n        "categories"\n      ]\n    },\n    "yelp_small": {\n      "input_path": "output/runs/20260322_162759_restaurant/schema-matching/yelp_small.parquet",\n      "output_path": "output/runs/20260322_162759_restaurant/normalization/attempt_1/yelp_small.csv",\n      "row_count": 10000,\n      "id_column": "id",\n      "spec_applied": {\n        "phone_raw": {\n          "output_type": "int",\n          "on_failure": "keep"\n        },\n        "phone_e164": {\n          "output_type": "int",\n          "on_failure": "keep",\n          "phone_format": "e164"\n        },\n        "house_number": {\n          "output_type": "keep",\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        },\n        "postal_code": {\n          "output_type": "int",\n          "on_failure": "keep"\n        },\n        "country": {\n          "strip_whitespace": true,\n          "country_format": "alpha_2",\n          "on_failure": "keep"\n        },\n        "categories": {\n          "strip_whitespace": true\n        },\n        "rating_count": {\n          "output_type": "float",\n          "on_failure": "keep"\n        }\n      },\n      "list_columns_applied": [\n        "categories"\n      ]\n    }\n  },\n  "warnings": [],\n  "acceptance_gate": {\n    "requested": false,\n    "request": {},\n    "pending": {}\n  },\n  "reverted_to_original": false,\n  "created_at": "2026-03-22T16:28:13.130954"\n}\n    \n        Create evaluation code that:\n        - Uses the correct fusion strategy\n        - Loads the fused output\n        - Loads the gold standard evaluation set (validation in sealed mode, otherwise test)\n        - Prints structured evaluation metrics\n        - Prints chosen evaluation functions in a compact one-line summary\n        - If helper modules are imported from local files (e.g., list_normalization), use a robust fallback import pattern that works from output/code execution context.\n        - Does NOT require exact matching everywhere by default.\n\n        EVALUATION ROBUSTNESS RULES (MANDATORY):\n- Use validation-set representation as the normalization target for evaluation.\n- Normalize fused and gold columns to the SAME representation before evaluating.\n- For country-like columns, infer and apply a shared normalize_country output_format from the evaluation set (alpha_2/alpha_3/numeric/name/official_name).\n- For free-text/list-like columns, avoid strict exact comparisons unless values are canonical identifiers.\n  Prefer tokenized_match with an explicit threshold (for example 0.7-0.9) instead of exact-only semantics.\n- If using set-based comparison on textual lists, first canonicalize list elements consistently across fused and gold.\n- Choose the right evaluation function per attribute type:\n  * tokenized_match: names, titles, labels, artists, text fields (handles word reordering like "The Beatles" vs "Beatles, The")\n  * year_only_match: dates where only the year matters\n  * set_equality_match: list-like columns (tracks, genres, categories)\n  * numeric_tolerance_match: durations, prices, ratings (use reasonable tolerance)\n  * numeric_tolerance_match: also use for year/count columns stored as floats (e.g. publish_year, page_count) —\n    cast both fused and gold values to int before comparison to avoid 274.0 != 274 mismatches\n  * exact_match: IDs, codes, boolean fields\n- If the gold set does NOT contain a column (i.e. it is absent or all-null), do NOT evaluate that column.\n  Only evaluate columns that are present and meaningful in BOTH the fused and gold datasets.\n- IMPORTANT: When the gold set has a parent column (e.g. "tracks") but the fused output has sub-columns\n  derived from it (e.g. "tracks_track_name", "tracks_track_duration", "tracks_track_position"),\n  DROP the sub-columns from evaluation unless they have explicit corresponding columns in the gold set.\n  Evaluating derived sub-columns against a non-existent gold column produces zero accuracy and wastes\n  investigation cycles. Only evaluate attributes that have a direct 1:1 column match in the gold set.\n- IMPORTANT: Before evaluation, coerce numeric-like columns (publish_year, page_count, year, count, rating, score)\n  to a consistent type in BOTH fused and gold DataFrames. Common pattern:\n    for col in numeric_cols:\n        df[col] = pd.to_numeric(df[col], errors=\'coerce\')\n        if df[col].dropna().apply(float.is_integer).all():\n            df[col] = df[col].astype(\'Int64\')  # nullable int avoids 274.0 vs 274 mismatches\n  This prevents false mismatches from float vs int representation differences.\n- If the fused output contains an "eval_id" column, use fused_id_column="eval_id" (NOT "_id" or "id").\n  The eval_id column is pre-computed to map cluster IDs back to validation-set source IDs.\n        \n            Evaluation reasoning from prior pipeline run:\n            {\n  "action": "decide",\n  "diagnosis": "The dominant failure is not normalization or matching; it is fusion/output ID handling caused by keeping singleton records and extracting eval_id from arbitrary source prefixes. Matching quality is already high (F1 0.89-0.98, correspondence files non-empty, cluster analysis clean), yet 94.2% of errors are missing_fused_value and many mismatch samples have fused_id=\'nan\'. This means the evaluator cannot align most validation rows to the correct fused entity. Additionally, several low-accuracy attributes use suboptimal fusion resolvers/trust: the current trust map prefers yelp_small over better sources for source/name/address_line1, and map_url/source/name/rating/address_line1 evidence shows different best resolvers. So the next fix is pipeline adaptation: correct post-clustering/output identity selection and update attribute fusers/trust, while preserving the 24 already-good attributes.",\n  "next_node": "pipeline_adaption",\n  "reasoning": "Routing to matching/blocking is not justified because correspondences exist for all pairs, blocking probes found no recall issues, and pairwise F1 is strong. Routing to normalization is also not primary because the main error class is missing fused output, not systematic format mismatch; the one visible name format issue is minor compared with the alignment problem. pipeline_adaption is the correct frozen-stage lever because it can change post-clustering and fusion strategy. The post-clustering recommendation is already MaximumBipartiteMatching, and current include_singletons/eval-id behavior is likely emitting many singleton fused rows whose chosen eval_id does not correspond to the validation IDs, producing blank fused matches. On top of that, resolver evidence from source-vs-validation comparison is strong: uber_eats_small is best for source/name/address_line1, yelp_small is best for rating and often for map_url, so current prefer_higher_trust(yelp>kaggle>uber) is actively wrong for several attributes. Protected attributes above 85% should be left untouched.",\n  "ceiling_assessment": "With current