idates=candidates_goodreads_metabooks,\n    comparators=comparators_goodreads_metabooks,\n    weights=[0.42, 0.23, 0.12, 0.15, 0.08],\n    threshold=threshold_metabooks_small_goodreads_small,\n    id_column="id",\n)\n\nif rb_correspondences_amazon_goodreads.empty:\n    raise ValueError("Empty correspondences for pair amazon_small_goodreads_small")\nif rb_correspondences_amazon_metabooks.empty:\n    raise ValueError("Empty correspondences for pair amazon_small_metabooks_small")\nif rb_correspondences_goodreads_metabooks.empty:\n    raise ValueError("Empty correspondences for pair goodreads_small_metabooks_small")\n\n# === 6. SAVE CORRESPONDENCES (MANDATORY) ===\nCORR_DIR = os.path.join(OUTPUT_DIR, "correspondences")\nos.makedirs(CORR_DIR, exist_ok=True)\n\nrb_correspondences_amazon_goodreads.to_csv(\n    os.path.join(CORR_DIR, "correspondences_amazon_small_goodreads_small.csv"),\n    index=False,\n)\nrb_correspondences_amazon_metabooks.to_csv(\n    os.path.join(CORR_DIR, "correspondences_amazon_small_metabooks_small.csv"),\n    index=False,\n)\nrb_correspondences_goodreads_metabooks.to_csv(\n    os.path.join(CORR_DIR, "correspondences_goodreads_small_metabooks_small.csv"),\n    index=False,\n)\n\nall_rb_correspondences = pd.concat(\n    [\n        rb_correspondences_amazon_goodreads,\n        rb_correspondences_amazon_metabooks,\n        rb_correspondences_goodreads_metabooks,\n    ],\n    ignore_index=True,\n)\nfrom PyDI.entitymatching import MaximumBipartiteMatching\n\n\n\n# === 7. POST-CLUSTERING ===\nprint("Applying Post-Clustering")\n\nrefined_amazon_goodreads = MaximumBipartiteMatching().cluster(rb_correspondences_amazon_goodreads)\nrefined_amazon_metabooks = rb_correspondences_amazon_metabooks\nrefined_goodreads_metabooks = rb_correspondences_goodreads_metabooks\n\nall_rb_correspondences = pd.concat(\n    [\n        refined_amazon_goodreads,\n        refined_amazon_metabooks,\n        refined_goodreads_metabooks,\n    ],\n    ignore_index=True,\n)\n\n# === 8. DATA FUSION ===\nprint("Fusing Data")\n\ntrust_map = {"amazon_small": 1, "goodreads_small": 2, "metabooks_small": 3}\npage_count_trust_map = {"amazon_small": 3, "goodreads_small": 2, "metabooks_small": 1}\n\nstrategy = DataFusionStrategy("fusion_strategy")\n\ntrust_map_publisher = {"metabooks_small": 3, "goodreads_small": 2, "amazon_small": 1}\ntrust_map_title = {"metabooks_small": 3, "goodreads_small": 2, "amazon_small": 1}\ntrust_map_page_count = {"amazon_small": 3, "goodreads_small": 2, "metabooks_small": 1}\nstrategy.add_attribute_fuser("title", prefer_higher_trust, trust_map=trust_map_title)\nstrategy.add_attribute_fuser("author", longest_string)\nstrategy.add_attribute_fuser("publisher", prefer_higher_trust, trust_map=trust_map_publisher)\nstrategy.add_attribute_fuser("isbn_clean", prefer_higher_trust, trust_map={"amazon_small": 3, "goodreads_small": 2, "metabooks_small": 2})\n\nstrategy.add_attribute_fuser("publish_year", prefer_higher_trust, trust_map={"amazon_small": 3, "goodreads_small": 2, "metabooks_small": 2})\nstrategy.add_attribute_fuser("rating", median)\nstrategy.add_attribute_fuser("numratings", maximum)\nstrategy.add_attribute_fuser("page_count", prefer_higher_trust, trust_map=trust_map_page_count)\nstrategy.add_attribute_fuser("price", median)\n\nstrategy.add_attribute_fuser("language", prefer_higher_trust, trust_map={"amazon_small": 3, "goodreads_small": 2, "metabooks_small": 2})\nstrategy.add_attribute_fuser("bookformat", most_complete)\nstrategy.add_attribute_fuser("edition", most_complete)\n\nstrategy.add_attribute_fuser("genres", prefer_higher_trust, trust_map={"goodreads_small": 3, "amazon_small": 2, "metabooks_small": 1})\n\n\n\n\n# === 8. RUN FUSION ===\nFUSION_DIR = os.path.join(OUTPUT_DIR, "data_fusion")\nos.makedirs(FUSION_DIR, exist_ok=True)\n\nengine = DataFusionEngine(\n    strategy,\n    debug=True,\n    debug_format="json",\n    debug_file=os.path.join(FUSION_DIR, "debug_fusion_data.jsonl"),\n)\n\nfused_result = engine.run(\n    datasets=[amazon_small, goodreads_small, metabooks_small],\n    correspondences=all_rb_correspondences,\n    id_column="id",\n    include_singletons=True,\n)\n\n\n# --- Eval ID: extract source ID matching validation prefix for reliable evaluation ---\nimport ast as _ast\n_EVAL_PREFIX = "amazon_"\ndef _extract_eval_id(row):\n    try:\n        sources = _ast.literal_eval(str(row.get("_fusion_sources", "[]")))\n        if isinstance(sources, (list, tuple)):\n            for sid in sources:\n                if str(sid).startswith(_EVAL_PREFIX):\n                    return str(sid)\n    except Exception:\n        pass\n    return str(row.get("_id", row.get("id", "")))\nfused_result["eval_id"] = fused_result.apply(_extract_eval_id, axis=1)\nfused_result.to_csv(os.path.join(FUSION_DIR, "fusion_data.csv"), index=False)\n    \n        Dataset profiles:\n        {\n  "output/runs/20260322_155058_books/schema-matching/amazon_small.parquet": "{\\"rows\\": 10000, \\"columns\\": 6, \\"nulls_total\\": 1, \\"nulls_per_column\\": {\\"id\\": 0, \\"title\\": 0, \\"author\\": 0, \\"publish_year\\": 0, \\"publisher\\": 1, \\"isbn_clean\\": 0}, \\"dtypes\\": {\\"id\\": \\"object\\", \\"title\\": \\"string\\", \\"author\\": \\"string\\", \\"publish_year\\": \\"Int16\\", \\"publisher\\": \\"string\\", \\"isbn_clean\\": \\"string\\"}}",\n  "output/runs/20260322_155058_books/schema-matching/goodreads_small.parquet": "{\\"rows\\": 10000, \\"columns\\": 14, \\"nulls_total\\": 1435, \\"nulls_per_column\\": {\\"id\\": 0, \\"title\\": 0, \\"author\\": 0, \\"rating\\": 0, \\"numratings\\": 0, \\"language\\": 0, \\"genres\\": 0, \\"bookformat\\": 0, \\"edition\\": 0, \\"page_count\\": 300, \\"publisher\\": 0, \\"publish_year\\": 159, \\"price\\": 976, \\"isbn_clean\\": 0}, \\"dtypes\\": {\\"id\\": \\"object\\", \\"title\\": \\"string\\", \\"author\\": \\"string\\", \\"rating\\": \\"float64\\", \\"numratings\\": \\"Int64\\", \\"language\\": \\"string\\", \\"genres\\": \\"object\\", \\"bookformat\\": \\"string\\", \\"edition\\": \\"string\\", \\"page_count\\": \\"Int32\\", \\"publisher\\": \\"string\\", \\"publish_year\\": \\"Int16\\", \\"price\\": \\"float64\\", \\"isbn_clean\\": \\"string\\"}}",\n  "output/runs/20260322_155058_books/schema-matching/metabooks_small.parquet": "{\\"rows\\": 10000, \\"columns\\": 12, \\"nulls_total\\": 8214, \\"nulls_per_column\\": {\\"id\\": 0, \\"title\\": 0, \\"author\\": 0, \\"rating\\": 0, \\"numratings\\": 0, \\"language\\": 49, \\"genres\\": 0, \\"publisher\\": 73, \\"page_count\\": 1017, \\"price\\": 957, \\"publish_year\\": 6118, \\"isbn_clean\\": 0}, \\"dtypes\\": {\\"id\\": \\"object\\", \\"title\\": \\"string\\", \\"author\\": \\"string\\", \\"rating\\": \\"float64\\", \\"numratings\\": \\"Int64\\", \\"language\\": \\"string\\", \\"genres\\": \\"object\\", \\"publisher\\": \\"string\\", \\"page_count\\": \\"Int32\\", \\"price\\": \\"Float32\\", \\"publish_year\\": \\"Int16\\", \\"isbn_clean\\": \\"string\\"}}"\n}\n    \n        The fused output is located at (use this EXACT path, not the one from the example):\n        output/runs/20260322_155058_books/data_fusion/fusion_data.csv\n\n        The evaluation output must be saved to:\n        output/runs/20260322_155058_books/pipeline_evaluation/pipeline_evaluation.json\n\n        The evaluation stage is:\n        validation\n\n        The evaluation set is located at:\n        input/datasets/books/testsets/validation_set.csv\n\n        The first row of the evaluation set looks like the following:\n        {\'id\': \'amazon_249834\', \'isbn_clean\': 618250743, \'title_provenance\': \'goodreads_8611\', \'title\': \'Carry On, Mr. Bowditch\', \'author_provenance\': \'metabooks_60346\', \'author\': \'Jean Lee Latham\', \'language_provenance\': \'metabooks_60346\', \'language\': \'English\', \'genres_provenance\': \'goodreads_8611+metabooks_60346\', \'genres\': \'Historical Fiction, Fiction, Classics, Young Adult, Childrens, Historical, School, Adventure, Middle Grade, Juvenile, Teen, Young Adult, Literature, Fiction\', \'publisher_provenance\': \'metabooks_60346\', \'publisher\': \'Clarion Books\', \'publisher_year_provenance\': \'amazon_249834\', \'publish_year\': 2003, \'page_count_provenance\': \'metabooks_60346\', \'page_count\': 256}\n\n        Normalization directives and report from previous steps:\n        {\n  "specs": {\n    "amazon_small": {},\n    "goodreads_small": {\n      "author": {\n        "strip_whitespace": true,\n        "on_failure": "keep"\n      },\n      "page_count": {\n        "output_type": "int",\n        "on_failure": "keep"\n      },\n      "publish_year": {\n        "output_type": "int",\n        "on_failure": "keep"\n      },\n      "publisher": {\n        "strip_whitespace": true,\n        "on_failure": "keep"\n      }\n    },\n    "metabooks_small": {\n      "page_count": {\n        "output_type": "int",\n        "on_failure": "keep"\n      },\n      "publish_year": {\n        "output_type": "int",\n        "on_failure": "keep"\n      },\n      "publisher": {\n        "strip_whitespace": true,\n        "on_failure": "keep"\n      }\n    }\n  },\n  "list_columns": []\n}\n        {\n  "status": "success",\n  "attempt": 2,\n  "max_attempts": 3,\n  "validation_set": "input/datasets/books/testsets/validation_set.csv",\n  "llm_specs": {\n    "amazon_small": {},\n    "goodreads_small": {\n      "author": {\n        "strip_whitespace": true,\n        "on_failure": "keep"\n      },\n      "page_count": {\n        "output_type": "int",\n        "on_failure": "keep"\n      },\n      "publish_year": {\n        "output_type": "int",\n        "on_failure": "keep"\n      },\n      "publisher": {\n        "strip_whitespace": true,\n        "on_failure": "keep"\n      }\n    },\n    "metabooks_small": {\n      "page_count": {\n        "output_type": "int",\n        "on_failure": "keep"\n      },\n      "publish_year": {\n        "output_type": "int",\n        "on_failure": "keep"\n      },\n      "publisher": {\n        "strip_whitespace": true,\n        "on_failure": "keep"\n      }\n    }\n  },\n  "llm_list_columns": [],\n  "llm_reasoning": "Target style preserves title/author/publisher capitalization and uses plain integer values for publish_year and page_count. Identifier columns like id and isbn_clean are preserved. Genres already appear as comma-separated strings matching target style, so no list normalization is added. Previous errors likely came from over-normalizing genres; this spec avoids transforming genres and only applies minimal publisher whitespace cleanup and numeric casting where source floats should match target ints.",\n  "datasets": {\n    "amazon_small": {\n      "input_path": "output/runs/20260322_155058_books/normalization/attempt_1/amazon_small.csv",\n      "output_path": "output/runs/20260322_155058_books/normalization/attempt_2/amazon_small.csv",\n      "row_count": 10000,\n      "id_column": "id",\n      "spec_applied": {},\n      "list_columns_applied": []\n    },\n    "goodreads_small": {\n      "input_path": "output/runs/20260322_155058_books/normalization/attempt_1/goodreads_small.csv",\n      "output_path": "output/runs/20260322_155058_books/normalization/attempt_2/goodreads_small.csv",\n      "row_count": 10000,\n      "id_column": "id",\n      "spec_applied": {\n        "author": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        },\n        "page_count": {\n          "output_type": "int",\n          "on_failure": "keep"\n        },\n        "publish_year": {\n          "output_type": "int",\n          "on_failure": "keep"\n        },\n        "publisher": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        }\n      },\n      "list_columns_applied": []\n    },\n    "metabooks_small": {\n      "input_path": "output/runs/20260322_155058_books/normalization/attempt_1/metabooks_small.csv",\n      "output_path": "output/runs/20260322_155058_books/normalization/attempt_2/metabooks_small.csv",\n      "row_count": 10000,\n      "id_column": "id",\n      "spec_applied": {\n        "page_count": {\n          "output_type": "int",\n          "on_failure": "keep"\n        },\n        "publish_year": {\n          "output_type": "int",\n          "on_failure": "keep"\n        },\n        "publisher": {\n          "strip_whitespace": true,\n          "on_failure": "keep"\n        }\n      },\n      "list_columns_applied": []\n    }\n  },\n  "warnings": [],\n  "acceptance_gate": {\n    "requested": false,\n    "request": {},\n    "pending": {}\n  },\n  "reverted_to_original": false,\n  "created_at": "2026-03-22T15:54:42.870754"\n}\n    \n        Create evaluation code that:\n        - Uses the correct fusion strategy\n        - Loads the fused output\n        - Loads the gold standard evaluation set (validation in sealed mode, otherwise test)\n        - Prints structured evaluation metrics\n        - Prints chosen evaluation functions in a compact one-line summary\n        - If helper modules are imported from local files (e.g., list_normalization), use a robust fallback import pattern that works from output/code execution context.\n        - Does NOT require exact matching everywhere by default.\n\n        EVALUATION ROBUSTNESS RULES (MANDATORY):\n- Use validation-set representation as the normalization target for evaluation.\n- Normalize fused and gold columns to the SAME representation before evaluating.\n- For country-like columns, infer and apply a shared normalize_country output_format from the evaluation set (alpha_2/alpha_3/numeric/name/official_name).\n- For free-text/list-like columns, avoid strict exact comparisons unless values are canonical identifiers.\n  Prefer tokenized_match with an explicit threshold (for example 0.7-0.9) instead of exact-only semantics.\n- If using set-based comparison on textual lists, first canonicalize list elements consistently across fused and gold.\n- Choose the right evaluation function per attribute type:\n  * tokenized_match: names, titles, labels, artists, text fields (handles word reordering like "The Beatles" vs "Beatles, The")\n  * year_only_match: dates where only the year matters\n  * set_equality_match: list-like columns (tracks, genres, categories)\n  * numeric_tolerance_match: durations, prices, ratings (use reasonable tolerance)\n  * numeric_tolerance_match: also use for year/count columns stored as floats (e.g. publish_year, page_count) —\n    cast both fused and gold values to int before comparison to avoid 274.0 != 274 mismatches\n  * exact_match: IDs, codes, boolean fields\n- If the gold set does NOT contain a column (i.e. it is absent or all-null), do NOT evaluate that column.\n  Only evaluate columns that are present and meaningful in BOTH the fused and gold datasets.\n- IMPORTANT: When the gold set has a parent column (e.g. "tracks") but the fused output has sub-columns\n  derived from it (e.g. "tracks_track_name", "tracks_track_duration", "tracks_track_position"),\n  DROP the sub-columns from evaluation unless they have explicit corresponding columns in the gold set.\n  Evaluating derived sub-columns against a non-existent gold column produces zero accuracy and wastes\n  investigation cycles. Only evaluate attributes that have a direct 1:1 column match in the gold set.\n- IMPORTANT: Before evaluation, coerce numeric-like columns (publish_year, page_count, year, count, rating, score)\n  to a consistent type in BOTH fused and gold DataFrames. Common pattern:\n    for col in numeric_cols:\n        df[col] = pd.to_numeric(df[col], errors=\'coerce\')\n        if df[col].dropna().apply(float.is_integer).all():\n            df[col] = df[col].astype(\'Int64\')  # nullable int avoids 274.0 vs 274 mismatches\n  This prevents false mismatches from float vs int representation differences.\n- If the fused output contains an "eval_id" column, use fused_id_column="eval_id" (NOT "_id" or "id").\n  The eval_id column is pre-computed to map cluster IDs back to validation-set source IDs.\n        \n            Evaluation reasoning from prior pipeline run:\n            {\n  "action": "decide",\n  "diagnosis": "The main remaining errors are caused by fusion/post-fusion formatting choices, but the first fix must be normalization because the worst attribute with 0% accuracy (genres) is failing due to source/target format mismatch before fusion. The validation set expects genres as a plain comma-separated string/list of individual items, while the current pipeline normalizes sources into list cells and then fuses with union(separator=\'; \'), producing nested/composite list elements like [\'historical fiction, fiction, ...\'] instead of atomic genres. In addition, title and author mismatches are systematic source-format issues: one source often includes series suffixes or role annotations (e.g. \'(The Birmingham Family, 1)\', \'(Goodreads Author)\', \'(Illustrator)\'), while validation expects cleaned canonical strings. Publisher/title source-vs-validation evidence also shows metabooks_small is the best source, but those fusion changes should wait until normalization fixes the target-alignment issues. Blocking and matching are not the bottleneck: correspondences exist, blocking recall probes show no issue, and pairwise matching F1 is already solid.",\n  "next_node": "normalization_node",\n  "reasoning": "Per routing rules, any fix that requires transforming source data before fusion must go to normalization_node. The highest-impact improvable errors are title and author format mismatches, and genres is entirely a pre-fusion representation mismatch. These cannot be safely fixed in pipeline_adaption because fusion is frozen to resolver/trust changes only there. Protected attributes to preserve: language (90%), isbn_clean (100%), publish_year (100%) and the other >85% attributes should not be altered. After normalization, a follow-up pipeline_adaption pass will likely still be needed to change trust/resolvers for title and publisher toward metabooks_small, but normalization is the correct first move because it addresses the target-format incompatibilities directly and removes avoidable mismatches without touching strong attributes.",\n  "ceiling_assessment": "With current entity matching/blocking structure, overall accuracy appears capped around 78.1%. A normalization pass should recover most of the improvable headroom (roughly +7% to +10% overall) by fixing title/author formatting and genres representation. Publisher and page_count remain partly structurally limited because sources genuinely disagree; even after normalization, perfect accuracy is unlikely without better source-specific fusion choices. A realistic near-term target after normalization plus later fusion adaptation is mid-to-high 70s overall.",\n  "recommendations": [\n    {\n      "attribute": "genres",\n      "issue": "Validation expects atomic genre items in a comma-separated representation, but current data enters fusion as list-like cells containing whole comma-joined strings from each source; union then preserves those composite strings as elements, causing systematic list_format_mismatch and 0% accuracy.",\n      "fix": "In normalization_node, normalize goodreads_small.genres and metabooks_small.genres into true atomic lists by splitting on commas, trimming whitespace, preserving original case, and removing empty items; ensure amazon_small missing values stay null/empty rather than stringified. Target output should align with validation\'s item granularity, not semicolon-joined composite strings.",\n      "resolver_reasoning": "This is not primarily a resolver-selection problem. Probe evidence shows fuzzy 100% for goodreads_small and metabooks_small against validation, meaning the content is present but formatted wrong. Validation samples show combined provenance from goodreads+metabooks, so the best downstream resolver remains union once inputs are atomized. Voting would drop complementary genres and perform worse; intersection would be too strict; prefer_higher_trust would ignore complementary coverage. First fix the pre-fusion structure so union can work correctly.",\n      "class": "improvable",\n      "expected_impact": 0.0\n    },\n    {\n      "attribute": "title",\n      "issue": "Systematic source formatting noise: titles often include appended series/imprint text in parentheses, while validation usually wants the canonical title string. Current fusion uses longest_string, which actively favors the noisy variant.",\n      "fix": "In normalization_node, add source-specific title cleanup rules that strip trailing parenthetical series/imprint annotations when they are auxiliary metadata rather than core title content, especially for amazon_small and goodreads_small. Preserve meaningful parenthetical content when it is part of the canonical validation title. Keep case/title text otherwise unchanged to match validation.",\n      "resolver_reasoning": "Source-vs-validation comparison shows metabooks_small exact=88%, goodreads_small=67%, amazon_small=20%. That means the correct canonical form is usually already present in metabooks_small, and longest_string is the wrong bias because it prefers expanded noisy titles. After normalization, a later pipeline_adaption should switch title to prefer_higher_trust with metabooks_small > goodreads_small > amazon_small. Voting is weaker because titles rarely have exact agreement when one source appends series text; shortest_string could help some cases but would fail where the canonical validation title legitimately includes a subtitle/volume phrase. prefer_higher_trust after cleanup is the best fit.",\n      "class": "improvable",\n      "expected_impact": 0.044\n    },\n    {\n      "attribute": "author",\n      "issue": "Author values contain role suffixes and extra contributors, e.g. \'(Goodreads Author)\', \'(Adaptation), Sharon Ross (Illustrator)\', while validation expects the principal author only.",\n      "fix": "In normalization_node, add source-specific author cleanup: remove platform suffixes like \'(Goodreads Author)\', strip contributor-role annotations in parentheses, and when multiple contributors are present with role labels, keep the main author matching the leading canonical person name used by validation. Preserve mixed/title case as in validation.",\n      "resolver_reasoning": "Mismatch examples are clearly format-driven, not entity-linking errors. Current longest_string encourages extra contributor text, so cleaning source strings first is the safest first step. A later fusion pass may keep prefer_higher_trust or favour_sources if diagnostics confirm one source is consistently canonical, but normalization should come first because the source values themselves are in the wrong target format. Alternatives like shortest_string are risky because they could truncate legitimate multi-part names.",\n      "class": "improvable",\n      "expected_impact": 0.025\n    },\n    {\n      "attribute": "publisher",\n      "issue": "Half the errors are source-choice or publisher hierarchy differences (imprint vs parent publisher), with some additional formatting noise like HTML entities and division suffixes.",\n      "fix": "Do not change in normalization first beyond safe decoding/cleanup if supported (e.g. \'&amp;\' -> \'&\', trimming corporate suffix noise only when it matches validation conventions). Preserve for now and revisit in pipeline_adaption after normalization rerun.",\n      "resolver_reasoning": "Evidence strongly favors metabooks_small (88% exact vs goodreads 67% vs amazon 20%), so the best downstream resolver is prefer_higher_trust with trust order metabooks_small > goodreads_small > amazon_small. longest_string is poor because it selects expanded variants like \'Simon & Schuster (Trade Division)\' and \'Vintage Books USA\'. Voting may fail when sources disagree on imprint/parent labels. However, because the immediate required fixes are pre-fusion formatting issues and routing must prioritize normalization first, publisher trust-map changes should be deferred to the next iteration.",\n      "class": "structurally_limited",\n      "expected_impact": 0.025\n    },\n    {\n      "attribute": "page_count",\n      "issue": "Sources disagree materially on numeric values, and one source (amazon_small) is often null/poor. Errors are not primarily normalization-driven.",\n      "fix": "No normalization change recommended now; revisit in pipeline_adaption after normalization if needed, likely replacing maximum with prefer_higher_trust or favour_sources toward metabooks_small based on full validation comparison.",\n      "resolver_reasoning": "Current maximum is wrong when larger values are edition-specific or inflated, as shown by 251 vs expected 256 and 554 vs expected 512. Probe summary indicates metabooks_small is closest by fuzzy rate and supplies validation provenance in samples. Voting is weak for numerics with three-way disagreement; median with two non-null disagreeing sources may still miss exact validation; prefer_higher_trust toward metabooks_small is the most evidence-based next fusion candidate. But this is secondary to normalization because page_count is structurally limited and lower-impact.",\n      "class": "structurally_limited",\n      "expected_impact": 0.013\n    }\n  ]\n}\n            \n            Compact summary from the prior reasoning:\n            {\n  "root_cause": "The main remaining errors are caused by fusion/post-fusion formatting choices, but the first fix must be normalization because the worst attribute with 0% accuracy (genres) is failing due to source/target format mismatch before fusion. The validation set expects genres as a plain comma-separated string/list of individual items, while the current pipeline normalizes sources into list cells and then fuses with union(separator=\'; \'), producing nested/composite list elements like [\'historical fiction, fiction, ...\'] instead of atomic genres. In addition, title and author mismatches are systematic source-format issues: one source often includes series suffixes or role annotations (e.g. \'(The Birmingham Family, 1)\', \'(Goodreads Author)\', \'(Illustrator)\'), while validation expects cleaned canonical strings. Publisher/title source-vs-validation evidence also shows metabooks_small is the best source, but those fusion changes should wait until normalization fixes the target-alignment issues. Blocking and matching are not the bottleneck: correspondences exist, blocking recall probes show no issue, and pairwise matching F1 is already solid.",\n  "next_step": "Per routing rules, any fix that requires transforming source data before fusion must go to normalization_node. The highest-impact improvable errors are title and author format mismatches, and genres is entirely a pre-fusion representation mismatch. These cannot be safely fixed in pipeline_adaption because fusion is frozen to resolver/trust changes only there. Protected attributes to preserve: language (90%), isbn_clean (100%), publish_year (100%) and the other >85% attributes should not be altered. After normalization, a follow-up pipeline_adaption pass will likely still be needed to change trust/resolvers for title and publisher toward metabooks_small, but normalization is the correct first move because it addresses the target-format incompatibilities directly and removes avoidable mismatches without touching strong attributes.",\n  "takeaway": "The main remaining errors are caused by fusion/post-fusion formatting choices, but the first fix must be normalization because the worst attribute with 0% accuracy (genres) is failing due to source/target format mismatch before fusion. The validation set expects genres as a plain comma-separated string/list of individual items, while the current pipeline normalizes sources into list cells and then fuses with union(separator=\'; \'), producing nested/composite list elements like [\'historical fiction, fiction, ...\'] instead of atomic genres. In ad