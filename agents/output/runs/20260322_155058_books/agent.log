ort from previous steps:\n        {\n  "specs": {\n    "amazon_small": {},\n    "goodreads_small": {\n      "author": {\n        "strip_whitespace": true,\n        "on_failure": "keep"\n      },\n      "page_count": {\n        "output_type": "int",\n        "on_failure": "keep"\n      },\n      "publish_year": {\n        "output_type": "int",\n        "on_failure": "keep"\n      },\n      "publisher": {\n        "strip_whitespace": true,\n        "on_failure": "keep"\n      }\n    },\n    "metabooks_small": {\n      "genres": {\n        "strip_whitespace": true,\n        "on_failure": "keep"\n      },\n      "publisher": {\n        "strip_whitespace": true,\n        "on_failure": "keep",\n        "case": "title"\n      },\n      "page_count": {\n        "output_type": "int",\n        "on_failure": "keep"\n      },\n      "publish_year": {\n        "output_type": "int",\n        "on_failure": "keep"\n      }\n    }\n  },\n  "list_columns": []\n}\n        {\n  "status": "success",\n  "attempt": 3,\n  "max_attempts": 3,\n  "validation_set": "input/datasets/books/testsets/validation_set.csv",\n  "llm_specs": {\n    "amazon_small": {},\n    "goodreads_small": {\n      "author": {\n        "strip_whitespace": true,\n        "on_failure": "keep"\n      },\n      "page_count": {\n        "output_type": "int",\n        "on_failure": "keep"\n      },\n      "publish_year": {\n        "output_type": "int",\n        "on_failure": "keep"\n      },\n      "publisher": {\n        "strip_whitespace": true,\n        "on_failure": "keep"\n      }\n    },\n    "metabooks_small": {\n      "genres": {\n        "strip_whitespace": true,\n        "on_failure": "keep"\n      },\n      "publisher": {\n        "strip_whitespace": true,\n        "on_failure": "keep",\n        "case": "title"\n      },\n      "page_count": {\n        "output_type": "int",\n        "on_failure": "keep"\n      },\n      "publish_year": {\n        "output_type": "int",\n        "on_failure": "keep"\n      }\n    