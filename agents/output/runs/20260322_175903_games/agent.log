loper"\n    ],\n    "priority_score": 0.008,\n    "confidence": 0.8,\n    "source": "investigation",\n    "attribute_class": "structurally_limited"\n  },\n  {\n    "action": "Keep prefer_higher_trust with trust_map={\'sales\':5,\'metacritic\':2,\'dbpedia\':1}.",\n    "target_attributes": [\n      "criticScore"\n    ],\n    "priority_score": 0.0,\n    "confidence": 0.8,\n    "source": "investigation",\n    "attribute_class": "structurally_limited"\n  },\n  {\n    "action": "Keep prefer_higher_trust but correct the trust map to {\'metacritic\':5,\'sales\':2,\'dbpedia\':1}. Do not spend the next iteration on alternative resolvers for this attribute.",\n    "target_attributes": [\n      "userScore"\n    ],\n    "priority_score": 0.0,\n    "confidence": 0.8,\n    "source": "investigation",\n    "attribute_class": "structurally_limited"\n  },\n  {\n    "action": "Preserve MaximumBipartiteMatching and ensure fusion continues to use the refined correspondences only.",\n    "target_attributes": [\n      "post_clustering"\n    ],\n    "priority_score": 0.005,\n    "confidence": 0.8,\n    "source": "investigation",\n    "attribute_class": "improvable"\n  }\n]\n\n            Implement highest-priority actions first.\n            Do not implement low-confidence actions unless supported by additional evidence.\n\n            CRITICAL — PROTECT WORKING ATTRIBUTES:\n            If the action plan recommends changing a fusion resolver for an attribute that\n            already has high accuracy (>80%), DO NOT change it unless the plan explicitly\n            acknowledges the regression risk and provides strong evidence that the change\n            will not hurt that attribute. Keeping a working resolver is always safer than\n            speculative changes.\n            \n            11b. GENERIC FUSION GUIDANCE FROM DIAGNOSTICS:\n            {\n  "mismatch_classifications": {\n    "userScore": {\n      "value_mismatch": 5\n    },\n    "developer": {\n      "value_mismatch": 4,\n   